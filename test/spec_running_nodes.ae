// spec_running_nodes.ae — the "2+2=4" test as an Aeocha BDD spec: boot REAL
// containers through aeo's driver and assert they compute and communicate.
// The describe/it form of demo_running_nodes.ae.
//
//   sh test/run-spec.sh test/spec_running_nodes.ae    (or via --lib, see below)
//   ae run test/spec_running_nodes.ae --lib lib --lib ../aeocha
//
// Needs a container engine (podman/docker) on PATH; no root.
//
// Three escalating it-blocks:
//   1. a node is alive          — driver up + probe.
//   2. a node COMPUTES          — exec `echo $((2+2))` in it → "4".
//   3. nodes COMMUNICATE        — a server node serves "42"; a client node
//      reaches it over a shared network → "42".
//
// HONESTY: the boot/exec/probe/capture all run through aeo's driver. The
// shared network is test scaffolding (aeo doesn't GENERATE networks from
// ip() yet). The bhyve/nested tiers aren't exercised here — this is the
// container tier, fully runnable today.

import aeocha
import driver_linux
import std.string
import std.os (run_capture)
import std.list

IMG() -> string { return "docker.io/library/busybox:latest" }
NET() -> string { return "aeo-rn-net" }

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "running nodes (real containers via aeo's driver)") {

        // Bring up the shared net + the calc node before each scenario,
        // tear it all down after — so each it-block is independent.
        aeocha.before_each() callback {
            _cleanup()
            if string.length(driver_linux.engine_resolve("")) > 0 {
                _net_create()
                _run_on_net("aeo-calc", "sleep 600")
            }
        }
        aeocha.after_each() callback {
            _cleanup()
        }

        aeocha.it("boots a node that is alive (up + probe)") callback {
            if _no_engine() == 1 {
                aeocha.expect_int(1).to_be_truthy()
            } else {
                aeocha.expect_int(driver_linux.probe("aeo-calc", "", "")).to_equal(1)
            }
        }

        aeocha.it("a node COMPUTES: 2+2=4 and 40+2=42 (exec_capture)") callback {
            if _no_engine() == 1 {
                aeocha.expect_int(1).to_be_truthy()
            } else {
                aeocha.expect_str(driver_linux.exec_capture("aeo-calc", "echo $((2 + 2))", "")).to_equal_str("4")
                aeocha.expect_str(driver_linux.exec_capture("aeo-calc", "echo $((40 + 2))", "")).to_equal_str("42")
            }
        }

        aeocha.it("two nodes COMMUNICATE across the shared network") callback {
            if _no_engine() == 1 {
                aeocha.expect_int(1).to_be_truthy()
            } else {
                _run_on_net("aeo-server", "while true; do echo 42 | nc -l -p 8080; done")
                sleep(2000)   // let the listener bind
                got = driver_linux.exec_capture("aeo-calc", "nc aeo-server 8080", "")
                aeocha.expect_str(got).to_equal_str("42")
            }
        }

        aeocha.it("a node is GONE after driver down") callback {
            if _no_engine() == 1 {
                aeocha.expect_int(1).to_be_truthy()
            } else {
                driver_linux.down("aeo-calc", "")
                aeocha.expect_int(driver_linux.probe("aeo-calc", "", "")).to_equal(0)
            }
        }
    }

    aeocha.run_summary(fw)
}

// ---- helpers ----

_no_engine() -> int {
    if string.length(driver_linux.engine_resolve("")) == 0 {
        return 1
    }
    return 0
}

// scaffolding: a shared network + containers joined to it (what aeo will
// generate from ip()/system networking later).
_net_create() {
    av = list_new()
    list_add(av, "network")
    list_add(av, "create")
    list_add(av, NET())
    _o, _s, _e = run_capture(_engine(), av, null)
    list_free(av)
}

_run_on_net(nm: string, cmd: string) {
    av = list_new()
    list_add(av, "run")
    list_add(av, "-d")
    list_add(av, "--replace")
    list_add(av, "--name")
    list_add(av, nm)
    list_add(av, "--network")
    list_add(av, NET())
    list_add(av, IMG())
    list_add(av, "/bin/sh")
    list_add(av, "-c")
    list_add(av, cmd)
    _o, _s, _e = run_capture(_engine(), av, null)
    list_free(av)
}

_cleanup() {
    if _no_engine() == 1 {
        return
    }
    _rm("aeo-calc")
    _rm("aeo-server")
    nv = list_new()
    list_add(nv, "network")
    list_add(nv, "rm")
    list_add(nv, "-f")
    list_add(nv, NET())
    _o, _s, _e = run_capture(_engine(), nv, null)
    list_free(nv)
}

_rm(nm: string) {
    av = list_new()
    list_add(av, "rm")
    list_add(av, "-f")
    list_add(av, nm)
    _o, _s, _e = run_capture(_engine(), av, null)
    list_free(av)
}

_engine() -> string {
    return driver_linux.engine_resolve("")
}
