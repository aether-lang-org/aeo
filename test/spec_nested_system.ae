// spec_nested_system.ae — the nested-system demo as an Aeocha BDD spec.
//
// The describe/it form of test/demo_nested_system.ae: it declares the same
// two-tier system (a bhyve VM containing a redis cache + a Python service
// that depends on it) and verifies it. Two describe blocks:
//
//   "nested system (declaration)"  — data-model assertions. Run anywhere,
//                                     instant, no deployment.
//   "live deployment"              — HTTP arithmetic + cache checks against
//                                     a DEPLOYED system. Gated on AEO_VERIFY=1;
//                                     skipped otherwise.
//
// Run (aeocha must be on the include path):
//   AETHER_INCLUDE_PATH=/home/paul/scm/aeocha ae run test/spec_nested_system.ae
//   AEO_VERIFY=1 AETHER_INCLUDE_PATH=... ae run test/spec_nested_system.ae   # + live
//
// Mirrors examples/nested_compose/module.ae (the `aeo up` target).

import aeocha
import compose (system, bhyve_vm, container)
import compose (image, dockerfile, cpus, memory, guest_image, network, ssh_key, health, expose, depends)
import compose (describe_tree)
import std.string
import std.os (getenv, run_capture)
import std.list
import std.http.client

// ---- the composition, exactly as an operator would write it ----
// Both tiers are containers INSIDE the bhyve VM. db is a stock redis image;
// app is built from an inline heredoc Dockerfile and uses db as a cache.
declare() {
    system("red222") {
        bhyve_vm("myapp") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-22.04")
            network("dhcp")
            ssh_key("/home/paul/.ssh/id_rsa.pub")
            db = container("db") {
                image("docker.io/library/redis:alpine")
                expose(6379)
                health("redis-cli ping")
            }
            app = container("app") {
                dockerfile(<<DOCKER
                    FROM docker.io/library/python:3-alpine
                    RUN printf 'import http.server as h, socket\ndef rcmd(*a):\n s=socket.create_connection(("127.0.0.1",6379),1)\n s.sendall(("*%%d\\r\\n"%%len(a)+"".join("$%%d\\r\\n%%s\\r\\n"%%(len(x),x) for x in a)).encode())\n r=s.recv(4096); s.close(); return r\nclass A(h.BaseHTTPRequestHandler):\n def do_GET(self):\n  p=self.path.strip("/").split("/")\n  try:\n   k="add:%%s:%%s"%%(p[1],p[2]); c=rcmd("GET",k)\n   if c[:1]==b"$" and c[1:2]!=b"-": b=c.split(b"\\r\\n")[1].decode()\n   else: b=str(int(p[1])+int(p[2])); rcmd("SET",k,b)\n  except: b="err"\n  self.send_response(200); self.end_headers(); self.wfile.write(b.encode())\n def log_message(self,*a): pass\nh.HTTPServer(("0.0.0.0",8080),A).serve_forever()\n' > /app.py
                    CMD ["python", "/app.py"]
DOCKER
                )
                expose(8080)
                health("curl -fsS http://localhost:8080/add/0/0")
                depends(db)
            }
        }
    }
}

main() {
    fw = aeocha.init()
    declare()

    aeocha.describe(fw, "nested system: bhyve_vm{ db(redis) ; app }") {

        aeocha.describe("declaration (data model)") {
            // One snapshot assertion of the WHOLE resolved tree. aeo emits the
            // canonical model (compose.describe_tree()); we assert it equals
            // the expected shape — system, nesting, kinds, images, expose,
            // and the app->db dependency, all in one line. Beats eight
            // field-by-field it-blocks: if the resolution changes, the diff
            // shows exactly what moved.
            aeocha.it("resolves to the expected system tree") callback {
                want = <<TREE
                    system red222:
                      bhyve myapp [guest=ubuntu-22.04, cpus=2, mem=2G]
                        container db [image=docker.io/library/redis:alpine, expose=6379]
                        container app [dockerfile, expose=8080] -> db
TREE
                aeocha.assert_str_eq(fw, describe_tree(), want, "resolved tree snapshot")
            }
        }

        aeocha.describe("live deployment (AEO_VERIFY=1)") {
            aeocha.it("app computes arithmetic over HTTP (2+2=4, 2+3=5, 40+2=42)") callback {
                if _verify_on() == 0 {
                    aeocha.assert_true(fw, 1, "skipped (set AEO_VERIFY=1 against a deployed system)")
                } else {
                    base = _base()
                    _http_body_is(fw, "${base}/add/2/2", "4", "2 + 2 = 4")
                    _http_body_is(fw, "${base}/add/2/3", "5", "2 + 3 = 5")
                    _http_body_is(fw, "${base}/add/40/2", "42", "40 + 2 = 42")
                }
            }
            aeocha.it("app serves from the db cache (poke redis, read it back)") callback {
                if _verify_on() == 0 {
                    aeocha.assert_true(fw, 1, "skipped (set AEO_VERIFY=1)")
                } else {
                    _redis_set(_ip(), "add:2:3", "CACHED99")
                    _http_body_is(fw, "${_base()}/add/2/3", "CACHED99", "2+3 -> cached value")
                }
            }
        }
    }

    aeocha.run_summary(fw)
}

// ---- helpers ----

// 1 if AEO_VERIFY is set (the live deployment checks run), else 0.
_verify_on() -> int {
    if string.length(getenv("AEO_VERIFY")) > 0 {
        return 1
    }
    return 0
}

_ip() -> string {
    ip = getenv("AEO_GUEST_IP")
    if string.length(ip) == 0 {
        return "172.16.0.50"
    }
    return ip
}

_base() -> string {
    return "http://${_ip()}:8080"
}

// GET url and assert the response body equals `want` (the arithmetic check).
_http_body_is(fw: ptr, url: string, want: string, msg: string) {
    req = client.request("GET", url)
    resp, cerr = client.send_request(req)
    client.request_free(req)
    if cerr != "" {
        aeocha.fail(fw, "${msg} — transport error: ${cerr}")
    } else {
        aeocha.expect_http_status(fw, resp, 200, "${msg} (200)")
        aeocha.expect_http_body_contains(fw, resp, want, "${msg} == ${want}")
        client.response_free(resp)
    }
}

// Poke a key into the deployed redis (db) over ssh, so the next GET proves
// app read from the cache rather than recomputing.
_redis_set(ip: string, key: string, val: string) {
    av = list_new()
    list_add(av, "-i")
    list_add(av, "/home/paul/.ssh/id_rsa")
    list_add(av, "-o")
    list_add(av, "StrictHostKeyChecking=no")
    list_add(av, "ubuntu@${ip}")
    list_add(av, "podman exec db redis-cli SET ${key} ${val}")
    out, status, err = run_capture("/usr/bin/ssh", av, null)
    list_free(av)
}

_first5(s: string) -> string {
    if string.length(s) < 5 {
        return s
    }
    return string.substring(s, 0, 5)
}
