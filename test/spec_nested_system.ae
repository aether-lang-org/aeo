// spec_nested_system.ae — THE apex case: a Python service + redis cache in a
// bhyve VM, with the hypervisor confined under Capsicum. The one spec we're
// evolving; everything else is in test/_parked/.
//
// It declares the two-tier system (a bhyve VM containing a redis cache + a
// Python /add service that uses it), confines the bhyve hypervisor in a second
// phase (constrain{}), and verifies it. describe blocks:
//
// MULTI-MODE (env AEO_MODE) — one artifact, four behaviours off ONE declare().
// The rich entry is run_aeo(mode); main() is the lowered fallback for `ae run`.
//
//   check  — (DEFAULT) data-model assertions only; no deploy. Instant, anywhere.
//   up     — `aeo up`, leave the system STANDING. No checks.
//   smoke  — `aeo up` + the SLIM post-deploy verification (did it come up
//            right?), leave it STANDING. The "deploy + verification expected to
//            pass" shape. Slim/no-framework (curl-and-compare, pass/fail).
//   suite  — `aeo up` + the FULLER aeocha checks, then TEAR DOWN. CI shape.
//
// Run (aeocha on the include path):
//   AETHER_INCLUDE_PATH=$HOME/scm/aeocha ae run test/spec_nested_system.ae
//   AEO_MODE=smoke AETHER_INCLUDE_PATH=... ae run test/spec_nested_system.ae
//   AEO_MODE=up    ...   /   AEO_MODE=suite ...
// Deploy modes shell out to `aeo up <AEO_DSL>` (default
// examples/nested_compose/module.ae); override the binary/home/dsl via
// AEO / AEO_HOME / AEO_DSL.

import aeocha
import compose (system, bhyve_vm, container)
import compose (image, dockerfile, entrypoint, base, cpus, memory, guest_image, network, ssh_key, health, expose, depends)
import compose (suspend, constrain, grant_fd, egress, ingress, ingress_from, deny_egress, start, get_suspended, get_started, get_constraints, get_netpolicy, describe_tree)
import std.string
import std.os (getenv, run_capture)
import std.list
import ipam (resolve_ip)

// ---- the composition, exactly as an operator would write it ----
// TWO bhyve VMs on the slim 24.04-minimal+podman base (251MB; the measured
// best slim guest — see lib/images/README.md): db_vm holds a stock redis;
// python_vm holds a /add service (readable entrypoint heredoc) that uses redis
// as a cache, reaching it ACROSS VMs at db_vm's resolved address (REDIS_HOST),
// under a deny-all egress/ingress whitelist. Each VM's hypervisor is confined
// under its OWN Capsicum constraint set.
declare() {
    // The VMs name the slim logical image "ubuntu-24.04-minimal+podman" — 251MB
    // (vs 695MB standard jammy), the MEASURED best slim base (boots+net+ssh all
    // green, see lib/images/README.md). The image_recipe that realizes that
    // name lives in lib/images/ubuntu_24_04_minimal_podman.ae and is registered
    // at `aeo up` time (the deploy concern); this DATA-MODEL spec only needs the
    // logical NAME, so it doesn't import the recipe.
    system("red222") {
        // PHASE 1: provision + first boot db_vm (the redis VM) UNCONSTRAINED.
        db_vm = bhyve_vm("db_vm") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-24.04-minimal+podman")
            network("dhcp")
            ssh_key(_key_pub())
            db = container("db") {
                image("docker.io/library/redis:alpine")
                expose(6379)
                health("redis-cli ping")
            }
        }

        // PHASE 2: confine db_vm's hypervisor — its OWN constraint set
        // ("lock1": the redis VM's disk/tap/console). suspend -> constrain ->
        // start, as a verb sequence on the db_vm handle.
        suspend(db_vm)
        constrain(db_vm) {           // the block IS db_vm's — names its target
            // Capsicum FD GRANTS — which kernel objects the bhyve PROCESS may
            // touch (NOT ports): the disk image, the tap network DEVICE, the
            // console. Everything else is denied once bhyve cap_enter()s.
            grant_fd("disk",    "/zroot/vm/db_vm/disk0.img", "rd,wr")
            grant_fd("net",     "tap0", "rd,wr")     // the DEVICE fd, not a port
            grant_fd("console", "nmdm-db_vm", "rd,wr")
            // PF PORT POLICY — db_vm is the redis SERVER:
            ingress_from(6379, "python_vm")  // accept 6379 from python_vm ONLY.
                                 //   A 3rd/4th VM hitting db_vm:6379 is DENIED —
                                 //   the open port answers exactly one client.
            deny_egress()        //   reach out to NOTHING. If redis is later
                                 //   compromised (latent malware), it STILL
                                 //   can't phone home / exfiltrate.
        }
        start(db_vm)

        // PHASE 3: provision python_vm (the app VM) — UNCONSTRAINED first — then
        // confine it with its OWN, DIFFERENT constraint set ("lock2": python_vm's
        // disk/tap/console).
        //
        // CROSS-VM (fixed): db lives in db_vm, so app reaches redis at db_vm's
        // address — NOT 127.0.0.1. The app reads REDIS_HOST (aeo resolves the
        // egress target "db_vm" to its IP at deploy time); the egress whitelist
        // below pins the only outbound it's allowed. depends("db") is the
        // cross-VM ordering edge.
        python_vm = bhyve_vm("python_vm") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-24.04-minimal+podman")
            network("dhcp")
            ssh_key(_key_pub())
            app = container("app") {
                // The workload as a READABLE heredoc — aeo writes it to
                // /app.py + synthesizes a COPY-based Dockerfile (no printf, no
                // escaping; COPY builds on every podman where a RUN heredoc
                // doesn't). base() defaults to python:3-alpine.
                entrypoint(<<PY
                    import http.server as h, socket, os
                    # redis lives in db_vm (a SEPARATE VM), so reach it at
                    # db_vm's address — aeo resolves the egress target "db_vm"
                    # to an IP at deploy time and passes it as REDIS_HOST. NOT
                    # 127.0.0.1 (that was same-guest only; the two-VM split broke
                    # it). Falls back to localhost for a single-guest layout.
                    RHOST = os.environ.get("REDIS_HOST", "127.0.0.1")
                    def rcmd(*a):
                        s = socket.create_connection((RHOST, 6379), 1)
                        s.sendall(("*%d\r\n" % len(a) + "".join("$%d\r\n%s\r\n" % (len(x), x) for x in a)).encode())
                        r = s.recv(4096); s.close(); return r
                    class A(h.BaseHTTPRequestHandler):
                        def do_GET(self):
                            p = self.path.strip("/").split("/")
                            try:
                                k = "add:%s:%s" % (p[1], p[2]); c = rcmd("GET", k)
                                if c[:1] == b"$" and c[1:2] != b"-": b = c.split(b"\r\n")[1].decode()
                                else: b = str(int(p[1]) + int(p[2])); rcmd("SET", k, b)
                            except: b = "err"
                            self.send_response(200); self.end_headers(); self.wfile.write(b.encode())
                        def log_message(self, *a): pass
                    h.HTTPServer(("0.0.0.0", 8080), A).serve_forever()
PY
                )
                expose(8080)
                health("curl -fsS http://localhost:8080/add/0/0")
                depends("db")    // cross-VM edge: 'db' lives in db_vm, so it's
                                 // referenced by NAME (its handle is out of
                                 // scope here — different VM block).
            }
        }

        suspend(python_vm)
        constrain(python_vm) {           // the block IS python_vm's — its own grants
            // Capsicum fd grants (devices the bhyve process may touch):
            grant_fd("disk",    "/zroot/vm/python_vm/disk0.img", "rd,wr")
            grant_fd("net",     "tap1", "rd,wr")     // the DEVICE fd, not a port
            grant_fd("console", "nmdm-python_vm", "rd,wr")
            // PF port policy (deny-default whitelist). python_vm may ONLY:
            egress("db_vm", 6379)        //   reach redis (db_vm:6379) — nowhere else out
            ingress(8080)                //   accept on 8080 — nothing else in
        }
        start(python_vm)
    }
}

// ---- MODES (the rich entrypoint) ----
// run_aeo(mode) is the recommended door — mode in, structured result out (a
// pass/fail-ish summary string). main() below is the lowered fallback for
// `ae run`. Modes (env AEO_MODE, default "check"):
//
//   check  — data-model assertions only; resolve declare(), assert the tree +
//            policy, no deployment. Runs anywhere, instant. (DEFAULT.)
//   up     — `aeo up` the composition, leave it STANDING. No checks.
//   smoke  — `aeo up`, then the SLIM post-deploy check (the HSBC shape: did it
//            come up right? curl /add, redis cache), leave it STANDING. This is
//            the "deploy + post-deployment verification expected to pass" mode.
//   suite  — `aeo up`, run the FULLER checks, then TEAR DOWN. (CI shape.)
//
// smoke vs suite: smoke is slim + leaves the system up (you keep poking it);
// suite is exhaustive + cleans up after itself.
run_aeo(mode: string) -> string {
    declare()                          // the composition — always resolved

    if mode == "check" {
        return _mode_check()
    }
    if mode == "up" {
        return _mode_up()
    }
    if mode == "smoke" {
        return _mode_smoke()
    }
    if mode == "suite" {
        return _mode_suite()
    }
    return "aeo: unknown AEO_MODE '${mode}' (check|up|smoke|suite)"
}

// CHECK — data-model assertions, in-process, no deploy (the default).
_mode_check() -> string {
    fw = aeocha.init()

    aeocha.describe(fw, "nested system: bhyve_vm{ db(redis) ; app }") {

        aeocha.describe("declaration (data model)") {
            // One snapshot assertion of the WHOLE resolved tree. aeo emits the
            // canonical model (compose.describe_tree()); we assert it equals
            // the expected shape — system, nesting, kinds, images, expose,
            // and the app->db dependency, all in one line. Beats eight
            // field-by-field it-blocks: if the resolution changes, the diff
            // shows exactly what moved.
            aeocha.it("resolves to two top-level VMs, each with its OWN confinement") callback {
                want = <<TREE
                    system red222:
                      bhyve db_vm [guest=ubuntu-24.04-minimal+podman, cpus=2, mem=2G, confined: disk(/zroot/vm/db_vm/disk0.img)=rd,wr, net(tap0)=rd,wr, console(nmdm-db_vm)=rd,wr, net{ingress:6379<-python_vm, egress:DENY-ALL; deny rest}]
                        container db [image=docker.io/library/redis:alpine, expose=6379]
                      bhyve python_vm [guest=ubuntu-24.04-minimal+podman, cpus=2, mem=2G, confined: disk(/zroot/vm/python_vm/disk0.img)=rd,wr, net(tap1)=rd,wr, console(nmdm-python_vm)=rd,wr, net{egress->db_vm:6379, ingress:8080; deny rest}]
                        container app [entrypoint(docker.io/library/python:3-alpine), expose=8080] -> db
TREE
                aeocha.assert_str_eq(fw, describe_tree(), want, "resolved tree snapshot")
            }

            aeocha.it("each VM's constrain block names ITS OWN VM (no floating block)") callback {
                // The constraints live directly on the VM the constrain(vm){}
                // block named — db_vm's grants on db_vm, python_vm's on python_vm.
                aeocha.assert_str_eq(fw, get_suspended("db_vm"), "1", "db_vm suspended")
                aeocha.assert_str_eq(fw, get_started("db_vm"), "1", "db_vm resumed")
                aeocha.assert_str_eq(fw, get_constraints("db_vm"),
                    "disk(/zroot/vm/db_vm/disk0.img)=rd,wr, net(tap0)=rd,wr, console(nmdm-db_vm)=rd,wr",
                    "db_vm's own fd grants")
                aeocha.assert_str_eq(fw, get_suspended("python_vm"), "1", "python_vm suspended")
                aeocha.assert_str_eq(fw, get_constraints("python_vm"),
                    "disk(/zroot/vm/python_vm/disk0.img)=rd,wr, net(tap1)=rd,wr, console(nmdm-python_vm)=rd,wr",
                    "python_vm's own fd grants (DIFFERENT from db_vm's)")
            }

            aeocha.it("python_vm's workload-mode network is a deny-all whitelist") callback {
                // egress only to redis, ingress only on 8080; everything else
                // is denied (pf, separate from the Capsicum fd grants).
                aeocha.assert_str_eq(fw, get_netpolicy("python_vm"),
                    "egress->db_vm:6379, ingress:8080",
                    "may reach db_vm:6379 + accept 8080 — and NOTHING else")
            }

            aeocha.it("db_vm answers 6379 to python_vm ONLY, and BLOCKS all egress") callback {
                // Peer-restricted ingress: redis on 6379 is reachable by
                // python_vm alone — a 3rd/4th VM is DENIED (the port answers
                // exactly one client). Plus egress to NOTHING, so a compromised
                // redis can't phone home. Both explicit + asserted, not silent.
                aeocha.assert_str_eq(fw, get_netpolicy("db_vm"),
                    "ingress:6379<-python_vm, egress:DENY-ALL",
                    "6379 from python_vm only (no 3rd VM); zero outbound")
            }
        }

    }

    aeocha.run_summary(fw)
    return "check: data-model assertions complete"
}

// UP — deploy the composition and LEAVE IT STANDING. No checks. The system
// outlives this process (bhyve/podman daemonize — not children of the spec), so
// "leave up" is simply: deploy, return, don't tear down. (Per the
// principles-of-containment: the spawned system persists; we just stop holding
// it.)
_mode_up() -> string {
    rc = _aeo_up()
    if rc != 0 {
        return "up: FAILED (aeo up rc=${string.from_int(rc)})"
    }
    return "up: system stood up + left running (no checks)"
}

// SMOKE — the HSBC shape: deploy, then the SLIM post-deployment verification
// (did it come up right?), and LEAVE IT STANDING. Slim + no-framework: a couple
// of curl-and-compare probes returning pass/fail, not the full suite.
_mode_smoke() -> string {
    rc = _aeo_up()
    if rc != 0 {
        return "smoke: deploy FAILED (rc=${string.from_int(rc)}) — no point smoking"
    }
    // slim post-deploy probes (no aeocha — plain pass/fail, the lightest form).
    p1 = _http_eq("${_base()}/add/2/2", "4")
    p2 = _http_eq("${_base()}/add/40/2", "42")
    if p1 == 1 {
        if p2 == 1 {
            return "smoke: PASS — deployed, post-deploy verification green, left STANDING"
        }
    }
    return "smoke: FAIL — deployed but post-deploy verification did not pass (system left up for inspection)"
}

// SUITE — deploy, run the FULLER checks (aeocha, incl. the cache behaviour),
// then TEAR DOWN. The CI shape: exhaustive + self-cleaning.
_mode_suite() -> string {
    rc = _aeo_up()
    if rc != 0 {
        return "suite: deploy FAILED (rc=${string.from_int(rc)})"
    }
    fw = aeocha.init()
    aeocha.describe(fw, "live deployment (full suite)") {
        aeocha.it("app computes arithmetic over HTTP (2+2=4, 2+3=5, 40+2=42)") callback {
            base = _base()
            aeocha.expect_http_get_body_eq(fw, "${base}/add/2/2", "4", "2 + 2 = 4")
            aeocha.expect_http_get_body_eq(fw, "${base}/add/2/3", "5", "2 + 3 = 5")
            aeocha.expect_http_get_body_eq(fw, "${base}/add/40/2", "42", "40 + 2 = 42")
        }
        aeocha.it("app serves from the db cache (poke redis, read it back)") callback {
            _redis_set(_ip(), "add:2:3", "CACHED99")
            aeocha.expect_http_get_body_eq(fw, "${_base()}/add/2/3", "CACHED99", "2+3 -> cached value")
        }
    }
    aeocha.run_summary(fw)
    _aeo_down()                          // CI shape: clean up after ourselves
    return "suite: full checks ran, system TORN DOWN"
}

// main() — the lowered FALLBACK (for `ae run`). Reads AEO_MODE (default check),
// delegates to the rich run_aeo() door, prints the summary.
main() {
    m = getenv("AEO_MODE")
    if string.length(m) == 0 {
        m = "check"
    }
    println(run_aeo(m))
}

// ---- helpers ----

// shell out to `aeo up` the composition (deploy). Returns the exit code.
_aeo_up() -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "AEO_HOME=${_aeo_home()} ${_aeo_bin()} up ${_dsl()}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    return status
}
_aeo_down() {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "AEO_HOME=${_aeo_home()} ${_aeo_bin()} down ${_dsl()}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
}
_aeo_bin() -> string {
    b = getenv("AEO")
    if string.length(b) == 0 {
        return "/tmp/aeo"
    }
    return b
}
// operator home / ssh key — $HOME-based so a colleague's checkout works unedited.
// (string.concat, not ${} interpolation — getenv inside ${} mis-parses.)
_home() -> string { return getenv("HOME") }
_key_priv() -> string { return string.concat(_home(), "/.ssh/id_rsa") }
_key_pub() -> string  { return string.concat(_home(), "/.ssh/id_rsa.pub") }
_aeo_home() -> string {
    h = getenv("AEO_HOME")
    if string.length(h) == 0 {
        return string.concat(_home(), "/aeo")
    }
    return h
}
_dsl() -> string {
    d = getenv("AEO_DSL")
    if string.length(d) == 0 {
        return "examples/nested_compose/module.ae"
    }
    return d
}

// slim no-framework HTTP probe: 1 if GET url body == want, else 0.
_http_eq(url: string, want: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "curl -fsS --max-time 5 ${url}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return 0
    }
    if out == want {
        return 1
    }
    // tolerate a trailing newline
    if out == "${want}\n" {
        return 1
    }
    return 0
}

// The app VM's address for the live-deploy probes. AEO_GUEST_IP overrides;
// otherwise resolve python_vm's ipam binding (the same sticky address the
// driver deployed it at) — no hardcoded .50.
_ip() -> string {
    ip = getenv("AEO_GUEST_IP")
    if string.length(ip) == 0 {
        return ipam.resolve_ip("red222", "python_vm")
    }
    return ip
}

_base() -> string {
    return "http://${_ip()}:8080"
}

// Poke a key into the deployed redis (db) over ssh, so the next GET proves
// app read from the cache rather than recomputing.
_redis_set(ip: string, key: string, val: string) {
    av = list_new()
    list_add(av, "-i")
    list_add(av, _key_priv())
    list_add(av, "-o")
    list_add(av, "StrictHostKeyChecking=no")
    list_add(av, "ubuntu@${ip}")
    list_add(av, "podman exec db redis-cli SET ${key} ${val}")
    out, status, err = run_capture("/usr/bin/ssh", av, null)
    list_free(av)
}
