// integration_app.ae — a REAL integration test: aeo builds a Python
// arithmetic service from an inline Dockerfile, runs it with expose(8080),
// and curls it to prove it computes. Pass/fail is the orchestrated
// service's actual HTTP answer — not a parsed data model.
//
//   ae build test/integration_app.ae -o /tmp/ia --lib lib && /tmp/ia
//
// Needs podman + network (pulls python:alpine, no pip). No
// root. Exits 0 on ALL PASS.
//
// This is the workload that will run INSIDE the bhyve guest once the nested
// tier executes (container-in-host here; same image, same curl, one level
// down later). It exercises the full chain: inline Dockerfile build → run
// with an exposed port → reach the service from the host → assert the
// computed result.

import driver_linux
import std.os (run_capture)
import std.list
import std.string (string_length, string_contains, string_char_at, string_substring)

extern exit(code: int)

NAME() -> string { return "aeo-calc-svc" }
PORT() -> int { return 8080 }

// A stdlib-only Python HTTP service: GET /add/2/3 -> "5". No pip — just
// python:alpine + http.server from the standard library. The image build
// is one printf-of-a-script with zero package installs (fast, and small
// enough for the eventual in-guest version). Verified against podman
// directly before encoding here.
//
// The app (written to /app.py by the Dockerfile RUN):
//   import http.server as h
//   class A(h.BaseHTTPRequestHandler):
//    def do_GET(self):
//     p=self.path.strip("/").split("/")      # ['add','2','3']
//     try: b=str(int(p[1])+int(p[2]))
//     except: b="err"
//     self.send_response(200); self.end_headers(); self.wfile.write(b.encode())
//    def log_message(self,*a): pass
//   h.HTTPServer(("0.0.0.0",8080),A).serve_forever()
//
// Built with <<DOCKER heredoc (literal — no ${} / escaping inside), so the
// Python (with its "/" and "0.0.0.0" quotes) lands verbatim.
DF() -> string {
    return <<DOCKER
FROM docker.io/library/python:3-alpine
RUN cat <<'PY' > /app.py
import http.server as h
class A(h.BaseHTTPRequestHandler):
 def do_GET(self):
  p=self.path.strip("/").split("/")
  try: b=str(int(p[1])+int(p[2]))
  except: b="err"
  self.send_response(200); self.end_headers(); self.wfile.write(b.encode())
 def log_message(self,*a): pass
h.HTTPServer(("0.0.0.0",8080),A).serve_forever()
PY
CMD ["python", "/app.py"]
DOCKER
}

check(label: string, got: string, want: string) -> int {
    if got == want {
        println("  PASS ${label}: ${got}")
        return 1
    }
    println("  FAIL ${label}: got '${got}', want '${want}'")
    _cleanup()
    exit(1)
    return 0
}

main() {
    if driver_linux.engine_resolve("") == "" {
        println("SKIP: no container engine on PATH")
        return
    }
    println("=== aeo integration: Python arithmetic service, exposed + curled ===")
    _cleanup()

    passed = 0

    // 1. Build the service image from the inline Dockerfile.
    berr = driver_linux.build(NAME(), DF(), "")
    if berr != "" {
        println("FAIL build: ${berr}")
        exit(1)
    }
    println("  PASS build (Python stdlib image)")
    passed = passed + 1

    // 2. Run it with the port exposed to the host.
    tag = driver_linux.built_tag(NAME())
    uerr = driver_linux.up(NAME(), tag, "", PORT(), "")
    if uerr != "" {
        println("FAIL up: ${uerr}")
        _cleanup()
        exit(1)
    }
    println("  PASS up (expose ${_itoa(PORT())})")
    passed = passed + 1

    // 3. Wait for the service to answer (Python http.server boot takes a sec).
    ready = _wait_http("http://localhost:${_itoa(PORT())}/add/0/0", 40)
    passed = passed + check("service reachable", ready, "yes")

    // 4. THE assertion: the orchestrated service computes 2+3 = 5, over HTTP.
    passed = passed + check("GET /add/2/3", _curl("http://localhost:${_itoa(PORT())}/add/2/3"), "5")
    // and a second sum so it's clearly arithmetic.
    passed = passed + check("GET /add/40/2", _curl("http://localhost:${_itoa(PORT())}/add/40/2"), "42")

    _cleanup()
    println("=== ALL ${_itoa(passed)} PASS — orchestrated service computed over HTTP ===")
}

// curl a URL, return the trimmed body ("" on failure).
_curl(url: string) -> string {
    av = list_new()
    list_add(av, "-fsS")
    list_add(av, url)
    out, status, err = run_capture("/usr/bin/curl", av, null)
    list_free(av)
    if err != "" {
        return ""
    }
    if status != 0 {
        return ""
    }
    return _chomp(out)
}

// Poll a URL until it answers (any 2xx) or `secs` elapse. "yes"/"no".
_wait_http(url: string, secs: int) -> string {
    waited = 0
    while waited < secs {
        av = list_new()
        list_add(av, "-fsS")
        list_add(av, "-o")
        list_add(av, "/dev/null")
        list_add(av, url)
        _o, status, err = run_capture("/usr/bin/curl", av, null)
        list_free(av)
        if err == "" {
            if status == 0 {
                return "yes"
            }
        }
        sleep(1000)
        waited = waited + 1
    }
    return "no"
}

_cleanup() {
    driver_linux.down(NAME(), "")
}

_chomp(s: string) -> string {
    n = string_length(s)
    if n == 0 {
        return s
    }
    if string_char_at(s, n - 1) == 10 {
        return string_substring(s, 0, n - 1)
    }
    return s
}

_itoa(n: int) -> string {
    if n == 0 { return "0" }
    v = n
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_d(d)}${s}"
        v = v / 10
    }
    return s
}
_d(x: int) -> string {
    if x == 0 { return "0" }
    if x == 1 { return "1" }
    if x == 2 { return "2" }
    if x == 3 { return "3" }
    if x == 4 { return "4" }
    if x == 5 { return "5" }
    if x == 6 { return "6" }
    if x == 7 { return "7" }
    if x == 8 { return "8" }
    return "9"
}
