// test/spec_teardown_batch.ae — the PURE half of the level-parallel teardown:
// driver_linux.down_many_command, the one-sweep shell line that backgrounds
// each container's stop+rm and waits for all (the per-level stop grace is paid
// once, not once per node — measured 15.6s -> 6.3s at width 3 against real
// SIGTERM-ignoring docker containers on the dev box, 2026-07-06). The exec'ing
// halves (down_many, the runner's reverse-level engine) are exercised live.

import aeocha
import driver_linux (down_many_command)
import std.string   // bare: aeocha's inlined asserts call string.copy unqualified
import std.string (string_contains)

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "teardown batch (down_many_command)") {

        aeocha.it("backgrounds each node's stop+rm and waits for all") callback {
            got = down_many_command("db app", "podman")
            want = "for n in db app; do { podman stop -t 5 \"$n\"; podman rm -f \"$n\"; } >/dev/null 2>&1 & done; wait"
            aeocha.assert_str_eq(got, want, "the one-sweep shell line")
        }

        aeocha.it("pins the chosen engine into every per-node job") callback {
            got = down_many_command("web", "docker")
            aeocha.assert_true(string_contains(got, "docker stop -t 5"), "docker stop")
            aeocha.assert_true(string_contains(got, "docker rm -f"), "docker rm")
        }

        aeocha.it("keeps the stop grace bounded (-t 5) so a hung node can't stall the sweep past it") callback {
            got = down_many_command("a b c", "podman")
            aeocha.assert_true(string_contains(got, "stop -t 5"), "bounded grace")
            aeocha.assert_true(string_contains(got, "; wait"), "barrier at the end")
        }
    }

    aeocha.run_summary(fw)
}
