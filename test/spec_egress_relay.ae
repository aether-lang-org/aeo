// spec_egress_relay.ae — pure CONNECT-gateway core for egress_fqdn.
// No sockets here: this pins the parse/decision behavior before runtime wiring.

import aeocha
import egress_relay (
    is_connect, connect_host, connect_port, host_allowed,
    decision_status, decision_reason, response_for_status,
    splice_supported, splice_blocker
)
import std.string

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "egress_relay CONNECT decision core") {
        aeocha.describe("CONNECT parsing") {
            aeocha.it("extracts lowercase host and port from the first line") callback {
                req = "CONNECT API.GitHub.com:443 HTTP/1.1\r\nHost: API.GitHub.com:443\r\n\r\n"
                aeocha.expect_int(is_connect(req)).to_be_truthy()
                aeocha.expect_str(connect_host(req)).to_equal_str("api.github.com")
                aeocha.expect_int(connect_port(req)).to_equal(443)
            }
            aeocha.it("rejects non-CONNECT and malformed authorities") callback {
                aeocha.expect_int(is_connect("GET / HTTP/1.1\r\n\r\n")).to_equal(0)
                aeocha.expect_str(connect_host("CONNECT api.github.com HTTP/1.1\r\n\r\n")).to_equal_str("")
                aeocha.expect_int(connect_port("CONNECT api.github.com:abc HTTP/1.1\r\n\r\n")).to_equal(0)
                aeocha.expect_int(connect_port("CONNECT api.github.com:70000 HTTP/1.1\r\n\r\n")).to_equal(0)
            }
        }

        aeocha.describe("allowlist decision") {
            aeocha.it("allows exact host matches, case-insensitively") callback {
                allow = "api.github.com, api.anthropic.com"
                aeocha.expect_int(host_allowed(allow, "API.GITHUB.COM")).to_be_truthy()
                aeocha.expect_int(host_allowed(allow, "uploads.github.com")).to_equal(0)
            }
            aeocha.it("returns 200 for allowed CONNECT before the splice") callback {
                req = "CONNECT api.github.com:443 HTTP/1.1\r\n\r\n"
                aeocha.expect_int(decision_status(req, "api.github.com")).to_equal(200)
                aeocha.expect_str(decision_reason(req, "api.github.com")).to_equal_str("allow")
                aeocha.expect_int(_has(response_for_status(200), "200 Connection Established")).to_be_truthy()
            }
            aeocha.it("returns 403 for a well-formed but unlisted host") callback {
                req = "CONNECT example.com:443 HTTP/1.1\r\n\r\n"
                aeocha.expect_int(decision_status(req, "api.github.com")).to_equal(403)
                aeocha.expect_str(decision_reason(req, "api.github.com")).to_equal_str("deny:not-allowlisted")
                aeocha.expect_int(_has(response_for_status(403), "403 Forbidden")).to_be_truthy()
            }
            aeocha.it("returns 400 for bad CONNECT shape") callback {
                req = "CONNECT api.github.com HTTP/1.1\r\n\r\n"
                aeocha.expect_int(decision_status(req, "api.github.com")).to_equal(400)
                aeocha.expect_str(decision_reason(req, "api.github.com")).to_equal_str("deny:bad-connect")
                aeocha.expect_int(_has(response_for_status(400), "400 Bad Request")).to_be_truthy()
            }
        }

        aeocha.describe("runtime splice readiness") {
            aeocha.it("does not claim opaque TCP splice support until std.tcp is length-aware") callback {
                aeocha.expect_int(splice_supported()).to_equal(0)
                aeocha.expect_int(_has(splice_blocker(), "strlen")).to_be_truthy()
                aeocha.expect_int(_has(splice_blocker(), "NUL-terminated")).to_be_truthy()
            }
        }
    }

    aeocha.run_summary(fw)
}

_has(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 1 }
    return 0
}
