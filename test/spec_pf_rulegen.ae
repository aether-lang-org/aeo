// spec_pf_rulegen.ae — proves aeo GENERATES the correct pf ruleset from the
// network policy (the enforcement of ingress_from/egress/ingress/deny_egress).
// Pure logic: netpolicy string -> pf rules, deny-default whitelist. Peer + self
// are $tokens the driver resolves to IPs at apply time (compose stays
// IP-agnostic). This is what a live `pfctl -f` would load.
//
// The headline case Paul asked for: redis (db_vm:6379) answers python_vm ONLY;
// a 3rd/4th VM is blocked. The generated rules show exactly that.

import aeocha
import compose (constrain, grant_fd, ingress_from, egress, ingress, deny_egress, pf_rules_for, get_netpolicy)
import std.string

declare() {
    constrain("db_vm") {
        ingress_from(6379, "python_vm")   // redis from python_vm only
        deny_egress()                     // no outbound at all
    }
    constrain("python_vm") {
        egress("db_vm", 6379)
        ingress(8080)
    }
}

main() {
    fw = aeocha.init()
    declare()

    aeocha.describe(fw, "pf rule generation enforces the network policy") {

        aeocha.describe("db_vm: redis answers ONE peer; a 3rd VM is blocked") {
            aeocha.it("emits a peer-restricted pass for 6379 from python_vm") callback {
                aeocha.expect_int(_has(pf_rules_for("db_vm"),
                    "pass in proto tcp from $python_vm to $db_vm port 6379")).to_be_truthy()
            }
            aeocha.it("blocks all OTHER inbound to db_vm (the 3rd/4th VM)") callback {
                aeocha.expect_int(_has(pf_rules_for("db_vm"),
                    "block in proto tcp to $db_vm")).to_be_truthy()
            }
            aeocha.it("blocks ALL egress from db_vm (compromised redis can't exfiltrate)") callback {
                aeocha.expect_int(_has(pf_rules_for("db_vm"),
                    "block out proto tcp from $db_vm")).to_be_truthy()
            }
            aeocha.it("db_vm has NO 'pass out' (deny_egress means no egress pass)") callback {
                aeocha.expect_int(_absent(pf_rules_for("db_vm"), "pass out")).to_be_truthy()
            }
        }

        aeocha.describe("python_vm: may reach redis + accept 8080, nothing else") {
            aeocha.it("passes OUT to db_vm:6379") callback {
                aeocha.expect_int(_has(pf_rules_for("python_vm"),
                    "pass out proto tcp from $python_vm to $db_vm port 6379")).to_be_truthy()
            }
            aeocha.it("passes IN on 8080") callback {
                aeocha.expect_int(_has(pf_rules_for("python_vm"),
                    "pass in proto tcp to $python_vm port 8080")).to_be_truthy()
            }
            aeocha.it("blocks the rest (deny-default catch-all)") callback {
                aeocha.expect_int(_has(pf_rules_for("python_vm"),
                    "block in proto tcp to $python_vm")).to_be_truthy()
                aeocha.expect_int(_has(pf_rules_for("python_vm"),
                    "block out proto tcp from $python_vm")).to_be_truthy()
            }
        }
    }

    aeocha.run_summary(fw)
}

_has(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 1 }
    return 0
}
_absent(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 0 }
    return 1
}
