// demo_nested_system.ae — a single self-contained, runnable demonstration
// of the headline feature: a SYSTEM with a bhyve VM containing a TWO-TIER
// app — a redis cache (db) and a Python service (app) that depends on it.
// No container engine, no root, no network — it declares the tree via the
// real compose DSL and asserts the resolved data model + bring-up order.
// Build & run anywhere:
//
//   ae build test/demo_nested_system.ae -o /tmp/demo --lib lib && /tmp/demo
//
// Two modes, like an IaC script that declares AND verifies:
//   default            — data-model assertions only (runs anywhere, instant,
//                         no deployment). Exits 0 (ALL PASS) or non-zero.
//   AEO_VERIFY=1 /tmp/demo
//                      — ALSO curls the LIVE deployed service and asserts the
//                        cache behaviour. Needs the system actually up (aeo up
//                        examples/nested_compose on the BSD box). Point at the
//                        guest with AEO_GUEST_IP (default 172.16.0.50).
//
// Mirrors examples/nested_compose/module.ae (the `aeo up` target).
//
//   system("red222")
//     └─ myapp (bhyve VM)
//          ├─ db  (redis container, INSIDE myapp)
//          └─ app (python container, INSIDE myapp) ── depends ──► db

import compose (system, bhyve_vm, container)
import compose (image, dockerfile, cpus, memory, guest_image, network, ssh_key, health, expose, depends)
import compose (count, name_at, get_kind, get_system, get_host, get_depends, get_dockerfile, get_image, get_guest_image, syscount, sysname_at)
import std.string (string_contains, string_length, string_substring)
import std.os (run_capture, getenv)
import std.list

extern exit(code: int)

// ---- the composition, exactly as an operator would write it ----
// Both tiers are containers INSIDE the bhyve VM. db is a stock redis image;
// app is built from an inline heredoc Dockerfile and uses db as a cache.
declare() {
    system("red222") {
        bhyve_vm("myapp") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-22.04")
            network("dhcp")
            ssh_key("/home/paul/.ssh/id_rsa.pub")
            db = container("db") {
                image("docker.io/library/redis:alpine")
                // expose(6379) scope: with the driver's --network host, this
                // port binds the GUEST VM's stack — reachable by sibling
                // containers (app -> 127.0.0.1:6379), anywhere in the guest,
                // and from the GhostBSD host at <guest-ip>:6379. NOT the LAN
                // (the guest is NAT'd). Only app needs it, so it's slightly
                // over-exposed; see lib/compose expose() + examples/nested_compose.
                expose(6379)
                health("redis-cli ping")
            }
            app = container("app") {
                dockerfile(<<DOCKER
                    FROM docker.io/library/python:3-alpine
                    RUN cat <<'PY' > /app.py
                    import http.server as h, socket
                    def rcmd(*a):
                     s=socket.create_connection(("127.0.0.1",6379),1)
                     s.sendall(("*%d\r\n"%len(a)+"".join("$%d\r\n%s\r\n"%(len(x),x) for x in a)).encode())
                     r=s.recv(4096); s.close(); return r
                    class A(h.BaseHTTPRequestHandler):
                     def do_GET(self):
                      p=self.path.strip("/").split("/")
                      try:
                       k="add:%s:%s"%(p[1],p[2])
                       c=rcmd("GET",k)
                       if c[:1]==b"$" and c[1:2]!=b"-": b=c.split(b"\r\n")[1].decode()
                       else:
                        b=str(int(p[1])+int(p[2])); rcmd("SET",k,b)
                      except: b="err"
                      self.send_response(200); self.end_headers(); self.wfile.write(b.encode())
                     def log_message(self,*a): pass
                    h.HTTPServer(("0.0.0.0",8080),A).serve_forever()
                    PY
                    CMD ["python", "/app.py"]
DOCKER
                )
                expose(8080)
                health("curl -fsS http://localhost:8080/add/0/0")
                depends(db)
            }
        }
    }
}

// Assert got==want; print PASS, or print FAIL and exit non-zero. Returns 1
// so the caller can tally (Aether has no top-level mutable global).
check(label: string, got: string, want: string) -> int {
    if got == want {
        println("  PASS ${label}: ${got}")
        return 1
    }
    println("  FAIL ${label}: got '${got}', want '${want}'")
    exit(1)
    return 0
}

main() {
    println("=== aeo nested-system demo: system{ bhyve_vm{ db(redis) ; app } } ===")
    declare()
    passed = 0

    // One system named red222.
    sc = syscount()
    passed = passed + check("system count", _itoa(sc), "1")
    passed = passed + check("system name", sysname_at(0), "red222")

    // Three resources. myapp (the block-host VM) opens first, then its
    // contained db + app.
    n = count()
    passed = passed + check("resource count", _itoa(n), "3")
    passed = passed + check("res[0] name", name_at(0), "myapp")
    passed = passed + check("res[1] name", name_at(1), "db")
    passed = passed + check("res[2] name", name_at(2), "app")

    // Kinds: myapp is the VM; db + app are both containers in it.
    passed = passed + check("myapp kind", get_kind("myapp"), "bhyve")
    passed = passed + check("db kind", get_kind("db"), "container")
    passed = passed + check("app kind", get_kind("app"), "container")

    // All belong to the system.
    passed = passed + check("db system", get_system("db"), "red222")
    passed = passed + check("app system", get_system("app"), "red222")

    // Nesting: myapp is at host level; db AND app are INSIDE myapp.
    passed = passed + check("myapp host (top level)", _orempty(get_host("myapp")), "<none>")
    passed = passed + check("db host (nested)", get_host("db"), "myapp")
    passed = passed + check("app host (nested)", get_host("app"), "myapp")

    // app depends on db (db comes up first).
    passed = passed + check("app depends", get_depends("app"), "db")

    // db is a stock image (redis); app is built from an inline Dockerfile.
    passed = passed + check("db image", get_image("db"), "docker.io/library/redis:alpine")

    // app is a real, buildable image: an inline heredoc Dockerfile, not a
    // fictional registry reference.
    passed = passed + check("app has inline Dockerfile", _hasdf("app"), "yes")

    // The heredoc body is indented in source (to nest under dockerfile(...)),
    // but aether's heredoc dedent (>=0.298) strips the common leading
    // whitespace — so the resolved Dockerfile starts at column 0 with FROM,
    // not with leaked indentation (which would break `podman build`).
    passed = passed + check("dockerfile dedented (starts FROM)", _starts_from("app"), "yes")

    // The VM declares its guest in the DSL — aeo provisions it (vm-bhyve).
    passed = passed + check("myapp guest_image", get_guest_image("myapp"), "ubuntu-22.04")

    println("=== ALL ${_itoa(passed)} PASS — nested system resolved correctly ===")
    println("")
    println("Tree:")
    println("  system(red222)")
    println("    myapp [bhyve]       (host level)")
    println("      db  [container]   (redis, inside myapp)")
    println("      app [container]   (inside myapp) -> depends db")

    // Live verification — the way an IaC script proves the thing it declared
    // is actually up. The data-model assertions above run anywhere, instantly,
    // with no deployment. The curl checks below need the system ACTUALLY
    // DEPLOYED (aeo up examples/nested_compose on the BSD box; the guest
    // booted + db/app running), so they're OFF by default and gated on
    // AEO_VERIFY=1. Point them at the guest with AEO_GUEST_IP (default the
    // static 172.16.0.50). This mirrors `terraform apply` then a smoke test.
    if string_length(getenv("AEO_VERIFY")) > 0 {
        verify()
    } else {
        println("")
        println("(set AEO_VERIFY=1 to also run the live curl check against a")
        println(" deployed system — e.g. after: aeo up examples/nested_compose)")
    }
}

// Live smoke test against a DEPLOYED system: curl app's /add from outside,
// asserting both the compute and that it reads from the redis cache (db).
// Exits non-zero on any failure (so it's CI-gateable).
verify() {
    ip = getenv("AEO_GUEST_IP")
    if string_length(ip) == 0 {
        ip = "172.16.0.50"
    }
    base = "http://${ip}:8080"
    println("")
    println("=== LIVE VERIFY — host -> app(${ip}:8080) -> db(redis) ===")

    // compute on a miss
    a = _curl("${base}/add/2/3")
    vcheck("GET /add/2/3 (compute)", a, "5")
    b = _curl("${base}/add/40/2")
    vcheck("GET /add/40/2 (compute)", b, "42")

    // prove app reads from db: poke the cached value via redis, expect it back
    _redis_set(ip, "add:2:3", "CACHED99")
    c = _curl("${base}/add/2/3")
    vcheck("GET /add/2/3 after cache poke (reads db)", c, "CACHED99")

    println("=== LIVE VERIFY PASS — deployed + serving from cache ===")
}

// Assert a live value; print + exit non-zero on mismatch.
vcheck(label: string, got: string, want: string) {
    if got == want {
        println("  PASS ${label}: ${got}")
    } else {
        println("  FAIL ${label}: got '${got}', want '${want}'")
        exit(1)
    }
}

// curl a URL, return the trimmed body ("" on failure).
_curl(url: string) -> string {
    av = list_new()
    list_add(av, "-fsS")
    list_add(av, "-m")
    list_add(av, "8")
    list_add(av, url)
    out, status, err = run_capture("/usr/bin/curl", av, null)
    list_free(av)
    if err != "" {
        return ""
    }
    if status != 0 {
        return ""
    }
    return _chomp(out)
}

// Set a key in the deployed redis (db) via ssh + podman exec, so the next
// curl proves app served from the cache rather than recomputing.
_redis_set(ip: string, key: string, val: string) {
    av = list_new()
    list_add(av, "-i")
    list_add(av, "/home/paul/.ssh/id_rsa")
    list_add(av, "-o")
    list_add(av, "StrictHostKeyChecking=no")
    list_add(av, "ubuntu@${ip}")
    list_add(av, "podman exec db redis-cli SET ${key} ${val}")
    out, status, err = run_capture("/usr/bin/ssh", av, null)
    list_free(av)
}

// Trim one trailing newline from a captured string.
_chomp(s: string) -> string {
    n = string_length(s)
    if n > 0 {
        if string_substring(s, n - 1, n) == "\n" {
            return string_substring(s, 0, n - 1)
        }
    }
    return s
}

// "yes" if app's dockerfile resolved and looks like a real Dockerfile.
_hasdf(nm: string) -> string {
    df = get_dockerfile(nm)
    if string_contains(df, "FROM ") == 1 {
        return "yes"
    }
    return "no"
}

// "yes" if the resolved dockerfile begins exactly with "FROM " at column 0
// (proves the heredoc dedent stripped the source indentation cleanly — a
// leaked leading space would make this "no").
_starts_from(nm: string) -> string {
    df = get_dockerfile(nm)
    if string_length(df) < 5 {
        return "no"
    }
    if string_substring(df, 0, 5) == "FROM " {
        return "yes"
    }
    return "no"
}

// helpers
_orempty(s: string) -> string {
    if s == "" {
        return "<none>"
    }
    return s
}

_itoa(n: int) -> string {
    if n == 0 {
        return "0"
    }
    v = n
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_digit(d)}${s}"
        v = v / 10
    }
    return s
}
_digit(d: int) -> string {
    if d == 0 { return "0" }
    if d == 1 { return "1" }
    if d == 2 { return "2" }
    if d == 3 { return "3" }
    if d == 4 { return "4" }
    if d == 5 { return "5" }
    if d == 6 { return "6" }
    if d == 7 { return "7" }
    if d == 8 { return "8" }
    return "9"
}
