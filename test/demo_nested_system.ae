// demo_nested_system.ae — a single self-contained, runnable demonstration
// of the headline feature: a SYSTEM with a bhyve VM containing a TWO-TIER
// app — a redis cache (db) and a Python service (app) that depends on it.
// No container engine, no root, no network — it declares the tree via the
// real compose DSL and asserts the resolved data model + bring-up order.
// Build & run anywhere:
//
//   ae build test/demo_nested_system.ae -o /tmp/demo --lib lib && /tmp/demo
//
// Exits 0 (ALL PASS) or non-zero on the first failed assertion. Mirrors
// examples/nested_compose/module.ae (the `aeo up` target).
//
//   system("red222")
//     └─ myapp (bhyve VM)
//          ├─ db  (redis container, INSIDE myapp)
//          └─ app (python container, INSIDE myapp) ── depends ──► db

import compose (system, bhyve_vm, container)
import compose (image, dockerfile, cpus, memory, guest_image, network, ssh_key, health, expose, depends)
import compose (count, name_at, get_kind, get_system, get_host, get_depends, get_dockerfile, get_image, get_guest_image, syscount, sysname_at)
import std.string (string_contains)

extern exit(code: int)

// ---- the composition, exactly as an operator would write it ----
// Both tiers are containers INSIDE the bhyve VM. db is a stock redis image;
// app is built from an inline heredoc Dockerfile and uses db as a cache.
declare() {
    system("red222") {
        bhyve_vm("myapp") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-22.04")
            network("dhcp")
            ssh_key("/home/paul/.ssh/id_rsa.pub")
            db = container("db") {
                image("docker.io/library/redis:alpine")
                expose(6379)
                health("redis-cli ping")
            }
            app = container("app") {
                dockerfile(<<DOCKER
FROM docker.io/library/python:3-alpine
RUN cat <<'PY' > /app.py
import http.server as h, socket
def rcmd(*a):
 s=socket.create_connection(("127.0.0.1",6379),1)
 s.sendall(("*%d\r\n"%len(a)+"".join("$%d\r\n%s\r\n"%(len(x),x) for x in a)).encode())
 r=s.recv(4096); s.close(); return r
class A(h.BaseHTTPRequestHandler):
 def do_GET(self):
  p=self.path.strip("/").split("/")
  try:
   k="add:%s:%s"%(p[1],p[2])
   c=rcmd("GET",k)
   if c[:1]==b"$" and c[1:2]!=b"-": b=c.split(b"\r\n")[1].decode()
   else:
    b=str(int(p[1])+int(p[2])); rcmd("SET",k,b)
  except: b="err"
  self.send_response(200); self.end_headers(); self.wfile.write(b.encode())
 def log_message(self,*a): pass
h.HTTPServer(("0.0.0.0",8080),A).serve_forever()
PY
CMD ["python", "/app.py"]
DOCKER
                )
                expose(8080)
                health("curl -fsS http://localhost:8080/add/0/0")
                depends(db)
            }
        }
    }
}

// Assert got==want; print PASS, or print FAIL and exit non-zero. Returns 1
// so the caller can tally (Aether has no top-level mutable global).
check(label: string, got: string, want: string) -> int {
    if got == want {
        println("  PASS ${label}: ${got}")
        return 1
    }
    println("  FAIL ${label}: got '${got}', want '${want}'")
    exit(1)
    return 0
}

main() {
    println("=== aeo nested-system demo: system{ bhyve_vm{ db(redis) ; app } } ===")
    declare()
    passed = 0

    // One system named red222.
    sc = syscount()
    passed = passed + check("system count", _itoa(sc), "1")
    passed = passed + check("system name", sysname_at(0), "red222")

    // Three resources. myapp (the block-host VM) opens first, then its
    // contained db + app.
    n = count()
    passed = passed + check("resource count", _itoa(n), "3")
    passed = passed + check("res[0] name", name_at(0), "myapp")
    passed = passed + check("res[1] name", name_at(1), "db")
    passed = passed + check("res[2] name", name_at(2), "app")

    // Kinds: myapp is the VM; db + app are both containers in it.
    passed = passed + check("myapp kind", get_kind("myapp"), "bhyve")
    passed = passed + check("db kind", get_kind("db"), "container")
    passed = passed + check("app kind", get_kind("app"), "container")

    // All belong to the system.
    passed = passed + check("db system", get_system("db"), "red222")
    passed = passed + check("app system", get_system("app"), "red222")

    // Nesting: myapp is at host level; db AND app are INSIDE myapp.
    passed = passed + check("myapp host (top level)", _orempty(get_host("myapp")), "<none>")
    passed = passed + check("db host (nested)", get_host("db"), "myapp")
    passed = passed + check("app host (nested)", get_host("app"), "myapp")

    // app depends on db (db comes up first).
    passed = passed + check("app depends", get_depends("app"), "db")

    // db is a stock image (redis); app is built from an inline Dockerfile.
    passed = passed + check("db image", get_image("db"), "docker.io/library/redis:alpine")

    // app is a real, buildable image: an inline heredoc Dockerfile, not a
    // fictional registry reference.
    passed = passed + check("app has inline Dockerfile", _hasdf("app"), "yes")

    // The VM declares its guest in the DSL — aeo provisions it (vm-bhyve).
    passed = passed + check("myapp guest_image", get_guest_image("myapp"), "ubuntu-22.04")

    println("=== ALL ${_itoa(passed)} PASS — nested system resolved correctly ===")
    println("")
    println("Tree:")
    println("  system(red222)")
    println("    myapp [bhyve]       (host level)")
    println("      db  [container]   (redis, inside myapp)")
    println("      app [container]   (inside myapp) -> depends db")
}

// "yes" if app's dockerfile resolved and looks like a real Dockerfile.
_hasdf(nm: string) -> string {
    df = get_dockerfile(nm)
    if string_contains(df, "FROM ") == 1 {
        return "yes"
    }
    return "no"
}

// helpers
_orempty(s: string) -> string {
    if s == "" {
        return "<none>"
    }
    return s
}

_itoa(n: int) -> string {
    if n == 0 {
        return "0"
    }
    v = n
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_digit(d)}${s}"
        v = v / 10
    }
    return s
}
_digit(d: int) -> string {
    if d == 0 { return "0" }
    if d == 1 { return "1" }
    if d == 2 { return "2" }
    if d == 3 { return "3" }
    if d == 4 { return "4" }
    if d == 5 { return "5" }
    if d == 6 { return "6" }
    if d == 7 { return "7" }
    if d == 8 { return "8" }
    return "9"
}
