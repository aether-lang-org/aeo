// demo_nested_system.ae — a single self-contained, runnable demonstration
// of the headline feature: a SYSTEM containing a jail and a bhyve VM, with
// a Linux container NESTED INSIDE that VM, depending across the VM
// boundary on the jail. No container engine, no root, no network — it
// declares the tree via the real compose DSL and asserts the resolved
// data model + bring-up order. Build & run anywhere:
//
//   ae build test/demo_nested_system.ae -o /tmp/demo --lib lib && /tmp/demo
//
// Exits 0 (ALL PASS) or non-zero on the first failed assertion.
//
//   system("red222")
//     ├─ db    (jail — BSD-native, host level)
//     └─ myapp (bhyve VM)
//          └─ app (container, INSIDE myapp) ── depends ──► db

import compose (system, bhyve_vm, jail, container)
import compose (dataset, command, dockerfile, cpus, memory, guest_image, network, ssh_key, health, expose, depends)
import compose (count, name_at, get_kind, get_system, get_host, get_depends, get_dockerfile, get_guest_image, syscount, sysname_at)
import std.string (string_contains)

extern exit(code: int)

// ---- the composition, exactly as an operator would write it ----
// `app` is a REAL, buildable image — an inline heredoc Dockerfile, not a
// fictional registry reference. On the GhostBSD box this is built and run
// INSIDE the bhyve Linux guest by the aeo-agent that lives there; the
// Dockerfile is also where the agent gets baked in.
declare() {
    system("red222") {
        db = jail("db") {
            dataset("zroot/jails/db")
            command("/rescue/sh -c 'sleep 600'")
            health("/rescue/test -d /")
        }
        bhyve_vm("myapp") {
            cpus(2)
            memory("2G")
            guest_image("debian-12")
            network("dhcp")
            ssh_key("/home/paul/.ssh/id_rsa.pub")
            app = container("app") {
                dockerfile(<<DOCKER
FROM docker.io/library/python:3-alpine
RUN printf 'import http.server as h\nclass A(h.BaseHTTPRequestHandler):\n def do_GET(self):\n  p=self.path.strip("/").split("/")\n  try: b=str(int(p[1])+int(p[2]))\n  except: b="err"\n  self.send_response(200); self.end_headers(); self.wfile.write(b.encode())\n def log_message(self,*a): pass\nh.HTTPServer(("0.0.0.0",8080),A).serve_forever()\n' > /app.py
CMD ["python", "/app.py"]
DOCKER
                )
                expose(8080)
                health("curl -fsS http://localhost:8080/add/0/0")
                depends(db)
            }
        }
    }
}

// Assert got==want; print PASS, or print FAIL and exit non-zero. Returns 1
// so the caller can tally (Aether has no top-level mutable global).
check(label: string, got: string, want: string) -> int {
    if got == want {
        println("  PASS ${label}: ${got}")
        return 1
    }
    println("  FAIL ${label}: got '${got}', want '${want}'")
    exit(1)
    return 0
}

main() {
    println("=== aeo nested-system demo: system{ jail ; bhyve_vm{ container } } ===")
    declare()
    passed = 0

    // One system named red222.
    sc = syscount()
    passed = passed + check("system count", _itoa(sc), "1")
    passed = passed + check("system name", sysname_at(0), "red222")

    // Three resources, in declaration order.
    n = count()
    passed = passed + check("resource count", _itoa(n), "3")
    passed = passed + check("res[0] name", name_at(0), "db")
    passed = passed + check("res[1] name", name_at(1), "myapp")
    passed = passed + check("res[2] name", name_at(2), "app")

    // Kinds.
    passed = passed + check("db kind", get_kind("db"), "jail")
    passed = passed + check("myapp kind", get_kind("myapp"), "bhyve")
    passed = passed + check("app kind", get_kind("app"), "container")

    // All belong to the system.
    passed = passed + check("db system", get_system("db"), "red222")
    passed = passed + check("app system", get_system("app"), "red222")

    // Nesting: db is at host level (no host), app is INSIDE myapp.
    passed = passed + check("db host (top level)", _orempty(get_host("db")), "<none>")
    passed = passed + check("myapp host (top level)", _orempty(get_host("myapp")), "<none>")
    passed = passed + check("app host (nested)", get_host("app"), "myapp")

    // The dependency crosses the VM boundary: app depends on db.
    passed = passed + check("app depends", get_depends("app"), "db")

    // app is a real, buildable image: an inline heredoc Dockerfile, not a
    // fictional registry reference.
    passed = passed + check("app has inline Dockerfile", _hasdf("app"), "yes")

    // The VM declares its guest in the DSL — aeo provisions it (vm-bhyve).
    passed = passed + check("myapp guest_image", get_guest_image("myapp"), "debian-12")

    println("=== ALL ${_itoa(passed)} PASS — nested system resolved correctly ===")
    println("")
    println("Tree:")
    println("  system(red222)")
    println("    db    [jail]      (host level)")
    println("    myapp [bhyve]     (host level)")
    println("      app [container] (inside myapp) -> depends db")
}

// "yes" if app's dockerfile resolved and looks like a real Dockerfile.
_hasdf(nm: string) -> string {
    df = get_dockerfile(nm)
    if string_contains(df, "FROM ") == 1 {
        return "yes"
    }
    return "no"
}

// helpers
_orempty(s: string) -> string {
    if s == "" {
        return "<none>"
    }
    return s
}

_itoa(n: int) -> string {
    if n == 0 {
        return "0"
    }
    v = n
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_digit(d)}${s}"
        v = v / 10
    }
    return s
}
_digit(d: int) -> string {
    if d == 0 { return "0" }
    if d == 1 { return "1" }
    if d == 2 { return "2" }
    if d == 3 { return "3" }
    if d == 4 { return "4" }
    if d == 5 { return "5" }
    if d == 6 { return "6" }
    if d == 7 { return "7" }
    if d == 8 { return "8" }
    return "9"
}
