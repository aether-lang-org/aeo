// spec_load_balancer.ae — the load-balancer MODEL + grammar + model-check rules.
// Pure model, no provisioning (mirrors how egress_fqdn landed: surface first).
// Proves: the balancer contains its backends; publish/listens are recorded;
// balance_to is the spec each backend's listens() is checked against; the
// algorithm is inferred from weights; a weight ignored by an explicit algo is
// flagged for `aeo up`; and the three role-relative/consistency model errors
// fire (and stay silent when the tree is well-formed).
// See docs/built_in_load_balancing.md.

import aeocha
import compose (
    load_balancer, container, listens, publish, publish_map,
    balance_to, algorithm, lb_health, balancer_weight, breaker, cache,
    is_load_balancer, get_lb_substrate, get_listens, get_publish, get_publish_inner,
    get_balance_to, get_weight, get_lb_health_path, get_lb_health_expect,
    get_lb_breaker, get_lb_cache,
    lb_backends, lb_algorithm, lb_weight_ignored,
    lb_model_errors, reset_nodes
)
import std.string

// A well-formed balancer: web contains app-1/app-2, both listen 8080, weighted.
declare_ok() {
    load_balancer("web", "container") {
        publish(9000)
        balance_to(8080) {
            lb_health("/healthz", 200)
        }
        container("app-1") { listens(8080); balancer_weight(3) }
        container("app-2") { listens(8080); balancer_weight(1) }
    }
}

main() {
    fw = aeocha.init()
    reset_nodes()
    declare_ok()

    aeocha.describe(fw, "load_balancer model + grammar") {

        aeocha.describe("shape: the balancer contains its backends") {
            aeocha.it("marks web as a load_balancer with its substrate") callback {
                aeocha.expect_int(is_load_balancer("web")).to_be_truthy()
                aeocha.expect_str(get_lb_substrate("web")).to_equal_str("container")
                aeocha.expect_int(is_load_balancer("app-1")).to_equal(0)
            }
            aeocha.it("derives the pool from the children (membership can't drift)") callback {
                aeocha.expect_str(lb_backends("web")).to_equal_str("app-1, app-2")
            }
        }

        aeocha.describe("directional port verbs (publish / listens)") {
            aeocha.it("publish(9000) collapses ext==inner on the LB") callback {
                aeocha.expect_str(get_publish("web")).to_equal_str("9000")
                aeocha.expect_str(get_publish_inner("web")).to_equal_str("9000")
            }
            aeocha.it("listens is recorded per backend") callback {
                aeocha.expect_str(get_listens("app-1")).to_equal_str("8080")
                aeocha.expect_str(get_listens("app-2")).to_equal_str("8080")
            }
        }

        aeocha.describe("balance_to is the SPEC, listens is the CLAIM") {
            aeocha.it("records the forward port on the LB") callback {
                aeocha.expect_str(get_balance_to("web")).to_equal_str("8080")
            }
        }

        aeocha.describe("circuit breaker + response cache") {
            aeocha.it("records breaker() and cache() on the LB, comma-joined") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080) {
                        breaker(5, 30000, 1)
                        cache(1000, 65536, 60, "method_url_vary")
                    }
                    container("app-1") { listens(8080) }
                }
                aeocha.expect_str(get_lb_breaker("web")).to_equal_str("5,30000,1")
                aeocha.expect_str(get_lb_cache("web")).to_equal_str("1000,65536,60,method_url_vary")
            }
            aeocha.it("are absent (empty) when not declared") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080)
                    container("app-1") { listens(8080) }
                }
                aeocha.expect_str(get_lb_breaker("web")).to_equal_str("")
                aeocha.expect_str(get_lb_cache("web")).to_equal_str("")
            }
        }

        aeocha.describe("algorithm inference (§5)") {
            aeocha.it("infers weighted_rr because backends carry weights") callback {
                reset_nodes(); declare_ok()   // independent of suite ordering
                aeocha.expect_str(lb_algorithm("web")).to_equal_str("weighted_rr")
            }
            aeocha.it("no weight is ignored (inferred algo honours them)") callback {
                reset_nodes(); declare_ok()
                aeocha.expect_int(lb_weight_ignored("web")).to_equal(0)
            }
        }

        aeocha.describe("a well-formed tree has NO model errors") {
            aeocha.it("lb_model_errors is empty") callback {
                reset_nodes(); declare_ok()
                aeocha.expect_str(lb_model_errors()).to_equal_str("")
            }
        }

        // ---- negative cases: each rebuilds a BROKEN tree and asserts the check
        // fires. reset_nodes() clears the global model between trees.

        aeocha.describe("model error (§4): backend listens() disagrees with balance_to()") {
            aeocha.it("flags the mismatched backend by name and port") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080)
                    container("app-1") { listens(8080) }
                    container("app-2") { listens(9090) }   // WRONG port
                }
                errs = lb_model_errors()
                aeocha.expect_int(_has(errs, "forwards to 8080 but backend 'app-2' listens on 9090")).to_be_truthy()
            }
        }

        aeocha.describe("model error (§7): unsupported substrate") {
            aeocha.it("flags a :vm balancer (only :container is realized today)") callback {
                reset_nodes()
                load_balancer("web", "vm") {
                    publish(9000)
                    balance_to(8080)
                    container("app-1") { listens(8080) }
                }
                errs = lb_model_errors()
                aeocha.expect_int(_has(errs, "substrate 'vm' is not yet supported")).to_be_truthy()
            }
            aeocha.it("a :container balancer is clean") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080)
                    container("app-1") { listens(8080) }
                }
                aeocha.expect_str(lb_model_errors()).to_equal_str("")
            }
        }

        aeocha.describe("model error (§3): publish() on a non-boundary node") {
            aeocha.it("flags a backend that tries to publish") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080)
                    container("app-1") { listens(8080); publish(8443) }   // ILLEGAL
                }
                errs = lb_model_errors()
                aeocha.expect_int(_has(errs, "node 'app-1' declares publish() but is not a load_balancer")).to_be_truthy()
            }
        }

        aeocha.describe("model error (§3): balancer_weight outside a load_balancer") {
            aeocha.it("flags a weight on a node whose parent is not an LB") callback {
                reset_nodes()
                container("loner") { listens(8080); balancer_weight(5) }   // no LB parent
                errs = lb_model_errors()
                aeocha.expect_int(_has(errs, "node 'loner' declares balancer_weight() but its parent is not a load_balancer")).to_be_truthy()
            }
        }

        aeocha.describe("weight/algorithm mismatch (§5): surfaced, not a hard error") {
            aeocha.it("flags a weight ignored by an explicit round_robin, but NOT as a model error") callback {
                reset_nodes()
                load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080) {
                        algorithm("round_robin")          // explicitly ignores weights
                    }
                    container("app-1") { listens(8080); balancer_weight(3) }
                    container("app-2") { listens(8080); balancer_weight(1) }
                }
                aeocha.expect_int(lb_weight_ignored("web")).to_be_truthy()   // surfaced at up
                aeocha.expect_str(lb_algorithm("web")).to_equal_str("round_robin")
                aeocha.expect_str(lb_model_errors()).to_equal_str("")        // NOT a hard error
            }
        }
    }

    aeocha.run_summary(fw)
}

_has(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 1 }
    return 0
}
