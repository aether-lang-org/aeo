// spec_protocol_delegate.ae — the recursion verb (`delegate`) of lib/protocol.
//
// `delegate <token> <child>` is how an agent is told to become a child's parent
// and recurse one boundary down (bin/aeo-agent _delegate_child hands a boot DOWN
// to the child's inbox and relays the child's report UP). This spec guards the
// WIRE CONTRACT for that verb — encode -> parse round-trip — so a transport swap
// or a protocol edit can't silently break recursion. The end-to-end convergence
// (two real agents, file transport) is proven by test/agent-recursion.sh.
//
//   sh test/run-spec.sh test/spec_protocol_delegate.ae
//
// Covers:
//   - encode_delegate produces a line whose verb/token/arg1 re-parse INTACT
//   - delegate is distinct from boot (same node+token, different verb)

import aeocha
import protocol (encode_delegate, encode_boot, verb_of, token_of, arg1_of)
import std.string   // bare form: inlined aeocha calls bare `copy` unqualified

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "lib/protocol — the delegate (recursion) verb") {

        aeocha.describe("encode/parse round-trip") {
            aeocha.it("a delegate line re-parses intact") callback {
                line = encode_delegate("courier-secret", "inner")
                aeocha.expect_str(verb_of(line)).to_equal_str("delegate")
                aeocha.expect_str(token_of(line)).to_equal_str("courier-secret")
                aeocha.expect_str(arg1_of(line)).to_equal_str("inner")
            }

            aeocha.it("delegate is distinct from boot (parent recurses, not self-boots)") callback {
                d = encode_delegate("t", "child")
                b = encode_boot("t", "child")
                aeocha.expect_str(verb_of(d)).to_equal_str("delegate")
                aeocha.expect_str(verb_of(b)).to_equal_str("boot")
                aeocha.expect_str(arg1_of(d)).to_equal_str(arg1_of(b))
            }
        }
    }

    aeocha.run_summary(fw)
}
