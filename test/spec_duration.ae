// test/spec_duration.ae — aether DURATION LITERALS woven into the aeo DSL, the
// FluentSelenium within()/secs() idiom on aeo's grain. `within(30s) every(500ms)`
// expresses a health-retry as WALL-CLOCK time (not a hand-computed attempt count);
// the budget is DERIVED (window / interval). A Duration is int64 ns -> /1e6 = ms.

import aeocha
import compose (system, container, image, within, every, without, health_interval, health_budget,
                get_interval, get_budget, get_within_ms, get_without_ms)
import std.string (string_from_int)
import std.string   // bare: aeocha's inlined asserts call string.copy unqualified

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "duration literals in the aeo DSL (within/every)") {

        aeocha.it("within(30s) every(500ms) -> interval 500ms, derived budget 60") callback {
            system("d1") {
                db = container("db") {
                    image("redis")
                    within(30s)
                    every(500ms)
                }
            }
            aeocha.assert_str_eq(string_from_int(get_interval("db")), "500", "every(500ms) -> 500")
            aeocha.assert_str_eq(string_from_int(get_within_ms("db")), "30000", "within(30s) -> 30000ms")
            // budget = window/interval = 30000/500 = 60 (the FluentSelenium within semantics)
            aeocha.assert_str_eq(string_from_int(get_budget("db")), "60", "derived attempts")
        }

        aeocha.it("within(5s) with default 1s interval -> budget 5") callback {
            system("d2") {
                svc = container("svc") {
                    image("redis")
                    within(5s)
                }
            }
            aeocha.assert_str_eq(string_from_int(get_budget("svc")), "5", "5s / 1s default = 5")
        }

        aeocha.it("an explicit health_budget still WINS over within (back-compat)") callback {
            system("d3") {
                old = container("old") {
                    image("redis")
                    health_interval(250)
                    health_budget(12)
                    within(99s)
                }
            }
            aeocha.assert_str_eq(string_from_int(get_interval("old")), "250", "int setter honored")
            aeocha.assert_str_eq(string_from_int(get_budget("old")), "12", "explicit budget wins")
        }

        aeocha.it("no tuning -> the defaults (1s interval, 60 attempts)") callback {
            system("d4") {
                bare = container("bare") { image("redis") }
            }
            aeocha.assert_str_eq(string_from_int(get_interval("bare")), "1000", "default interval")
            aeocha.assert_str_eq(string_from_int(get_budget("bare")), "60", "default budget")
        }

        // The FluentSelenium FLOAT: within(d) at SYSTEM scope applies to every node
        // below that doesn't set its own — frozen at each node's declaration so a
        // later sibling's within() can't leak backward.
        aeocha.it("system-scope within(20s) every(250ms) FLOATS onto nodes below") callback {
            system("d5") {
                within(20s)
                every(250ms)
                inherits = container("inherits") { image("redis") }     // no own -> floats
                overrides = container("overrides") { image("redis") within(5s) }
            }
            aeocha.assert_str_eq(string_from_int(get_within_ms("inherits")), "20000", "floated window")
            aeocha.assert_str_eq(string_from_int(get_interval("inherits")), "250", "floated interval")
            // a later sibling's own within() must NOT leak back onto an earlier one:
            aeocha.assert_str_eq(string_from_int(get_within_ms("overrides")), "5000", "own wins")
            aeocha.assert_str_eq(string_from_int(get_within_ms("inherits")), "20000", "no backward leak")
        }

        aeocha.it("the float is scoped per-system (doesn't leak across systems)") callback {
            system("d6a") { within(9s) a = container("a") { image("redis") } }
            system("d6b") { b = container("b") { image("redis") } }   // fresh system, no float
            aeocha.assert_str_eq(string_from_int(get_within_ms("a")), "9000", "d6a floated")
            aeocha.assert_str_eq(string_from_int(get_within_ms("b")), "0", "d6b unset (float reset)")
        }

        // without() — the FluentSelenium retry-until-GONE twin (teardown wait).
        // Same float + snapshot + per-system mechanism as within().
        aeocha.it("without(d) floats + overrides like within (the teardown twin)") callback {
            system("d7") {
                without(10s)                                            // floats
                lingerable = container("lingerable") { image("redis") }
                fast = container("fast") { image("redis") without(2s) } // own
            }
            aeocha.assert_str_eq(string_from_int(get_without_ms("lingerable")), "10000", "floated gone-window")
            aeocha.assert_str_eq(string_from_int(get_without_ms("fast")), "2000", "own wins")
            // within and without are INDEPENDENT windows on the same node.
            system("d8") {
                both = container("both") { image("redis") within(30s) without(8s) }
            }
            aeocha.assert_str_eq(string_from_int(get_within_ms("both")), "30000", "within independent")
            aeocha.assert_str_eq(string_from_int(get_without_ms("both")), "8000", "without independent")
        }

        aeocha.it("no without() -> 0 (back-compat: the old state-flip teardown)") callback {
            system("d9") { plain = container("plain") { image("redis") } }
            aeocha.assert_str_eq(string_from_int(get_without_ms("plain")), "0", "unset -> no extra wait")
        }
    }

    aeocha.run_summary(fw)
}
