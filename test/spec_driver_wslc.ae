// spec_driver_wslc.ae — Microsoft WSL Containers backend argv seam (lib/driver_wslc).
//
// driver_wslc shells `wslc.exe` (MSFT's native WSL Containers CLI, WSL >= 2.9.3)
// DIRECTLY — no `wsl -d <distro> -- podman` prefix, no podman. The testable core
// (no wslc host needed) is the pure argv builders + the JSON name extraction the
// probe relies on. This spec proves those; the up/down/probe exec paths need a real
// wslc host (proven on the bazzite Win11 guest) — that's integration, not unit.
//
//   sh test/run-spec.sh test/spec_driver_wslc.ae
//
// Covers:
//   - run_argv: `run -d --name N [-p H:C] [-e K=V] IMG /bin/sh -c CMD` (no --replace)
//   - list_json_argv: `list --filter name=N --format json` (probe query)
//   - stop_argv/remove_argv: wslc's teardown verbs (`container stop`, `container
//     remove` — NOT `rm`)
//   - name() identifies the tier

import aeocha
import driver_wslc (name, run_argv, list_json_argv, stop_argv, remove_argv, exec_argv)
import std.string (string_from_int)
import std.string   // bare form: inlined aeocha calls bare `copy` unqualified

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "lib/driver_wslc — native WSL Containers argv") {

        aeocha.describe("run_argv") {
            aeocha.it("builds `run -d --name N -p H:C -e K=V IMG /bin/sh -c CMD`") callback {
                av = run_argv("db", "docker.io/library/alpine:latest", "sleep 600", 8080, "K=V")
                // run, -d, --name, db, -p, 8080:8080, -e, K=V, IMG, /bin/sh, -c, sleep 600 = 12
                aeocha.assert_str_eq(string_from_int(list_size(av)), "12", "12 tokens")
                aeocha.assert_str_eq(list_get_raw(av, 0), "run", "run")
                aeocha.assert_str_eq(list_get_raw(av, 1), "-d", "detached")
                aeocha.assert_str_eq(list_get_raw(av, 2), "--name", "name flag")
                aeocha.assert_str_eq(list_get_raw(av, 3), "db", "name")
                aeocha.assert_str_eq(list_get_raw(av, 4), "-p", "publish flag")
                aeocha.assert_str_eq(list_get_raw(av, 5), "8080:8080", "port map")
                aeocha.assert_str_eq(list_get_raw(av, 6), "-e", "env flag")
                aeocha.assert_str_eq(list_get_raw(av, 7), "K=V", "env pair")
                aeocha.assert_str_eq(list_get_raw(av, 8), "docker.io/library/alpine:latest", "image")
                aeocha.assert_str_eq(list_get_raw(av, 11), "sleep 600", "command")
            }
            aeocha.it("omits -p and -e when unset; no command -> no /bin/sh") callback {
                av = run_argv("bare", "alpine", "", 0, "")
                // run, -d, --name, bare, alpine = 5 tokens
                aeocha.assert_str_eq(string_from_int(list_size(av)), "5", "5 tokens (no -p/-e/cmd)")
                aeocha.assert_str_eq(list_get_raw(av, 4), "alpine", "image last")
            }
        }

        aeocha.describe("probe query") {
            aeocha.it("list_json_argv = `list --filter name=N --format json`") callback {
                av = list_json_argv("web")
                aeocha.assert_str_eq(string_from_int(list_size(av)), "5", "5 tokens")
                aeocha.assert_str_eq(list_get_raw(av, 0), "list", "list")
                aeocha.assert_str_eq(list_get_raw(av, 1), "--filter", "filter flag")
                aeocha.assert_str_eq(list_get_raw(av, 2), "name=web", "name filter")
                aeocha.assert_str_eq(list_get_raw(av, 3), "--format", "format flag")
                aeocha.assert_str_eq(list_get_raw(av, 4), "json", "json format")
            }
        }

        aeocha.describe("teardown verbs (wslc uses `container remove`, not `rm`)") {
            aeocha.it("stop_argv = `container stop N`") callback {
                av = stop_argv("db")
                aeocha.assert_str_eq(string_from_int(list_size(av)), "3", "3 tokens")
                aeocha.assert_str_eq(list_get_raw(av, 0), "container", "container")
                aeocha.assert_str_eq(list_get_raw(av, 1), "stop", "stop")
                aeocha.assert_str_eq(list_get_raw(av, 2), "db", "name")
            }
            aeocha.it("remove_argv = `container remove N` (NOT rm)") callback {
                av = remove_argv("db")
                aeocha.assert_str_eq(list_get_raw(av, 1), "remove", "remove (not rm)")
            }
        }

        aeocha.describe("identity") {
            aeocha.it("names the wslc tier") callback {
                aeocha.assert_str_eq(name(), "wslc", "kind name")
            }
        }
    }

    aeocha.run_summary(fw)
}
