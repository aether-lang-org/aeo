// spec_ipam.ae — the iterative-dev STICKY IP property: try-again re-runs reuse
// the SAME address (the dev's curl/browser/poked-redis stay valid), cleared
// only by an explicit reset. Composition stays IP-free; ipam binds name->addr
// in ./.aeo/<system>.ips (survives `make clean`; dies on rm -rf .aeo).

import aeocha
import ipam (resolve_ip, reset_bindings, bindings_dump)
import std.string

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "ipam: sticky per-project IP allocation (iterative-dev DX)") {

        aeocha.describe("first allocation") {
            aeocha.it("allocates lowest-free in the range, distinct per resource") callback {
                reset_bindings("specsys")
                a = resolve_ip("specsys", "db_vm")
                b = resolve_ip("specsys", "python_vm")
                aeocha.assert_str_eq(a, "172.16.0.10", "db_vm -> first free (.10, after the .1 gateway)")
                aeocha.assert_str_eq(b, "172.16.0.11", "python_vm -> next free (.11)")
                aeocha.assert_true(_ne(a, b), "two resources get DISTINCT addresses")
            }
        }

        aeocha.describe("STICKY: re-runs reuse the same address (try-again DX)") {
            aeocha.it("resolving the same resource again returns the SAME address") callback {
                // the heart of it: db_vm comes back at the same IP run after run
                first  = resolve_ip("specsys", "db_vm")
                again  = resolve_ip("specsys", "db_vm")
                again2 = resolve_ip("specsys", "db_vm")
                aeocha.assert_str_eq(again,  first, "2nd run: same IP")
                aeocha.assert_str_eq(again2, first, "3rd run: STILL same IP")
            }
            aeocha.it("the binding is persisted to the file (survives a fresh process)") callback {
                dump = bindings_dump("specsys")
                aeocha.assert_true(_has(dump, "db_vm  172.16.0.10"), "db_vm binding written to ./.aeo")
                aeocha.assert_true(_has(dump, "python_vm  172.16.0.11"), "python_vm binding written")
            }
        }

        aeocha.describe("RESET: the explicit 'fresh IPs' gesture") {
            aeocha.it("reset clears the bindings; next resolve re-allocates") callback {
                reset_bindings("specsys")
                aeocha.assert_str_eq(bindings_dump("specsys"), "", "bindings cleared")
                fresh = resolve_ip("specsys", "db_vm")
                aeocha.assert_str_eq(fresh, "172.16.0.10", "re-allocates from the bottom after reset")
            }
        }
    }

    aeocha.run_summary(fw)
    reset_bindings("specsys")    // leave no .aeo artifact behind
}

_ne(a: string, b: string) -> int { if a == b { return 0 } return 1 }
_has(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 1 }
    return 0
}
