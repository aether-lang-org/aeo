// spec_capsicum.ae — Capsicum confinement of the bhyve HYPERVISOR, two-phase.
//
// THE MODEL (corrected): Capsicum is a FreeBSD-kernel facility. It can only
// confine FreeBSD-native processes — here the BHYVE hypervisor process. It
// CANNOT confine a Linux container inside the guest (no Capsicum in a Linux
// kernel) and it CANNOT confine a running process after the fact (cap_enter()
// is enter-once / irreversible). And bhyve needs broad access during
// provision + first boot (open the disk image, the tap, the seed ISO,
// cloud-init). So confinement is a TWO-PHASE lifecycle, expressed as two
// blocks:
//
//   db = bhyve_vm("myapp") { ... }    // PHASE 1: provision + first boot +
//                                     //          shut down — UNCONSTRAINED
//   constrain("lock") {               // PHASE 2: relaunch confined
//       constraint("disk", ".../disk0.img", "rd,wr")
//       constraint("net",  "tap0", "rd,wr")
//       start(db)                     // re-exec bhyve under cap_enter(),
//   }                                 //   holding ONLY those fds; else DENIED
//
// This spec asserts the resolved data model (the snapshot shows the VM as
// confined by the block + its bound constraints). The LIVE enforcement —
// aeo actually relaunching bhyve through a cap_enter() wrapper and proving the
// confined process holds only the granted fds — is gated AEO_VERIFY=1 and
// needs the BSD box (and the launcher wiring); documented as the next build.
//
//   ae run test/spec_capsicum.ae --lib lib --lib ../aeocha

import aeocha
import compose (system, bhyve_vm, container, image, expose, guest_image, cpus, memory)
import compose (constrain, constraint, start, get_confined_by, get_constraints, describe_tree)
import std.string
import std.os (getenv)

// PHASE 1: declare + (on aeo up) provision + first boot + shut down. This is
// the bhyve_vm exactly as it works today — no restrictions, so cloud-init can
// open everything it needs.
//
// PHASE 2: a constrain("lock") block relaunches `myapp` holding only the disk,
// tap, and console fds. The redis container still lives inside the guest (a
// Linux concern — NOT Capsicum's job); Capsicum confines the HYPERVISOR around
// it.
declare() {
    system("red222") {
        db = bhyve_vm("myapp") {
            cpus(2)
            memory("2G")
            guest_image("ubuntu-22.04")
            app = container("app") {
                image("docker.io/library/redis:alpine")
                expose(6379)
            }
        }

        constrain("lock") {
            constraint("disk",    "/zroot/vm/myapp/disk0.img", "rd,wr")
            constraint("net",     "tap0", "rd,wr")
            constraint("console", "nmdm-myapp", "rd,wr")
            start(db)
        }
    }
}

main() {
    fw = aeocha.init()
    declare()

    aeocha.describe(fw, "CAPSICUM — two-phase confinement of the bhyve hypervisor") {

        aeocha.it("snapshot: myapp is confined by 'lock' with the bound fd grants") callback {
            want = <<TREE
                system red222:
                  bhyve myapp [guest=ubuntu-22.04, cpus=2, mem=2G, confined[lock]: disk(/zroot/vm/myapp/disk0.img)=rd,wr, net(tap0)=rd,wr, console(nmdm-myapp)=rd,wr]
                    container app [image=docker.io/library/redis:alpine, expose=6379]
TREE
            aeocha.assert_str_eq(fw, describe_tree(), want, "VM shows its phase-2 confinement")
        }

        aeocha.it("the constrain block records exactly the granted capabilities") callback {
            aeocha.assert_str_eq(fw, get_confined_by("myapp"), "lock", "myapp is confined by 'lock'")
            aeocha.assert_str_eq(fw, get_constraints("lock"),
                "disk(/zroot/vm/myapp/disk0.img)=rd,wr, net(tap0)=rd,wr, console(nmdm-myapp)=rd,wr",
                "the three bound fd grants, in order")
        }

        aeocha.it("LIVE: bhyve relaunches under cap_enter() holding only the granted fds") callback {
            // The real teeth: aeo re-execs bhyve through a wrapper that opens
            // disk/tap/console, cap_rights_limit()s each to the granted mask,
            // cap_enter()s, then exec bhyve. Then prove the confined process
            // can't open anything else. Needs the BSD box + the launcher.
            if string.length(getenv("AEO_VERIFY")) == 0 {
                aeocha.assert_true(fw, 1, "skipped (AEO_VERIFY=1 on the BSD box; launcher is the next build)")
            } else {
                aeocha.assert_true(fw, 1, "TODO: assert confined bhyve holds only disk/tap/console")
            }
        }
    }

    aeocha.run_summary(fw)
}
