// Smoke test: the FreeBSD jail driver — pure-logic + idempotency checks
// that need no privilege. A real jail up→probe→down cycle needs root + a
// populated jail root and is driven separately (see test/jail-root setup
// notes); this validates the driver's contract surface.
//
// Run:  ae build test/smoke_bsd.ae -o /tmp/sb --lib lib && /tmp/sb

import driver_bsd

main() {
    // --- pure-logic assertions (always) ---
    if driver_bsd.name() != "bsd" {
        println("FAIL: name")
        return
    }
    mp = driver_bsd.mountpoint_for("zroot/jails/db")
    if mp != "/zroot/jails/db" {
        println("FAIL: mountpoint_for got ${mp}")
        return
    }
    println("PASS: bsd driver pure logic (name, mountpoint_for)")

    // --- probe of a definitely-absent jail returns 0 ---
    if driver_bsd.probe("aeo-nope-xyz", "", "") != 0 {
        println("FAIL: probe of absent jail should be 0")
        return
    }
    println("PASS: probe(absent jail) == 0")

    // --- down of an absent jail is success (idempotent) ---
    e = driver_bsd.down("aeo-nope-xyz")
    if e != "" {
        println("FAIL: down(absent) should be ok, got: ${e}")
        return
    }
    println("PASS: down(absent jail) is idempotent success")

    println("=== driver_bsd pure-logic: ALL PASS ===")
    println("(real jail up/down requires root + a populated jail root; see test/jail-root setup)")
}
