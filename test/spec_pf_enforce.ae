// spec_pf_enforce.ae — the ENFORCEMENT seam (lib/pf.resolve): the proven pf
// rulegen (spec_pf_rulegen) emits $<name> tokens; this proves they get
// substituted with the ipam-resolved IPs the driver booted each VM at, so the
// live firewall and the boot AGREE. The pure half — no root, no pfctl; runs
// anywhere. The `pfctl -f` load itself (lib/pf.apply) is FreeBSD+root, exercised
// on the GhostBSD box.
//
//   sh test/run-spec.sh test/spec_pf_enforce.ae
//
// Closes the model->live gap: spec_pf_rulegen proved the RIGHT rules are
// generated; this proves they're RESOLVED to real addresses ready for pfctl.

import aeocha
import compose (constrain, grant_fd, ingress_from, egress, ingress, deny_egress, pf_rules_for)
import pf (resolve, anchor_name, anchor_path)
import ipam (resolve_ip, reset_bindings)
import std.string (string_contains)
import std.string   // bare: inlined aeocha calls bare exports unqualified

SYS() -> string { return "pfsys" }

main() {
    fw = aeocha.init()

    // Deterministic sticky bindings: resolve in declaration order so db_vm gets
    // the lowest IP, python_vm the next — the SAME order the runner resolves.
    reset_bindings(SYS())
    db_ip  = resolve_ip(SYS(), "db_vm")
    py_ip  = resolve_ip(SYS(), "python_vm")

    // The apex netpolicy (same as silly_addition_cache).
    constrain("db_vm")     { ingress_from(6379, "python_vm") deny_egress() }
    constrain("python_vm") { egress("db_vm", 6379) ingress(8080) }

    aeocha.describe(fw, "pf enforcement seam: tokens resolve to booted IPs") {

        aeocha.describe("db_vm rules") {
            aeocha.it("substitutes $db_vm and $python_vm with their ipam IPs") callback {
                r = resolve(SYS(), pf_rules_for("db_vm"))
                // peer-restricted ingress: from python_vm's IP to db_vm's IP:6379
                aeocha.assert_true(_has(r, "pass in proto tcp from ${py_ip} to ${db_ip} port 6379"),
                    "6379 allowed from python_vm's resolved address only")
                // deny-default catch-all on db_vm's resolved address
                aeocha.assert_true(_has(r, "block in proto tcp to ${db_ip}"), "deny rest in")
                aeocha.assert_true(_has(r, "block out proto tcp from ${db_ip}"), "zero egress (deny_egress)")
            }
            aeocha.it("leaves no $ tokens behind") callback {
                r = resolve(SYS(), pf_rules_for("db_vm"))
                aeocha.assert_true(_absent(r, "$"), "every $<name> token was resolved")
            }
        }

        aeocha.describe("python_vm rules") {
            aeocha.it("egress + ingress resolve to real addresses") callback {
                r = resolve(SYS(), pf_rules_for("python_vm"))
                aeocha.assert_true(_has(r, "pass out proto tcp from ${py_ip} to ${db_ip} port 6379"),
                    "egress to db_vm:6379 at its resolved IP")
                aeocha.assert_true(_has(r, "pass in proto tcp to ${py_ip} port 8080"), "ingress 8080")
                aeocha.assert_true(_absent(r, "$"), "no tokens left")
            }
        }

        aeocha.describe("per-VM anchor isolation") {
            aeocha.it("each VM loads into its OWN anchor (aeo/<vm>, distinct path)") callback {
                aeocha.assert_str_eq(anchor_name("db_vm"), "aeo/db_vm", "db_vm anchor")
                aeocha.assert_str_eq(anchor_name("python_vm"), "aeo/python_vm", "python_vm anchor")
                aeocha.assert_str_eq(anchor_path("db_vm"), "/etc/pf.anchors/aeo-db_vm", "db_vm anchor file")
            }
        }
    }

    reset_bindings(SYS())   // leave no .aeo artifact behind
    aeocha.run_summary(fw)
}

_has(hay: string, needle: string) -> int {
    if string_contains(hay, needle) == 1 { return 1 }
    return 0
}
_absent(hay: string, needle: string) -> int {
    if string_contains(hay, needle) == 1 { return 0 }
    return 1
}
