// spec_agent_auth.ae — the bank-courier auth core (lib/agent_auth).
//
// Proves the mint + constant-time-verify the aeo-agent channel will use: a
// freshly-minted CSPRNG secret, HMAC-keyed verification, fail-closed on an empty
// secret. All stock stdlib (std.nanoid + std.cryptography.hmac) — wiring, not
// new crypto. (Wire transport + TLS are separate; this is the auth core.)
//
//   sh test/run-spec.sh test/spec_agent_auth.ae
//
// Covers:
//   - mint_secret yields a non-empty secret, and two mints DIFFER (it's random)
//   - verify accepts the matching secret
//   - verify REJECTS a wrong secret
//   - verify is FAIL-CLOSED: an empty configured secret denies everything
//   - mac is stable for the same secret (deterministic keyed MAC)

import aeocha
import agent_auth (mint_secret, verify, mac)
import std.string (string_length)
import std.string   // bare form: inlined aeocha calls bare `copy` unqualified

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "lib/agent_auth — bank-courier mint + verify") {

        aeocha.describe("mint") {
            aeocha.it("mints a non-empty secret") callback {
                s = mint_secret()
                aeocha.expect_int(string_length(s)).to_be_gt(0)
            }
            aeocha.it("two mints differ (it's actually random)") callback {
                a = mint_secret()
                b = mint_secret()
                // no fluent str-inequality matcher (StrSubject.not_ isn't wired) —
                // assert the equality PREDICATE is false: distinct secrets.
                aeocha.expect_int(_eq(a, b)).to_be_falsy()
            }
        }

        aeocha.describe("verify (constant-time)") {
            aeocha.it("accepts the matching secret") callback {
                s = mint_secret()
                aeocha.expect_int(verify(s, s)).to_be_truthy()      // match -> allow
            }
            aeocha.it("rejects a wrong secret") callback {
                s = mint_secret()
                w = mint_secret()
                aeocha.expect_int(verify(s, w)).to_be_falsy()       // mismatch -> deny
            }
            aeocha.it("is fail-closed: empty configured secret denies all") callback {
                aeocha.expect_int(verify("", "anything")).to_be_falsy()  // no key -> deny
                aeocha.expect_int(verify("", "")).to_be_falsy()          // empty vs empty -> deny
            }
        }

        aeocha.describe("mac") {
            aeocha.it("is stable for the same secret") callback {
                m1 = mac("courier-key-xyz")
                m2 = mac("courier-key-xyz")
                aeocha.expect_str(m1).to_equal_str(m2)              // same secret -> same MAC
            }
        }
    }

    aeocha.run_summary(fw)
}

// 1 if the two strings are equal (aeocha has no fluent str-inequality yet).
_eq(a: string, b: string) -> int {
    if a == b { return 1 }
    return 0
}
