// spec_driver_loadbalancer.ae — the load_balancer driver's pure renderers
// (docs §9 step 2/3). backend_specs() maps the model (children + listens +
// weight) to the ';'-separated "url|weight;…" the aeo-lb container parses;
// lb_env() renders the full AEO_LB_* env; lb_net() names the backends' net.
// No container launch here — that's the live proof (spec_driver_loadbalancer_live).

import aeocha
import compose (
    system, container, load_balancer, listens, publish, balance_to, lb_health, balancer_weight,
    health_retry, every, up_within, down_within,
    reset_nodes
)
import driver_loadbalancer (backend_specs, lb_env, lb_net, lb_image, lb_health_timing)
import std.string

_declare() {
    reset_nodes()
    system("lbsys") {
        web = load_balancer("web", "container") {
            publish(9000)
            balance_to(8080)
            app1 = container("app-1") { listens(8080); balancer_weight(3) }
            app2 = container("app-2") { listens(8080); balancer_weight(1) }
        }
    }
}

main() {
    fw = aeocha.init()
    _declare()

    aeocha.describe(fw, "driver_loadbalancer pure renderers") {
        aeocha.it("renders backends as http://name:port|weight, weighted") callback {
            aeocha.expect_str(backend_specs("web")).to_equal_str(
                "http://app-1:8080|3;http://app-2:8080|1")
        }
        aeocha.it("defaults weight to 1 when unset") callback {
            reset_nodes()
            system("s2") {
                lb = load_balancer("lb", "container") {
                    publish(80)
                    balance_to(8080)
                    a = container("a") { listens(8080) }          // no weight
                }
            }
            aeocha.expect_str(backend_specs("lb")).to_equal_str("http://a:8080|1")
        }
        aeocha.it("skips a child with no listens() (not routable)") callback {
            reset_nodes()
            system("s3") {
                lb = load_balancer("lb", "container") {
                    publish(80)
                    balance_to(8080)
                    good = container("good") { listens(8080) }
                    bad  = container("bad")  { }                  // no listens
                }
            }
            aeocha.expect_str(backend_specs("lb")).to_equal_str("http://good:8080|1")
        }
        aeocha.it("lb_env renders the full AEO_LB_* pool (health included)") callback {
            reset_nodes()
            system("s4") {
                lb = load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080) {
                        lb_health("/healthz", 200)
                    }
                    a1 = container("app-1") { listens(8080); balancer_weight(3) }
                    a2 = container("app-2") { listens(8080); balancer_weight(1) }
                }
            }
            e = lb_env("web")
            aeocha.expect_int(_has(e, "AEO_LB_PORT=9000")).to_be_truthy()
            aeocha.expect_int(_has(e, "AEO_LB_ALGO=weighted_rr")).to_be_truthy()
            aeocha.expect_int(_has(e, "AEO_LB_BACKENDS=http://app-1:8080|3;http://app-2:8080|1")).to_be_truthy()
            aeocha.expect_int(_has(e, "AEO_LB_HEALTH_PATH=/healthz")).to_be_truthy()
            aeocha.expect_int(_has(e, "AEO_LB_HEALTH_STATUS=200")).to_be_truthy()
        }
        aeocha.it("lb_net is the backends' shared aeo-<system> net") callback {
            reset_nodes()
            system("mysys") {
                lb = load_balancer("web", "container") { publish(80); balance_to(8080) }
            }
            aeocha.expect_str(lb_net("web")).to_equal_str("aeo-mysys")
        }
        aeocha.it("lb_image defaults to the aeo-lb tag") callback {
            aeocha.expect_int(_has(lb_image(), "aeo-lb")).to_be_truthy()
        }
        // §6 "one clock, two enforcers": the system health_retry timing lowers
        // onto the pool checker. every=500ms, down_within=10s => interval 500,
        // timeout 500, unhealthy 10000/500=20, healthy=2 (readmit, fixed).
        aeocha.it("lowers system health_retry timing onto the pool checker (§6)") callback {
            reset_nodes()
            system("s5") {
                health_retry() {
                    every(500ms)
                    up_within(30s)
                    down_within(10s)
                }
                lb = load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080) { lb_health("/healthz", 200) }
                    a1 = container("app-1") { listens(8080) }
                }
            }
            aeocha.expect_str(lb_health_timing("web")).to_equal_str("500;500;20;2")
            e = lb_env("web")
            aeocha.expect_int(_has(e, "AEO_LB_HEALTH_INTERVAL=500")).to_be_truthy()
            aeocha.expect_int(_has(e, "AEO_LB_HEALTH_UNHEALTHY=20")).to_be_truthy()
        }
        // Defaults when no health_retry window is declared: interval falls to
        // get_interval's 1000 default; down_within unset => unhealthy 3.
        aeocha.it("falls back to sane defaults with no health_retry window") callback {
            reset_nodes()
            system("s6") {
                lb = load_balancer("web", "container") {
                    publish(9000)
                    balance_to(8080) { lb_health("/healthz", 200) }
                    a1 = container("app-1") { listens(8080) }
                }
            }
            aeocha.expect_str(lb_health_timing("web")).to_equal_str("1000;1000;3;2")
        }
    }

    aeocha.run_summary(fw)
}

_has(hay: string, needle: string) -> int {
    if string.contains(hay, needle) == 1 { return 1 }
    return 0
}
_ends_with(s: string, suffix: string) -> int {
    ls = string.length(s)
    lf = string.length(suffix)
    if lf > ls { return 0 }
    tail = string.substring(s, ls - lf, ls)
    if tail == suffix { return 1 }
    return 0
}
