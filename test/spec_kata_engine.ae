// spec_kata_engine.ae — engine("kata") as a container runtime (driver_linux).
//
// Kata Containers gives a `container()` VM-grade isolation (each container runs in a
// lightweight microVM with its own guest kernel) while keeping the container API. It's
// an OCI RUNTIME podman delegates to, not a standalone engine — so aeo realizes
// engine("kata") as the podman path + `--runtime <kata>`. This locks the pure runtime-
// flag decision; the live boot needs Kata installed on the host.
//
//   sh test/run-spec.sh test/spec_kata_engine.ae

import aeocha
import driver_linux (kata_runtime_flag)
import std.string

main() {
    fw = aeocha.init()
    aeocha.describe(fw, "engine(\"kata\") — Kata as a container OCI runtime") {

        aeocha.describe("kata_runtime_flag — the --runtime injection") {
            aeocha.it("engine(\"kata\") -> `--runtime kata` (podman's default kata runtime name)") callback {
                aeocha.expect_str(kata_runtime_flag("kata")).to_equal_str("--runtime kata")
            }
            aeocha.it("a non-kata engine adds NO runtime flag") callback {
                aeocha.expect_str(kata_runtime_flag("")).to_equal_str("")
                aeocha.expect_str(kata_runtime_flag("podman")).to_equal_str("")
                aeocha.expect_str(kata_runtime_flag("docker")).to_equal_str("")
                aeocha.expect_str(kata_runtime_flag("wslc")).to_equal_str("")
            }
        }
    }
    aeocha.run_summary(fw)
}
