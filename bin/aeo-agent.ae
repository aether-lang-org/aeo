// bin/aeo-agent — the recursive orchestration agent (v0).
//
// The container hands its contained an aeo-agent; the agent receives the
// instructions for its node (and, later, everything nested below it),
// brings its node up locally, and reports back OUT to its parent. It never
// reaches through a boundary — it acts inside, reports outward. The runner
// is just the depth-0 agent whose parent is the operator; this is the same
// role one boundary down.
//
// v0 scope: a single agent, file transport, driving a Linux container as
// its node. Bootstrap from env (the parent stamps these when it launches
// the host the agent rides in):
//   AEO_NODE   — which node this agent IS (its name in the parent's tree)
//   AEO_TOKEN  — the per-agent secret; the agent rejects commands whose
//                token doesn't match (v0: warn; the http transport will
//                fail-closed — single-parent security).
//   AEO_RENDEZVOUS — optional override of the shared transport root.
//
// Loop: announce → poll inbox → handle (boot/halt/probe) → report. The
// driver calls are the SAME ones the runner uses (driver_linux) — the
// agent and the runner share the bring-up mechanism; only "where work
// comes from" differs (transport vs compiled-in composition).
//
// Recursion (next): when a node the agent boots itself has get_host children,
// the agent hands THEM to their agents — same code it received work through.

import std.os
import std.os (run_capture, platform)
import std.list
import std.config
import std.string (string_length, string_char_at, string_contains)
import protocol
import agent_auth
import transport_file (ensure_dirs, inbox_dir, outbox_dir, put, recv_one)
import transport_http (send_command)
import driver_linux
import driver_windows
import std.http (server_create, server_set_host, server_get, server_post,
                 server_start_background,
                 response_set_status, response_set_header, response_set_body,
                 request_body)
import std.net (tcp_connect_raw, tcp_close)

extern exit(code: int)

// A MIDDLE agent must serve its parent AND dial its child — "serve-and-dial". The
// blocking `http_server_start_raw` prevents that (it never returns, so the second
// server never binds / the dial never runs — see aether:
// http-serve-and-dial-reentrancy-ask.md). `server_start_background` starts the
// listener on a detached native thread and returns immediately, so one process
// can host the server AND make outbound client calls. No actor needed.

// ---- HTTP-mode handlers (same compilation unit as main + the actor) -------
// Aether handlers are C-extern fn-pointers — they can't close over main's
// locals, so they read who-am-i + the secret from std.config (stamped at boot
// by _run_http). Each does the work INLINE via _dispatch_verb and replies
// synchronously with the report line, so http mode needs no drain loop.

_h_health(req: ptr, res: ptr, ud: ptr) -> int {
    response_set_status(res, 200)
    response_set_body(res, "ok")           // open liveness — the residence probe
    return 0
}

_h_dispatch(req: ptr, res: ptr, ud: ptr) -> int {
    me = config.get("aeo.agent.me")
    token = config.get("aeo.agent.token")
    line = request_body(req)
    // Auth gate FIRST (fail-closed) — a bad token never reaches the verb.
    if _auth_ok(token, protocol.token_of(line)) == 0 {
        response_set_status(res, 401)
        response_set_body(res, "unauthorized")
        return 0
    }
    rep = _dispatch_verb(me, token, line)
    response_set_status(res, 200)
    response_set_header(res, "Content-Type", "text/plain")
    response_set_body(res, rep)            // the report line, synchronously
    return 0
}

// Run the agent in HTTP mode: stamp identity into config (for the handlers),
// stand up the listener, spawn the blocking server actor. Does not return.
_run_http(me: string, token: string, port: int) {
    config.put("aeo.agent.me", me)
    config.put("aeo.agent.token", token)
    config.put("aeo.agent.transport", "http")   // so _delegate_child recurses via http
    raw = server_create(port)
    if raw == 0 {
        println("aeo-agent[${me}]: FAIL server_create on port ${port}")
        exit(1)
    }
    // Bind address. A RESIDENT agent inside a guest must be reachable by its
    // parent from OUTSIDE the guest (across the VM NIC), so it binds 0.0.0.0 by
    // default — 127.0.0.1 only answers loopback and is invisible to the parent's
    // dial (this bit the first real VM proof: the agent bound 127.0.0.1 and the
    // host's hostfwd couldn't reach it). AEO_BIND overrides (e.g. 127.0.0.1 for a
    // same-host localhost test where loopback is the whole point).
    bind = _env_or("AEO_BIND", "0.0.0.0")
    server_set_host(raw, bind)
    server_get(raw, "/health", _h_health, 0)
    server_post(raw, "/dispatch", _h_dispatch, 0)
    // Non-blocking start (detached thread) so this process can ALSO act as an
    // http client — the serve-and-dial property a middle agent needs.
    serr = server_start_background(raw)
    if string_length(serr) > 0 {
        println("aeo-agent[${me}]: FAIL server_start_background: ${serr}")
        exit(1)
    }
    println("aeo-agent[${me}]: http listening on 127.0.0.1:${port} (token=${_mask(token)})")
    // The server runs on its own thread; keep main alive to serve indefinitely.
    while 1 == 1 {
        sleep(1000)
    }
}

main() {
    me = _env_or("AEO_NODE", "")
    token = _env_or("AEO_TOKEN", "")
    if string_length(me) == 0 {
        println("aeo-agent: AEO_NODE not set — don't know who I am")
        exit(2)
    }
    println("aeo-agent[${me}]: starting (token=${_mask(token)})")

    // Transport select. http = a real socket (the conduit); file (default) = the
    // shared-dir rendezvous. The VERB logic (_dispatch_verb) is identical; only
    // "where work comes from / where the report goes" differs.
    transport = _env_or("AEO_TRANSPORT", "file")
    if transport == "http" {
        prt = _atoi(_env_or("AEO_PORT", "9450"))
        _run_http(me, token, prt)
        return
    }

    ensure_dirs(me)

    // Reach OUT: tell the parent I'm alive and ready for work.
    outbox = outbox_dir(me)
    _ = put(outbox, _next(), protocol.encode_announce(token, me))

    // Poll for work. v0: a bounded loop so the agent exits cleanly in
    // tests; a real agent loops until a shutdown command.
    inbox = inbox_dir(me)
    polls = 0
    running = 1
    while running == 1 {
        line = recv_one(inbox)
        if line == "" {
            polls = polls + 1
            if polls > 600 {           // ~60s at 100ms — give up if idle
                println("aeo-agent[${me}]: idle timeout, exiting")
                running = 0
            } else {
                sleep(100)
            }
        } else {
            polls = 0
            running = _handle(me, token, outbox, line)
        }
    }
}

// Authenticate a presented token against the couriered secret (bank-courier,
// constant-time). Returns 1 = ok, 0 = refuse. FAIL-CLOSED on a wrong token when
// a secret IS configured; OPEN when no secret is set on this agent (dev /
// file-transport convenience — both sides "" and we proceed). Shared by both
// transports so the policy lives in ONE place.
_auth_ok(token: string, presented: string) -> int {
    if string_length(token) == 0 {
        return 1                       // no courier key -> open mode
    }
    return agent_auth.verify(token, presented)
}

// Dispatch one verb and RETURN its report line (the wire artifact), or "" for a
// refused/unknown command. Pure w.r.t. transport: file mode `put`s the result
// to the outbox; http mode returns it as the response body. boot/probe/delegate/
// halt all funnel through here so the two transports can't diverge.
_dispatch_verb(me: string, token: string, line: string) -> string {
    v = protocol.verb_of(line)
    tok = protocol.token_of(line)
    node = protocol.arg1_of(line)

    if _auth_ok(token, tok) == 0 {
        println("aeo-agent[${me}]: REFUSED ${v} — token mismatch (fail-closed)")
        return ""
    }

    if v == "boot" {
        println("aeo-agent[${me}]: boot ${node}")
        err = _boot_node(node)
        st = "up"
        if err != "" {
            println("aeo-agent[${me}]: boot ${node} failed: ${err}")
            st = "failed"
        }
        return protocol.encode_report(token, node, st)
    }
    if v == "delegate" {
        // RECURSION, ASYNC: bringing a child up can take MINUTES on a cold guest
        // (podman install + image pull), which would starve this single-threaded
        // http handler and drop the parent's connection ("empty reply"). So FIRE
        // the child bring-up in the BACKGROUND and return `pending` immediately;
        // the parent polls `status <child>` until up/failed. (aeb-agent's
        // fire-async model.) File transport keeps the old synchronous path.
        println("aeo-agent[${me}]: delegate ${node} (async, backgrounded)")
        transport = config.get("aeo.agent.transport")
        if transport == "http" {
            _fire_child_async(token, node)
            return protocol.encode_report(token, node, "pending")
        }
        st = _delegate_child(token, node)      // file mode: synchronous (fast)
        return protocol.encode_report(token, node, st)
    }
    if v == "status" {
        // Report a child's current state WITHOUT blocking: just check its health.
        // The child's own /health IS the source of truth (up / not-yet).
        port = _env_or("AEO_PORT_${node}", "9451")
        st = "pending"
        if _child_health(port) == 1 {
            st = "up"
        }
        return protocol.encode_report(token, node, st)
    }
    if v == "attest" {
        // SELF-ATTESTATION (§5.4 of the paper consideration): re-verify, FROM
        // INSIDE the boundary, that this node's confinement still holds — the
        // orchestrator can't see in, the resident agent can. Reports "ok" or
        // "drift:<what>". Currently checks deny_egress (a node that must have no
        // egress must genuinely fail to reach out); more axes (image digest,
        // cgroup caps) slot in the same way. Best-effort, non-destructive.
        st = _self_attest()
        return protocol.encode_report(token, node, st)
    }
    if v == "probe" {
        alive = _probe_node(node)
        st = "down"
        if alive == 1 {
            st = "up"
        }
        return protocol.encode_report(token, node, st)
    }
    if v == "halt" {
        println("aeo-agent[${me}]: halt ${node}")
        _de = _down_node(node)
        return protocol.encode_report(token, node, "down")
    }
    println("aeo-agent[${me}]: unknown verb '${v}'")
    return ""
}

// Handle one command in FILE mode. Returns 1 to keep looping, 0 to stop (on a
// halt of the agent's OWN node). Wraps the shared dispatch + the outbox write.
_handle(me: string, token: string, outbox: string, line: string) -> int {
    rep = _dispatch_verb(me, token, line)
    if string_length(rep) > 0 {
        _ = put(outbox, _next(), rep)
    }
    // A halt of the agent's OWN node ends the agent (the report still went out).
    if protocol.verb_of(line) == "halt" {
        if protocol.arg1_of(line) == me {
            return 0
        }
    }
    return 1
}

// Bring a node up locally, INSIDE wherever this agent runs. v0 reads the
// node's image/command from env the parent stamped (AEO_<NODE>_IMAGE /
// _CMD); a richer agent will receive the full spec in the boot command.
//
// AEO_BOOT_NOOP=1 skips the driver and reports success — this lets the
// RECURSION logic (delegate -> boot-down -> report-up) be proven WITHOUT a
// container substrate (e.g. on a laptop with no podman). It isolates "the
// orchestration tree converges" from "a real container ran"; the substrate is
// tested separately, on a box that has one.
_boot_node(node: string) -> string {
    fail = _env_or("AEO_BOOT_FAIL", "")
    if string_length(fail) > 0 {
        // Forced failure for tests: return a distinct error so the child reports
        // "failed" and that detail propagates up through the tree. Proves the
        // body path carries real report detail (not just a 200/non-200 bit).
        println("aeo-agent: FORCED boot failure ${node} (AEO_BOOT_FAIL set)")
        return "forced-fail"
    }
    noop = _env_or("AEO_BOOT_NOOP", "")
    if string_length(noop) > 0 {
        println("aeo-agent: NOOP boot ${node} (AEO_BOOT_NOOP set)")
        return ""
    }
    img = _env_or("AEO_BOOT_IMAGE", "docker.io/library/busybox:latest")
    cmd = _env_or("AEO_BOOT_CMD", "sleep 600")
    // SUBSTRATE SELECTION: on Windows the workload is a Linux container run through
    // WSL2 (driver_windows: `wsl -d <distro> -- podman ...`); on Linux it's podman
    // directly (driver_linux). Same container semantics either way — the agent
    // just picks the arm that matches the host it was compiled for. platform() is
    // compile-time, so the Windows agent .exe takes the WSL arm with no runtime
    // branch cost. AEO_WSL_DISTRO selects the distro ("" = WSL's default distro).
    if _on_windows() == 1 {
        distro = _env_or("AEO_WSL_DISTRO", "Ubuntu")
        return driver_windows.up(node, distro, img, cmd, 0, "", "", "")
    }
    return driver_linux.up(node, img, cmd, 0, "")
}

// 1 if this agent runs on Windows (compile-time platform). The seam that routes
// child bring-up to driver_windows (podman-through-WSL2) instead of driver_linux.
_on_windows() -> int {
    if platform() == "windows" {
        return 1
    }
    return 0
}

// Leaf probe/down, substrate-selected like _boot_node so a node's whole lifecycle
// (boot/probe/halt) uses ONE arm. On Windows both go through driver_windows (WSL).
_probe_node(node: string) -> int {
    if _on_windows() == 1 {
        return driver_windows.probe(node, _env_or("AEO_WSL_DISTRO", "Ubuntu"), "")
    }
    return driver_linux.probe(node, "", "")
}
_down_node(node: string) -> string {
    if _on_windows() == 1 {
        return driver_windows.down(node, _env_or("AEO_WSL_DISTRO", "Ubuntu"))
    }
    return driver_linux.down(node, "")
}

// Hand a boot DOWN to the child's RESIDENT agent and relay its report UP. This
// is the whole of recursion: I message the child agent, I never reach THROUGH
// the child — the child boots its own node (and its own children) and reports
// back. Depth-agnostic, because the child runs this same code. The two
// transports differ only in HOW I reach the child; the protocol is identical.
_delegate_child(token: string, child: string) -> string {
    transport = config.get("aeo.agent.transport")
    if transport == "http" {
        return _delegate_child_http(token, child)
    }
    return _delegate_child_file(token, child)
}

// FILE: write a boot into the child's inbox, poll its outbox for the report.
_delegate_child_file(token: string, child: string) -> string {
    ensure_dirs(child)
    cin = inbox_dir(child)
    cout = outbox_dir(child)
    _ = put(cin, _next(), protocol.encode_boot(token, child))

    // Poll the child's outbox for ITS report about itself. Bounded so a dead
    // child can't hang the parent (same ~60s budget as the main loop).
    waits = 0
    while waits < 600 {
        line = recv_one(cout)
        if line != "" {
            v = protocol.verb_of(line)
            n = protocol.arg1_of(line)
            if v == "report" {
                if n == child {
                    return protocol.arg2_of(line)   // "up" / "failed" / "down"
                }
            }
            // an announce or an unrelated line: keep draining, don't count it
        } else {
            waits = waits + 1
            sleep(100)
        }
    }
    return "timeout"
}

// HTTP: I am the child's parent, so I act as the http CLIENT to the child's own
// listener. Per the addressing convention (docs/aeo-agent.md), the child's
// address is (its ipam IP) : (the port I stamped at bootstrap) — the contained
// never told me where it lives; I assigned it. In the real deployment the IP is
// the child's ipam address; in the localhost proof it's 127.0.0.1 and the port
// arrives as AEO_PORT_<child>. (Naming: grandparent=aeo host, parent=this agent,
// child=the node one boundary down — see test/agent-http-recursion.sh.)
//
// SERVE-AND-DIAL: this runs inside MY /dispatch handler (a server worker thread).
// I dial the child and read its REPORT LINE from the response body, so I relay the
// child's actual state up (up / failed / down), not just a boolean. Reading the
// body from an in-handler dial is safe as of aether v0.341.0 (fee8118: response
// body is an owned string; the earlier worker-thread UAF is fixed — see
// aether:http-response-body-uaf-priority-ask.md). Older toolchains need the
// status-only path (send_command_status); v0.341.0+ carries full report detail.
_delegate_child_http(token: string, child: string) -> string {
    // The child's port: assigned by me (the parent), per the addressing
    // convention. Couriered as AEO_PORT_<child> if the orchestrator stamped one,
    // else I assign the convention default (9451). The contained never chooses.
    port = _env_or("AEO_PORT_${child}", "9451")
    // RECURSION / bring-up: I START the child's container-agent inside me, THEN
    // dial it. "delegate" = bring up my child's subtree, not merely reach an
    // already-running one. Idempotent (skips if already listening).
    serr = _ensure_child_container(token, child, port)
    if string_length(serr) > 0 {
        println("aeo-agent: could not start child container ${child}: ${serr}")
        return "unreachable"
    }
    base = "http://127.0.0.1:${port}"
    rep = send_command(base, token, protocol.encode_boot(token, child))
    if string_length(rep) == 0 {
        return "unreachable"                 // transport error / non-200
    }
    if protocol.verb_of(rep) == "report" {
        if protocol.arg1_of(rep) == child {
            return protocol.arg2_of(rep)     // the child's real state: up/failed/down
        }
    }
    return "unreachable"                     // unexpected reply shape
}

// Start the child's container-agent inside this guest (podman): the SAME agent
// binary, in a glibc container, as node=<child> on <port>, with my token. I
// mount my own agent binary (/usr/local/bin/aeo-agent) into the container so no
// image bake is needed. Idempotent: if the child already answers /health, skip.
// Then wait (bounded) for it to listen. Returns "" on success, else an error.
// Self-attest this node's confinement FROM INSIDE. Returns "ok" if every checked
// axis still holds, else "drift:<axis>". Only the resident agent can do this —
// the orchestrator is outside the boundary. Non-destructive, best-effort.
//
// Axis 1 — deny_egress: when AEO_DENY_EGRESS=1 the node is supposed to have NO
// outbound network. So egress MUST fail; if we CAN reach the outside, confinement
// has drifted (the deny rule was removed/bypassed) — the exact thing an attacker
// who escaped netpolicy would enable. (When the var is unset, egress is allowed
// and this axis is trivially ok.) More axes (image digest via podman inspect,
// cgroup pids-limit via /sys/fs/cgroup) slot in the same shape.
_self_attest() -> string {
    deny = _env_or("AEO_DENY_EGRESS", "")
    if string_length(deny) > 0 {
        if _can_reach_out() == 1 {
            return "drift:deny_egress"       // could phone home but shouldn't
        }
    }
    return "ok"
}
// 1 iff this node can reach the outside network (a quick, bounded probe to a
// well-known host). Used ONLY to detect deny_egress drift (reachable == bad there).
// Portable probe: prefer `nc -z` (present on most guests); fall back to bash's
// /dev/tcp (dash lacks it — DON'T use plain sh for that). Non-destructive: a bare
// TCP connect to :53, no payload.
_can_reach_out() -> int {
    // IN-PROCESS TCP-connect probe via std.net — no shell-out, no `nc` dependency,
    // no seed provisioning gap (the resident deputy shouldn't rely on the guest's
    // toolage). tcp_connect_raw returns a socket ptr on connect, null (0) on any
    // failure. For a real deny_egress node the connect FAILS FAST (no route /
    // network-unreachable → immediate error), which is the whole point. Port 53
    // (DNS) is a benign well-known port; no payload is sent.
    tgt = _env_or("AEO_EGRESS_PROBE", "1.1.1.1")
    sock = tcp_connect_raw(tgt, 53)
    if sock == 0 {
        return 0                             // could not connect -> confined (ok)
    }
    tcp_close(sock)
    return 1                                 // connected -> egress reachable
}
// Fire the child bring-up in the BACKGROUND (detached), returning immediately so
// the http handler doesn't block. The detached shell: waits for podman, then
// `podman run`s the child (retrying through the transient post-install 125), then
// exits. The child's own /health becomes the readiness signal the parent polls
// via `status`. All the timing lives out here, off the request thread.
_fire_child_async(token: string, child: string) {
    port = _env_or("AEO_PORT_${child}", "9451")
    img = _env_or("AEO_CHILD_IMAGE", "docker.io/library/debian:stable-slim")
    abin = _env_or("AEO_AGENT_SELF", "/usr/local/bin/aeo-agent")
    log = "/tmp/aeo-child-${child}.log"
    // one self-contained bring-up script, backgrounded via setsid so it outlives
    // this handler. `until podman` covers the background install; the run retries
    // ride the just-installed 125 race.
    script = "echo start >> ${log}; i=0; until command -v podman >/dev/null 2>&1; do i=$((i+1)); [ $i -gt 600 ] && { echo no-podman >> ${log}; exit 1; }; sleep 1; done; echo podman-ready >> ${log}; t=0; while [ $t -lt 20 ]; do podman rm -f aeo-${child} >/dev/null 2>&1; if podman run -d --name aeo-${child} -p ${port}:${port} -v ${abin}:/aeo-agent:ro -e AEO_TRANSPORT=http -e AEO_PORT=${port} -e AEO_NODE=${child} -e AEO_TOKEN=${token} -e AEO_BIND=0.0.0.0 -e AEO_BOOT_NOOP=1 ${img} /aeo-agent >>${log} 2>&1; then echo run-ok >> ${log}; break; fi; t=$((t+1)); echo run-retry-$t >> ${log}; sleep 3; done"
    av = list_new()
    list_add(av, "-c")
    list_add(av, "setsid sh -c '${script}' </dev/null >>${log} 2>&1 &")
    o, s, e = run_capture("/bin/sh", av, null)
    list_free(av)
    _crumb(child, "fired async bring-up")
}
_ensure_child_container(token: string, child: string, port: string) -> string {
    _crumb(child, "enter port=${port}")
    // already up?
    if _child_health(port) == 1 {
        _crumb(child, "already up")
        return ""
    }
    // podman may still be installing (the seed installs it in the background so
    // it doesn't delay agent start) — wait for it before running the child.
    _crumb(child, "waiting for podman")
    if _wait_podman() == 0 {
        _crumb(child, "podman wait FAILED")
        return "podman not available in guest (install still running / failed)"
    }
    _crumb(child, "podman ready; running container")
    img = _env_or("AEO_CHILD_IMAGE", "docker.io/library/debian:stable-slim")
    abin = _env_or("AEO_AGENT_SELF", "/usr/local/bin/aeo-agent")
    run = "podman rm -f aeo-${child} >/dev/null 2>&1; podman run -d --name aeo-${child} -p ${port}:${port} -v ${abin}:/aeo-agent:ro -e AEO_TRANSPORT=http -e AEO_PORT=${port} -e AEO_NODE=${child} -e AEO_TOKEN=${token} -e AEO_BIND=0.0.0.0 -e AEO_BOOT_NOOP=1 ${img} /aeo-agent 2>&1"
    // Retry the run: a `podman run` fired the instant podman finished installing
    // hits a TRANSIENT init/lock error (exit 125 — storage db not ready / a
    // concurrent podman from the background install still holding a lock). A few
    // seconds later it succeeds. So retry a bounded number of times on failure.
    tries = 0
    s = 1
    o = ""
    while tries < 20 {
        av = list_new()
        list_add(av, "-c")
        list_add(av, run)
        o, s, e = run_capture("/bin/sh", av, null)
        list_free(av)
        if s == 0 {
            tries = 20
        } else {
            _crumb(child, "podman run try ${_itoa_a(tries)} status=${_itoa_a(s)} out=${o}")
            sleep(3000)
            tries = tries + 1
        }
    }
    _crumb(child, "podman run final status=${_itoa_a(s)} out=${o}")
    if s != 0 {
        return "podman run failed after retries: ${o}"
    }
    // Wait for it to listen. `podman run -d` returns before the image is pulled,
    // so on a COLD guest (no cached image) the first run pulls debian:stable-slim
    // over the guest's NAT (~30-60s) BEFORE the container's agent starts. 30s was
    // too short and the child came up "unreachable"; give the cold pull + start
    // real headroom (~3min).
    waits = 0
    while waits < 360 {
        if _child_health(port) == 1 {
            return ""
        }
        sleep(500)
        waits = waits + 1
    }
    return "child never listened on ${port}"
}
// Wait (bounded, ~5min) for podman to appear on PATH — the seed installs it in
// the BACKGROUND (so it doesn't delay agent start), and a cold apt-get install on
// a fresh guest genuinely takes ~2min. 90s was too short and lost the race, so
// the child came up "unreachable"; give apt real headroom. 1 if available.
_wait_podman() -> int {
    waits = 0
    while waits < 600 {
        av = list_new()
        list_add(av, "-c")
        list_add(av, "command -v podman >/dev/null 2>&1 && echo ok")
        o, s, e = run_capture("/bin/sh", av, null)
        list_free(av)
        if string_contains(o, "ok") == 1 {
            return 1
        }
        sleep(500)
        waits = waits + 1
    }
    return 0
}
// File breadcrumb (stdout capture from a worker-thread handler is unreliable, so
// log to a file directly for post-mortem). Best-effort.
_crumb(child: string, msg: string) {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "echo \"[$(date +%H:%M:%S)] ${msg}\" >> /tmp/aeo-child-${child}.log")
    o, s, e = run_capture("/bin/sh", av, null)
    list_free(av)
}
_itoa_a(n: int) -> string {
    if n == 0 { return "0" }
    v = n
    neg = 0
    if v < 0 { neg = 1 v = 0 - v }
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_da(d)}${s}"
        v = v / 10
    }
    if neg == 1 { return "-${s}" }
    return s
}
_da(x: int) -> string {
    if x == 0 { return "0" } if x == 1 { return "1" } if x == 2 { return "2" }
    if x == 3 { return "3" } if x == 4 { return "4" } if x == 5 { return "5" }
    if x == 6 { return "6" } if x == 7 { return "7" } if x == 8 { return "8" }
    return "9"
}
_child_health(port: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "curl -fsS --max-time 2 http://127.0.0.1:${port}/health >/dev/null 2>&1 && echo ok")
    o, s, e = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(o, "ok") == 1 {
        return 1
    }
    return 0
}

// os.getenv returns NULL (not "") when unset, and null != "" — so guard on
// length and fall back to `def`. (The unset-env footgun.)
_env_or(name: string, def: string) -> string {
    v = os.getenv(name)
    if string_length(v) == 0 {
        return def
    }
    return v
}

// --- monotonic seq for outbox filenames (counter in a config-KV cell;
// Aether has no top-level mutable global) ---
_next() -> int {
    v = config.get("aeo.agent.seq")
    n = 0
    if string_length(v) > 0 {
        n = _atoi(v)
    }
    n = n + 1
    config.put("aeo.agent.seq", _itoa_seq(n))
    return n
}

_mask(t: string) -> string {
    if string_length(t) == 0 {
        return "<none>"
    }
    return "***"
}

_atoi(s: string) -> int {
    n = string_length(s)
    acc = 0
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c >= 48 {
            if c <= 57 {
                acc = acc * 10 + (c - 48)
            }
        }
        i = i + 1
    }
    return acc
}
// int->string. NOT named `_itoa`: that's a reserved MSVCRT name (stdlib.h
// declares `_itoa`), and the entry program emits its top-level functions
// UNPREFIXED at C file scope, so `_itoa` there collides with the CRT on a
// native Windows build. Library modules are namespaced (driver_linux__itoa &c)
// so they don't clash; only the program's own top-level names must avoid the
// reserved set. (_itoa_a below is fine — not a reserved name.)
_itoa_seq(n: int) -> string {
    if n == 0 {
        return "0"
    }
    v = n
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_d(d)}${s}"
        v = v / 10
    }
    return s
}
_d(x: int) -> string {
    if x == 0 { return "0" }
    if x == 1 { return "1" }
    if x == 2 { return "2" }
    if x == 3 { return "3" }
    if x == 4 { return "4" }
    if x == 5 { return "5" }
    if x == 6 { return "6" }
    if x == 7 { return "7" }
    if x == 8 { return "8" }
    return "9"
}
