# Aether / aeb build artifacts
/target/
/build/
# built binaries (emitted at repo root by `ae build bin/<name>.ae`)
/aeo
/aeo-agent
# load-balancer front-door binaries baked beside their .ae source by the
# examples-suite (test/examples-suite.sh) — compiled artifacts, not source.
/bin/aeo-lb
/bin/aeo-l4lb
*.o
*.d
*.gcda
*.gcno
*.gcov

# Generated C from .ae compilation
*.ae.c

# Lazy-built tool binaries (cached, gitignored — like aeb/tools/*)
/tools/aeo-main
/tools/aeo-link
/tools/*[!.ae]
# ...but tools/ SOURCE scripts are tracked (the [!.ae] glob above targets binaries).
!/tools/*.sh
!/tools/*.md

# aeb per-project SDK symlinks (consumer-side)
/.aeb/lib/*

# Local scratch
/tmp/
*.swp

# Aether LSP server log (per-dev tooling artifact)
aether-lsp.log

# iterative-dev sticky IP bindings (lib/ipam) — per-dev, not committed
.aeo/
