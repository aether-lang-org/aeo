// lib/aeo/runner.ae — the fixed aeo runner (the single compilation unit).
//
// Owns the generic resource ACTOR and the bring-up/teardown ENGINE (main),
// both of which must live in the unit with `main` because Aether actors
// are single-compilation-unit (they don't cross `import`). Drivers, host
// probe, the compose declaration DSL, and the state bridge are imported.
//
// The only per-composition variation is the operator's resource
// declaration, which is data (compose-DSL setters → std.config). So this
// runner is FIXED; the `aeo` front-door assembles a build dir (lib/ + this
// runner copied to a top-level run.ae + the operator's compose.ae as the
// `aeo_compose` module) and `ae build`s it. See bin/aeo and
// memory aeo-frontdoor-codegen for the build-layout rules.
//
// Bring-up: declaration order, each resource gated on liveness, a resource
// whose depends() target isn't up yet deferred to a later pass (converges
// for any DAG depth ≤ N). Teardown: reverse boot order. Subcommand from
// AEO_CMD env (the front-door sets it): up (default) / down / status.

import std.config
import std.string (string_length, string_substring, string_index_of, string_char_at, string_from_char, string_starts_with)
import std.list
import driver_linux
import driver_lxc
import driver_bsd
import driver_vm
import driver_bwrap
import driver_nspawn
import driver_firecracker
import driver_kata
import driver_windows
import driver_wslc
import driver_loadbalancer
import driver_proxmox
import death
import compose
import ipam
import pf
import rctl
import snapshot
import snapshot_linux
import confine_linux
import reconcile
import extract
import transport_http (post_path, probe_health)
import attest
import audit
import secrets
import std.intarr
import resource (set_state, get_state, STATE_DOWN, STATE_BOOTING, STATE_UP, STATE_FAILED)
import host (family, profile)
import aeo_compose (aeo_orchestration)

// `aeo_compose` is the operator's composition module. The `aeo` front-door
// installs the operator's compose.ae as that module; it must define
// `aeo_orchestration()` — the entry that declares one or more
// `system("name") { … }` blocks. For a self-contained build, build with
// `--lib <dir-with-aeo_compose>`; examples/ provide one.

// ---- messages ----
// Configure sets the actor's identity (name + kind) once at spawn; Boot
// and Halt then carry no payload — the actor reads nm/kind from its own
// state. (The earlier in_name-on-every-message threading was a workaround
// for an actor-state string-corruption bug fixed in ae 0.295; aeo now
// requires >= 0.295, so the actor holds real string state.)
message Configure { in_name: string, in_kind: string }
message Boot {}
message Halt {}

// ---- the generic resource actor ----
// One actor per declared resource. Holds its own identity (nm/kind) as
// state, set once via Configure. Per-resource declaration details
// (image/health/command/…) are read from the operator's compose data via
// compose.get_*(nm) — that's the declaration source of truth, not actor
// state. The main composition observes progress through the std.config
// state bridge (set_state/get_state), since main can't await an actor
// reply directly.
actor Resource {
    state nm = ""
    state kind = ""

    receive {
        Configure(in_name, in_kind) -> {
            nm = in_name
            kind = in_kind
            set_state(nm, STATE_DOWN())
        }
        Boot -> {
            set_state(nm, STATE_BOOTING())
            err = driver_up(nm, kind)
            if err != "" {
                println("aeo: [${nm}] up failed: ${err}")
                set_state(nm, STATE_FAILED())
            }
            // Readiness is polled by the ENGINE (run_up's single per-level poller),
            // NOT blocked-on here: a per-actor health poll would serialize a whole
            // level (the runtime serializes blocking ops inside actors), defeating
            // the point of dispatching detached boots concurrently. On up() success
            // the node stays BOOTING; the engine promotes it to UP once health passes.
        }
        Halt -> {
            err = driver_down(nm, kind)
            if err != "" {
                println("aeo: [${nm}] down failed: ${err}")
            }
            set_state(nm, STATE_DOWN())
        }
    }
}

// _await_level — the ENGINE-side, SINGLE-THREADED readiness poller for one
// topological level. Every node in `booted` has already had its (detached) boot
// dispatched by its actor; this loop probes them ALL each tick and promotes each
// to UP as its health passes — so their readiness overlaps at the OS level
// instead of one blocking poll per actor (which the runtime would serialize).
// Returns 1 once every node is UP, 0 if any FAILED or the level times out.
//
// The level's time budget is the MAX of its nodes' own health windows
// (get_budget×get_interval — the within()/every() config), never shorter than
// `min_secs`, so a slow VM configured for a long boot still gets its full window
// under the level poller. The tick is the fastest node's interval (floored), so
// no node is probed slower than it asked. A node whose driver_up() errored is
// already FAILED (set by the actor) and aborts the level.
_await_level(booted: ptr, min_secs: int) -> int {
    m = list_size(booted)
    tick = _level_tick(booted)
    budget = _level_budget_ms(booted, min_secs)
    waited = 0
    while waited < budget {
        // BATCHED liveness: for nodes whose readiness IS liveness (no health()) and
        // whose liveness source is RELIABLE — pidfile kinds (a local `kill -0`) and
        // container/docker (a rootless `podman/docker ps`) — check the whole level
        // in O(1) queries per tick instead of O(N). A space-padded " a b c "
        // membership string; every other node (health-checked, or a sudo-gated
        // nspawn/lxc/jail where a false "down" could hang) falls to the per-node
        // probe below. See _alive_set.
        alive = _alive_set(booted)
        allup = 1
        i = 0
        while i < m {
            bn = list_get_raw(booted, i)
            st = get_state(bn)
            if st == STATE_FAILED() {
                return 0
            }
            if st != STATE_UP() {
                promoted = 0
                if st == STATE_BOOTING() {
                    ready = 0
                    if _batchable(bn) == 1 {
                        if string_index_of(alive, " ${bn} ") >= 0 {
                            ready = 1
                        }
                    } else {
                        if driver_probe(bn, compose.get_kind(bn), compose.get_health(bn)) == 1 {
                            ready = 1
                        }
                    }
                    if ready == 1 {
                        set_state(bn, STATE_UP())
                        println("aeo: [${bn}] up")
                        _enforce_netpolicy(bn)
                        _enforce_limits(bn)
                        _surface_lb_weight_ignored(bn)
                        promoted = 1
                    }
                }
                if promoted == 0 {
                    allup = 0
                }
            }
            i = i + 1
        }
        if allup == 1 {
            return 1
        }
        sleep(tick)
        waited = waited + tick
    }
    // TIMEOUT/FAIL: surface WHICH nodes weren't UP + their last state, so a stuck
    // bring-up isn't a silent "bring-up failed". (Diagnostic — cheap, once per level.)
    _diag_level_not_up(booted, budget)
    return 0
}

// The node's share() mounts for driver dispatch — and the AUDIT record: a
// share is a filesystem pinhole through the boundary (the publish()/gpu()
// class of capability grant), so every granted mount goes on the hash chain.
// Newlines flattened to "; " (an audit entry is one line).
_shares_of(nm: string) -> string {
    sh = compose.get_shares(nm)
    if string_length(sh) > 0 {
        flat = ""
        rest = sh
        more = 1
        while more == 1 {
            nl = string_index_of(rest, "\n")
            one = rest
            if nl >= 0 {
                one = string_substring(rest, 0, nl)
                rest = string_substring(rest, nl + 1, string_length(rest))
            } else {
                more = 0
            }
            if string_length(flat) == 0 {
                flat = one
            } else {
                flat = "${flat}; ${one}"
            }
        }
        _ = audit.record(nm, compose.get_kind(nm), "share", flat)
    }
    return sh
}

// Print each non-UP node in a timed-out level + its state (diagnostic). For
// engine containers, also ask the KERNEL why: an exited container's post-mortem
// (OOM kill / fatal signal / exit code) turns "not up within window" into an
// actionable verdict — and goes on the audit chain (forensics, like attest-refuse).
_diag_level_not_up(booted: ptr, budget: int) {
    m = list_size(booted)
    i = 0
    while i < m {
        bn = list_get_raw(booted, i)
        st = get_state(bn)
        if st != STATE_UP() {
            sn = "?"
            if st == STATE_FAILED() { sn = "FAILED" }
            if st == STATE_BOOTING() { sn = "BOOTING (never became ready in ${string_from_int(budget)}ms)" }
            if st == STATE_DOWN() { sn = "DOWN" }
            // per-substrate post-mortem: each driver's death_state returns the
            // canonical status|oom|exit line; lib/death classifies it. Absent
            // node / remote engine / no verdict -> "" and the plain line below.
            verdict = ""
            k = compose.get_kind(bn)
            if k == "container" {
                eng = compose.get_engine(bn)
                dhost = compose.get_host(bn)
                dhk = ""
                if string_length(dhost) > 0 { dhk = compose.get_kind(dhost) }
                if eng == "wslc" {
                    verdict = death.death_cause(driver_wslc.death_state(bn))
                } else {
                if eng == "wsl_podman" {
                    verdict = death.death_cause(driver_windows.death_state(bn, compose.get_wsl_distro(bn)))
                } else {
                    if dhk == "proxmox_vm" {
                        // nested in a REMOTE guest: the guest's resident agent
                        // runs the inspect (the same conduit probe uses — a
                        // host engine or ssh can't be assumed to reach in).
                        dgip = driver_proxmox.guest_ip(dhost)
                        if string_length(dgip) > 0 {
                            dtok = _agent_token(dhost)
                            if string_length(dtok) == 0 { dtok = "aeo-dev-token" }
                            dbase = "http://${dgip}:${string_from_int(_agent_port(dhost))}"
                            verdict = death.death_cause(driver_vm.agent_death_at(dbase, bn, dtok))
                        }
                    } else {
                    if dhk == "kvm" {
                        // nested in a LOCAL VM guest: the engine inspect runs
                        // in-guest over the exec seam (resolved IP + guest key).
                        dhip = ipam.resolve_ip(compose.get_system(dhost), dhost)
                        verdict = death.death_cause(driver_vm.guest_death_state(dhost, dhip, bn))
                    } else {
                        if dhk == "bhyve" {
                            dhip = ipam.resolve_ip(compose.get_system(dhost), dhost)
                            verdict = death.death_cause(driver_vm.guest_death_state(dhost, dhip, bn))
                        } else {
                            verdict = death.death_cause(driver_linux.death_state(bn, eng))
                        }
                    }
                    }
                }
                }
            }
            if k == "nspawn" {
                verdict = death.death_cause(driver_nspawn.death_state(bn))
            }
            if k == "firecracker" {
                verdict = death.death_cause(driver_firecracker.death_state(bn))
            }
            if k == "kvm" {
                verdict = death.death_cause(driver_vm.death_state(bn))
            }
            if k == "bhyve" {
                verdict = death.death_cause(driver_vm.bhyve_death_state(bn))
            }
            if k == "bwrap" {
                verdict = death.death_cause(driver_bwrap.death_state(bn))
            }
            if k == "lxc" {
                verdict = death.death_cause(driver_lxc.death_state(bn))
            }
            if k == "proxmox_vm" {
                verdict = death.death_cause(driver_proxmox.death_state(bn))
            }
            if k == "proxmox_ct" {
                verdict = death.death_cause(driver_proxmox.death_state(bn))
            }
            if string_length(verdict) > 0 {
                println("aeo: [${bn}] NOT UP at level timeout — state=${sn}; kernel verdict: ${verdict}")
                _ = audit.record(bn, k, "death", verdict)
            } else {
                println("aeo: [${bn}] NOT UP at level timeout — state=${sn}")
            }
        }
        i = i + 1
    }
}

// 1 if `nm`'s readiness can be batch-checked from a RELIABLE liveness source with
// NO health() command (so "process alive" == "ready"): a pidfile-tracked kind
// (bwrap/firecracker/kvm — local `kill -0`) or container/docker (rootless
// `podman/docker ps`). Health-checked nodes, and sudo-gated kinds (nspawn/lxc)
// where a false "down" from a denied sudo could HANG bring-up, are NOT batchable
// and take the per-node probe path.
_batchable(nm: string) -> int {
    if string_length(compose.get_health(nm)) > 0 {
        return 0
    }
    k = compose.get_kind(nm)
    if _pidfile_of(nm, k) != "" {
        return 1
    }
    if k == "container" {
        // container liveness = a host `podman/docker ps` — batchable. EXCEPT the
        // WSL engines (wslc/wsl_podman), whose ps is a remote `wsl -d ...` call,
        // NOT the local host engine — those take the per-node probe path.
        eng = compose.get_engine(nm)
        if eng == "wslc" {
            return 0
        }
        if eng == "wsl_podman" {
            return 0
        }
        // A container NESTED in a REMOTE proxmox_vm runs inside the guest — a host
        // `podman ps` can't see it. Its liveness is the guest agent's `status`
        // (driver_probe -> agent_status_at), so it is NOT batchable.
        chost = compose.get_host(nm)
        if string_length(chost) > 0 {
            if compose.get_kind(chost) == "proxmox_vm" {
                return 0
            }
        }
        return 1
    }
    return 0
}

// _alive_set — the space-padded " name ... " membership string of every batchable
// BOOTING node currently alive, gathered in O(1) queries per tick: one local
// pidfile sweep, plus one `ps` per container/docker engine present in the level.
// The engine's readiness fast-path (see _await_level).
_alive_set(booted: ptr) -> string {
    s = " ${_batch_pidfile_alive(booted)} "
    // `container` nodes are batched per ENGINE (podman/docker are separate `ps`
    // planes; a level can hold both). Query each engine present among batchable
    // containers. (wslc/wsl_podman aren't batchable — see _batchable — so they
    // never reach here.) The call is hoisted to a local BEFORE interpolation: a
    // string literal nested in ${...} inside "..." mis-parses (E0300).
    if _level_has_engine(booted, "") == 1 {
        names = driver_linux.running_names("")            // podman (auto)
        s = "${s}${_nl2sp(names)} "
    }
    if _level_has_engine(booted, "docker") == 1 {
        names = driver_linux.running_names("docker")
        s = "${s}${_nl2sp(names)} "
    }
    return s
}
// 1 if the level has a BOOTING, health-less `container` node resolving to `eng`
// (""=podman/auto, "docker"). The batch-liveness engine partition (replaces the
// old kind-keyed _level_has_batch_kind for containers, now that docker is an
// engine not a kind). WSL engines are skipped — not host-ps batchable.
_level_has_engine(booted: ptr, eng: string) -> int {
    m = list_size(booted)
    i = 0
    while i < m {
        bn = list_get_raw(booted, i)
        if get_state(bn) == STATE_BOOTING() {
            if compose.get_kind(bn) == "container" {
                if string_length(compose.get_health(bn)) == 0 {
                    ne = compose.get_engine(bn)
                    if ne != "wslc" {
                        if ne != "wsl_podman" {
                            if ne == eng {
                                return 1
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return 0
}


// Replace every newline in `s` with a space (so a multi-line `ps` name list joins
// into the single space-delimited membership string).
_nl2sp(s: string) -> string {
    out = ""
    n = string_length(s)
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c == 10 {
            out = "${out} "
        } else {
            out = "${out}${string_from_char(c)}"
        }
        i = i + 1
    }
    return out
}

// The pidfile path for a pidfile-tracked kind, else "" (via each driver's own
// exported pidfile_for — no scheme is duplicated here).
_pidfile_of(nm: string, kind: string) -> string {
    if kind == "bwrap" {
        return driver_bwrap.pidfile_for(nm)
    }
    // NB: firecracker is NOT here — it now launches via `systemd-run --user` (for
    // SIGHUP-survival) and writes NO pidfile, so it can't be batch-swept by
    // pidfile. Its per-node probe() checks `systemctl --user is-active` instead.
    // (The non-systemd fallback writes a pidfile, but per-node probe reads it too,
    // so firecracker always takes the per-node path — correct, just not batched.)
    if kind == "kvm" {
        return driver_vm.pidfile_for(nm)
    }
    return ""
}

// One shell sweep over every batchable BOOTING node: for each `name|pidfile`
// pair, print the name iff the pidfile holds a live pid (`kill -0`). Returns the
// space-prefixed list of alive names (e.g. " db app"), or "" if none batchable.
// Replaces N×(cat+kill) per tick with a single run_capture.
_batch_pidfile_alive(booted: ptr) -> string {
    pairs = ""
    m = list_size(booted)
    i = 0
    while i < m {
        bn = list_get_raw(booted, i)
        if get_state(bn) == STATE_BOOTING() {
            if _batchable(bn) == 1 {
                pf = _pidfile_of(bn, compose.get_kind(bn))
                pairs = "${pairs} \"${bn}|${pf}\""
            }
        }
        i = i + 1
    }
    if string_length(pairs) == 0 {
        return ""
    }
    // `read`/`kill -0`/`[` are all shell BUILTINS — the whole sweep runs in the
    // one sh with ZERO child processes (vs 2N cat+kill spawns the per-node path
    // would make), on top of collapsing 2N Aether run_captures into 1.
    cmd = "for pair in${pairs}; do n=\"\${pair%%|*}\"; pf=\"\${pair#*|}\"; if [ -f \"\$pf\" ]; then read pid < \"\$pf\" 2>/dev/null; kill -0 \"\$pid\" 2>/dev/null && printf ' %s' \"\$n\"; fi; done"
    av = list_new()
    list_add(av, "-c")
    list_add(av, cmd)
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    return out
}

// The level's total wait budget (ms): the longest per-node health window
// (get_budget attempts × get_interval ms — the within()/every() config). The
// `min_secs` floor protects DEFAULT-window nodes only (a slow VM with no
// declared window still gets a real budget under the level poller); a level
// where EVERY node states its own within()/up_within() is the operator's
// explicit budget and is honoured as-is — shorter or longer — so a
// dead-on-arrival node under within(10s) reports in 10s, not 2 minutes.
_level_budget_ms(booted: ptr, min_secs: int) -> int {
    best = 0
    all_explicit = 1
    m = list_size(booted)
    i = 0
    while i < m {
        bn = list_get_raw(booted, i)
        if compose.get_within_ms(bn) <= 0 {
            all_explicit = 0
        }
        w = _node_window_ms(bn)
        if w > best {
            best = w
        }
        i = i + 1
    }
    if all_explicit == 1 {
        if m > 0 {
            return best
        }
    }
    fl = min_secs * 1000
    if best < fl {
        return fl
    }
    return best
}
_node_window_ms(nm: string) -> int {
    // An explicit within()/up_within() is the operator's stated bring-up budget —
    // honour it directly (it's a duration in ms). This matters for slow bring-ups
    // like a nested container in a REMOTE proxmox guest (cold podman + image pull +
    // recursive agent), where the health-retry default (interval×budget = 120s) is
    // far too short and the node would be spuriously torn down mid-bring-up.
    wm = compose.get_within_ms(nm)
    if wm > 0 {
        return wm
    }
    iv = compose.get_interval(nm)
    if iv <= 0 {
        iv = 500
    }
    bg = compose.get_budget(nm)
    if bg <= 0 {
        bg = 240
    }
    return iv * bg
}

// The poll tick (ms): the FASTEST node's interval (so no node is probed slower
// than it asked), floored at 250ms to bound probe overhead.
_level_tick(booted: ptr) -> int {
    best = 0
    m = list_size(booted)
    i = 0
    while i < m {
        bn = list_get_raw(booted, i)
        iv = compose.get_interval(bn)
        if iv <= 0 {
            iv = 500
        }
        if best == 0 {
            best = iv
        } else {
            if iv < best {
                best = iv
            }
        }
        i = i + 1
    }
    if best < 250 {
        best = 250
    }
    return best
}

// Resolve the image a container resource runs: if it has an inline
// dockerfile(), build that and use the built tag; otherwise use image().
// Returns (image_or_tag, build_err). build_err "" means ok.
_container_image(nm: string, engine_pref: string) -> string {
    // Three shapes, same precedence as the VM-nested path (guest_container_up):
    //   entrypoint() — synthesize a COPY-based image from the Python source.
    //   dockerfile() — build the operator's inline Dockerfile.
    //   image()      — a stock image ref, run as-is.
    ep = compose.get_entrypoint(nm)
    if ep != "" {
        eerr = driver_linux.build_entrypoint(nm, ep, compose.get_base(nm), engine_pref)
        if eerr != "" {
            return "ERR:${eerr}"
        }
        return driver_linux.built_tag(nm)
    }
    df = compose.get_dockerfile(nm)
    if df == "" {
        return compose.get_image(nm)
    }
    berr = driver_linux.build(nm, df, engine_pref)
    if berr != "" {
        // Signal the failure by returning the error text prefixed; driver_up
        // checks for it. (Single-return constraint — no tuple literal.)
        return "ERR:${berr}"
    }
    return driver_linux.built_tag(nm)
}

// --- image realization (the recipe executor) -------------------------------
// Given a VM's logical guest_image (e.g. "ubuntu-22.04+podman"), resolve its
// image_recipe and return the FAST-PATH realize target — the snapshot to clone
// if it exists, parsed from realize_as("clone:<snap>"). "" if no recipe / no
// clone hint (then the driver full-provisions). The runner is the bridge: it
// imports both compose (recipe getters) and driver_vm (realization).
_realize_target(img: string) -> string {
    spec = compose.get_img_realize(img)
    // spec looks like "clone:aeo-base@golden"
    if string_index_of(spec, "clone:") == 0 {
        return string_substring(spec, 6, string_length(spec))
    }
    return ""
}

// Render the shell that writes + enables the recipe's systemd units inside the
// guest (each as /etc/systemd/system/<name>.service), for the cold-path build.
// Returns "" if the recipe declares no units.
_render_unit_writes(img: string) -> string {
    units = compose.get_img_units(img)   // "aeo-linkup, other"
    if string_length(units) == 0 {
        return ""
    }
    // single-unit common case (the recipe today has one); split on ", " for more.
    sh = ""
    name = _first_csv(units)
    body = compose.get_img_unit_body(img, name)
    if string_length(body) > 0 {
        sh = "cat <<'AEOUNIT' | sudo tee /etc/systemd/system/${name}.service >/dev/null\n${body}\nAEOUNIT\nsudo systemctl enable ${name}.service"
    }
    return sh
}

_first_csv(csv: string) -> string {
    p = string_index_of(csv, ",")
    if p < 0 {
        return csv
    }
    return string_substring(csv, 0, p)
}

// The shell that BUILDS the image from its recipe when the realize target is
// absent (fresh host / cold cache): fetch from(), provision, then install
// packages + write the static netplan + install the systemd units inside the
// guest, and finally snapshot it as the realize target so future clones are
// fast. Returns "" if there's no recipe (driver falls back to plain provision).
// NOTE: this returns the DECLARATIVE build plan as a newline-joined script the
// driver runs; aeo's existing setup scripts are the imperative ancestor.
_realize_build_steps(img: string) -> string {
    frm = compose.get_img_from(img)
    if string_length(frm) == 0 {
        return ""
    }
    steps = "from=${frm}"
    ins = compose.get_img_install(img)
    if string_length(ins) > 0 {
        steps = "${steps}\ninstall=${ins}"
    }
    np = compose.get_img_netplan(img)
    if string_length(np) > 0 {
        steps = "${steps}\nnetplan=${np}"
    }
    units = compose.get_img_units(img)
    if string_length(units) > 0 {
        steps = "${steps}\nunits=${units}"
    }
    return steps
}

// ---- driver dispatch by kind (exported; pure routing) ----
driver_up(nm: string, k: string) -> string {
    if k == "load_balancer" {
        // The L7 balancer front-door (docs §9 step 2): render the pool from this
        // node's children and background aeo-lb. The backends themselves are
        // ordinary container nodes booted by their own actors (they live INSIDE
        // this LB via get_host==nm, so they're on the internal net, not published).
        return driver_loadbalancer.up(nm)
    }
    if k == "lxc" {
        // REAL LXC system container (driver_lxc), not podman. image() is the
        // download-template "dist:release" (e.g. "alpine:3.21").
        return driver_lxc.up(nm, compose.get_image(nm), _shares_of(nm))
    }
    if k == "container" {
        // ENGINE DISPATCH: `container` is the one OCI kind; get_engine(nm) picks
        // the realizer (podman/docker auto per host, or wslc/wsl_podman on
        // Windows). The Windows engines run through their own drivers (WSL owns
        // its networking; no host podman nets) — route them FIRST, before the
        // Linux podman-network + confine path below. podman/docker/"" fall
        // through to the Linux path, with the engine passed to engine_resolve.
        eng = compose.get_engine(nm)
        if eng == "wslc" {
            // Microsoft's native wslc.exe — no podman, no distro. (Confine
            // rendering onto wslc's governance knobs is a follow-up.)
            imgw = _container_image(nm, "")
            if string_starts_err(imgw) == 1 {
                return _strip_err(imgw)
            }
            return driver_wslc.up(nm, imgw, compose.get_command(nm), compose.get_expose(nm), compose.get_env(nm))
        }
        if eng == "wsl_podman" {
            // podman INSIDE a WSL2 distro: `wsl -d <distro> -- podman ...`.
            // wsl_distro() selects the distro ("" = WSL default).
            imgd = _container_image(nm, "")
            if string_starts_err(imgd) == 1 {
                return _strip_err(imgd)
            }
            confinew = _confine_flags(nm, "", "")
            if string_length(confinew) > 0 {
                _ = audit.record(nm, k, "confine", confinew)
            }
            return driver_windows.up(nm, compose.get_wsl_distro(nm), imgd, compose.get_command(nm), compose.get_expose(nm), "", compose.get_env(nm), confinew)
        }
        // NESTED container: if it lives INSIDE a VM (get_host != ""), aeo
        // reaches into that guest over ssh and builds+runs it THERE — the
        // real nested-execution path that makes `aeo up <dsl>` converge to a
        // host-reachable service in the guest (not a host-local podman run).
        host = compose.get_host(nm)
        // A load_balancer BACKEND has host == the LB node (a container, not a VM).
        // It deploys as an ordinary HOST container on the internal net — reachable
        // by the LB by name — NOT nested-in-a-guest. Only a VM/guest host takes the
        // ssh/agent nested path below.
        if host != "" {
            if compose.is_load_balancer(host) == 1 {
                host = ""
            }
        }
        if host != "" {
            // REMOTE PROXMOX guest: a container nested inside a proxmox_vm is run by
            // the guest's RESIDENT aeo-agent (deployed via cloud_init()+agent()) —
            // aeo can't ssh/ipam a PVE guest (it's on the remote bridge). Resolve the
            // guest's LAN IP via the PVE guest-agent and delegate DIRECTLY to
            // <guest-ip>:9450 (no hostfwd). This is the doer path, in the nested-
            // container grammar (mirrors kvm_podman/bhyve_podman). See
            // examples/silly_addition_proxmox_podman.ae.
            if compose.get_kind(host) == "proxmox_vm" {
                // WAIT for the guest IP: the container-delegate fires right after the
                // VM's up() returns, but the guest-agent (and its DHCP IP) only comes
                // up ~45-90s into cloud-init. Poll guest_ip bounded (~4min) rather
                // than failing on the first empty result.
                gip = _wait_guest_ip(host, 80)     // 80 * 3s = 240s
                if string_length(gip) == 0 {
                    return "aeo: nested '${nm}' — proxmox_vm '${host}' guest IP never resolved (guest-agent not up after ~4min? check agent(1) + the cloud_init snippet)"
                }
                gport = _agent_port(host)          // 9450 by default (the guest agent's bind)
                // The token MUST match what the doer cloud-init seeded into the guest
                // agent. _agent_token reads AEO_TOKEN[_<host>] (empty by default ->
                // agent rejects "unauthorized"). For proxmox default to the doer
                // snippet's dev token when unset. PROD: seed a per-node sealed token
                // (the deferred identity/token gap) and set AEO_TOKEN_<host>.
                gtok = _agent_token(host)
                if string_length(gtok) == 0 { gtok = "aeo-dev-token" }
                base = "http://${gip}:${string_from_int(gport)}"
                // FIRE-AND-RETURN: accept the delegate, then let the engine poll
                // readiness via probe (agent_status_at — the nested-in-proxmox
                // container is NON-batchable, so the engine uses the guest agent's
                // `status`, not a host-local podman ps). A blocking up() would
                // outlive the level poller and trigger a spurious teardown.
                return driver_vm.agent_delegate_fire(base, host, nm, gtok)
            }
            // AGENT PATH (containment-correct): when enabled, aeo does NOT reach
            // into the guest over ssh — it sends a `delegate` to the guest's
            // RESIDENT aeo-agent, which runs the child locally and reports back.
            // Opt-in via AEO_AGENT_PATH=1 while the boot-side bake/courier is
            // productized; the ssh path below stays the default until then.
            // Proven on real KVM: test/real-nested-vm-container.sh.
            if _agent_path_on() == 1 {
                tok = _agent_token(host)
                prt = _agent_port(host)
                return driver_vm.agent_delegate(host, nm, tok, prt)
            }
            // the host VM's ipam-resolved IP (same binding bhyve_up used) — so
            // the container path ssh's to the right guest, not a hardcoded .50.
            hip = ipam.resolve_ip(compose.get_system(host), host)
            return driver_vm.guest_container_up(host, hip, nm, compose.get_dockerfile(nm), compose.get_entrypoint(nm), compose.get_base(nm), compose.get_image(nm), compose.get_expose(nm))
        }
        img = _container_image(nm, "")
        if string_starts_err(img) == 1 {
            return _strip_err(img)
        }
        // ATTESTATION (supply-chain gate): if attest("sha256:...") is pinned,
        // verify the image's ACTUAL digest BEFORE boot and REFUSE on mismatch
        // (fail-closed). Then run image@<digest> so podman enforces the pin too.
        pin = compose.get_attest(nm)
        if attest.is_attested(pin) == 1 {
            averr = attest.verify(img, pin)
            if averr != "" {
                _ = audit.record(nm, k, "attest-refuse", pin)   // FORENSICS: a refused boot
                return averr                       // refuse to boot — loud
            }
            _ = audit.record(nm, k, "attest-pass", pin)
            img = attest.pinned_ref(img, pin)      // run-by-digest
        }
        // HOST container networks: a SHARED net (intra + external egress) and an
        // INTERNAL net (intra only — no host/internet, the per-flow netpolicy
        // "internal" tier). Peers resolve each other BY NAME on either. env()
        // pairs (e.g. REDIS_HOST=db) reach the dependency's container.
        net = "aeo-${compose.get_system(nm)}"
        inet = "aeo-${compose.get_system(nm)}-int"
        _ne = driver_linux.network_ensure(net, "")
        _nei = driver_linux.network_ensure_internal(inet, "")
        // CONFINEMENT (the Linux peer of rctl/Capsicum/pf): render limit{} caps,
        // constrain{} hardening, and netpolicy to podman flags via confine_linux,
        // so a composition's confinement is substrate-portable. A node with
        // peer-only egress lands on the internal net (can't phone home).
        confine = _confine_flags(nm, net, inet)
        // GPU (§G): a gpu("shared") claim renders to a --device token, spliced into
        // the SAME argv path as confine. exclusive/VM claims never reach here
        // (refused at check). We PROBE the host for a CDI spec first: if present we
        // render the structured CDI selector (--device intel.com/gpu=all — the full
        // card+render+by-path bundle), else fall back to the raw DRI render node.
        // Both proven live on the N100; --gpus is NOT used (it fails on Intel).
        cdidev = ""
        if string_length(compose.get_gpu_mode(nm)) > 0 {
            cdidev = _gpu_cdi_device(nm)
        }
        gflags = compose.gpu_flags(nm, k, eng, cdidev)
        if string_length(gflags) > 0 {
            if string_length(confine) > 0 {
                confine = "${confine} ${gflags}"
            } else {
                confine = gflags
            }
            _ = audit.record(nm, k, "gpu", gflags)
        }
        // FORENSICS: record the posture this node booted WITH (the audit trail —
        // what was confined/attested is then provable after the fact).
        if string_length(confine) > 0 {
            _ = audit.record(nm, k, "confine", confine)
        }
        // engine_pref = the resolved engine ("" auto → podman→docker; "docker"
        // pins docker). This is the fix for the old second-class docker path —
        // docker-pinned nodes now get the SAME shared-net + env + confine
        // treatment as podman ones, differing only in the engine binary.
        return driver_linux.up_confined(nm, img, compose.get_command(nm), compose.get_expose(nm), net, compose.get_env(nm), confine, _shares_of(nm), eng)
    }
    if k == "jail" {
        return driver_bsd.up(nm, compose.get_dataset(nm), "", compose.get_ip(nm), compose.get_command(nm))
    }
    if k == "bhyve" {
        // bhyve provisions-if-absent then starts via vm-bhyve. The image is a
        // logical name (e.g. "ubuntu-22.04+podman") realized per-host: if its
        // image_recipe's realize_as("clone:<snap>") target exists, clone it
        // (fast); else full-provision. The runner resolves the recipe (it
        // bridges compose<->driver) and passes the clone target down.
        gi = compose.get_guest_image(nm)
        // Resolve this VM's IP via the per-project sticky binding (ipam):
        // reused across re-runs (iterative-dev DX), distinct per VM — retiring
        // the old single 172.16.0.50 assumption. The runner resolves (it has the
        // system name) + passes the address down; the driver receives it.
        gip = ipam.resolve_ip(compose.get_system(nm), nm)
        return driver_vm.bhyve_up(nm, gi, _realize_target(gi), gip, compose.get_cpus(nm), compose.get_memory(nm), compose.get_network(nm), compose.get_ssh_key(nm))
    }
    if k == "kvm" {
        return driver_vm.up("kvm", nm, compose.get_image(nm), compose.get_cpus(nm), compose.get_memory(nm), compose.get_nic(nm), _shares_of(nm))
    }
    if k == "proxmox_vm" {
        // REMOTE VM on a Proxmox VE host, over its HTTPS API (driver_proxmox):
        // clone the template -> cloud-init config -> start. All node inputs
        // (host/node/token/storage/bridge/template/cpus/memory) come from the
        // compose model; the driver is a pure API client (std.http.client).
        return driver_proxmox.up(nm)
    }
    if k == "proxmox_ct" {
        // REMOTE LXC container on PVE (driver_proxmox, /lxc path): create from an
        // ostemplate tarball -> start. Same driver, kind-branched internally.
        return driver_proxmox.up(nm)
    }
    if k == "bwrap" {
        // UNPRIVILEGED bubblewrap sandbox (driver_bwrap): the lightest tier, no
        // host setup. image() is an optional rootfs dir ("" = sandbox the host
        // userland); command() is the (required) process the sandbox runs.
        return driver_bwrap.up(nm, compose.get_image(nm), compose.get_command(nm), _shares_of(nm))
    }
    if k == "nspawn" {
        // systemd-nspawn SYSTEM container (driver_nspawn): the systemd-native LXC
        // peer. image() is the (required) rootfs directory; command() "" -> --boot
        // the rootfs init, else run command() as the container payload.
        return driver_nspawn.up(nm, compose.get_image(nm), compose.get_command(nm), _shares_of(nm))
    }
    if k == "firecracker" {
        // Firecracker microVM (driver_firecracker): a minimal-device-model VMM.
        // image() is a bundle dir (vmlinux + rootfs.ext4); cpus()/memory() size it.
        return driver_firecracker.up(nm, compose.get_image(nm), compose.get_cpus(nm), compose.get_memory(nm))
    }
    if k == "kata" {
        // Kata microVM (driver_kata): an OCI image booted inside a lightweight VM via
        // containerd's kata shim-v2. image() is the OCI image; command() its payload.
        return driver_kata.up(nm, compose.get_image(nm), compose.get_command(nm))
    }
    return "aeo: kind '${k}' has no up() driver on this host"
}

// driver_exec(nm, k, cmd) — run a command IN a single node, return its stdout
// ("" on failure). The per-node operability primitive (`aeo exec <node> <cmd>`),
// routed per kind exactly like driver_up:
//   jail              -> jexec (driver_bsd)
//   bhyve             -> ssh into the guest (driver_vm)
//   container in a VM -> ssh into its host VM, podman exec there
//   container/docker/lxc on the host -> podman/docker exec (driver_linux)
driver_exec(nm: string, k: string, cmd: string) -> string {
    if k == "jail" {
        return driver_bsd.exec_capture(nm, cmd)
    }
    if k == "bhyve" {
        gip = ipam.resolve_ip(compose.get_system(nm), nm)
        return driver_vm.exec_capture(nm, gip, cmd)
    }
    if k == "container" {
        eng = compose.get_engine(nm)
        if eng == "wslc" {
            return driver_wslc.exec_capture(nm, cmd)
        }
        if eng == "wsl_podman" {
            return driver_windows.exec_capture(nm, compose.get_wsl_distro(nm), cmd)
        }
        host = compose.get_host(nm)
        if host != "" {
            // nested: ssh into the host VM and podman-exec the container there.
            hip = ipam.resolve_ip(compose.get_system(host), host)
            return driver_vm.exec_capture(host, hip, "podman exec ${nm} ${cmd}")
        }
        return driver_linux.exec_capture(nm, cmd, eng)   // eng "" auto, "docker" pins
    }
    if k == "lxc" {
        return driver_lxc.exec_capture(nm, cmd)
    }
    if k == "bwrap" {
        return driver_bwrap.exec_capture(nm, cmd)
    }
    if k == "nspawn" {
        return driver_nspawn.exec_capture(nm, cmd)
    }
    if k == "firecracker" {
        return driver_firecracker.exec_capture(nm, cmd)
    }
    return ""
}

driver_down(nm: string, k: string) -> string {
    if k == "load_balancer" {
        return driver_loadbalancer.down(nm)
    }
    if k == "jail" {
        return driver_bsd.down(nm)
    }
    if k == "bhyve" {
        return driver_vm.down("bhyve", nm)
    }
    if k == "kvm" {
        return driver_vm.down("kvm", nm)
    }
    if k == "proxmox_vm" {
        // Remote PVE VM: stop -> destroy(--purge) over the API (idempotent — a
        // VM that isn't there is already down).
        return driver_proxmox.down(nm)
    }
    if k == "proxmox_ct" {
        // Remote PVE LXC: stop -> destroy(--purge) over the /lxc API (idempotent).
        return driver_proxmox.down(nm)
    }
    if k == "lxc" {
        return driver_lxc.down(nm)
    }
    if k == "bwrap" {
        return driver_bwrap.down(nm)
    }
    if k == "nspawn" {
        return driver_nspawn.down(nm)
    }
    if k == "firecracker" {
        return driver_firecracker.down(nm)
    }
    if k == "kata" {
        return driver_kata.down(nm)
    }
    if k == "container" {
        eng = compose.get_engine(nm)
        if eng == "wslc" {
            return driver_wslc.down(nm)
        }
        if eng == "wsl_podman" {
            return driver_windows.down(nm, compose.get_wsl_distro(nm))
        }
        return driver_linux.down(nm, eng)   // "" auto, "docker" pins
    }
    return driver_linux.down(nm, "")
}

driver_probe(nm: string, k: string, health: string) -> int {
    if k == "load_balancer" {
        return driver_loadbalancer.probe(nm, health, "")
    }
    // AGENT PATH: a nested container (get_host != "") runs INSIDE its guest, so a
    // HOST podman probe can't see it — health must be asked of the guest's agent
    // (a `status` check via agent_delegate's polling already confirmed up at
    // bring-up; re-probe through the agent, not host podman).
    if k == "container" {
        eng = compose.get_engine(nm)
        if eng == "wslc" {
            return driver_wslc.probe(nm, health)
        }
        if eng == "wsl_podman" {
            return driver_windows.probe(nm, compose.get_wsl_distro(nm), health)
        }
        phost = compose.get_host(nm)
        if string_length(phost) > 0 {
            // Nested container in a REMOTE proxmox_vm: probe via the guest agent at
            // its LAN IP (same doer path as up).
            if compose.get_kind(phost) == "proxmox_vm" {
                pgip = driver_proxmox.guest_ip(phost)
                if string_length(pgip) == 0 { return 0 }
                pbase = "http://${pgip}:${string_from_int(_agent_port(phost))}"
                ptok = _agent_token(phost)
                if string_length(ptok) == 0 { ptok = "aeo-dev-token" }
                return driver_vm.agent_status_at(pbase, nm, ptok)
            }
            if _agent_path_on() == 1 {
                return driver_vm.agent_status(phost, nm, _agent_token(phost), _agent_port(phost))
            }
        }
        return driver_linux.probe(nm, health, eng)   // "" auto, "docker" pins
    }
    if k == "jail" {
        return driver_bsd.probe(nm, health, "")
    }
    if k == "bhyve" {
        return driver_vm.probe("bhyve", nm, health)
    }
    if k == "kvm" {
        return driver_vm.probe("kvm", nm, health)
    }
    if k == "proxmox_vm" {
        // Remote PVE VM liveness == status/current is "running" (API probe). A
        // deeper in-guest health() check (ssh/qemu-agent) is a follow-up; for now
        // "the hypervisor reports it running" is the readiness signal.
        return driver_proxmox.probe(nm)
    }
    if k == "proxmox_ct" {
        // Remote PVE LXC liveness == status/current is "running".
        return driver_proxmox.probe(nm)
    }
    if k == "lxc" {
        return driver_lxc.probe(nm, health, "")
    }
    if k == "bwrap" {
        return driver_bwrap.probe(nm, health, "")
    }
    if k == "nspawn" {
        return driver_nspawn.probe(nm, health, "")
    }
    if k == "firecracker" {
        return driver_firecracker.probe(nm, health, "")
    }
    if k == "kata" {
        return driver_kata.probe(nm, health, "")
    }
    return driver_linux.probe(nm, health, "")
}


// _gpu_preflight() — for each container/lxc node with a gpu() claim, probe that its
// DRI render node actually EXISTS on this host. Non-fatal: a missing node means "not
// the host to `up` on", not "the composition is wrong" — so CI on a GPU-less runner
// still validates shape. VM/exclusive claims skip (their device model is checked at
// deploy). BSD hosts skip (no /dev/dri). Prints one warning per absent device.
// _proxmox_preflight — reach each proxmox_vm's PVE host and verify deploy-readiness.
// Returns 1 to continue (all ready, OR only unreachable-hosts which we WARN about),
// 0 to fail the check (a reachable host is misconfigured — a real blocker). One
// remote round-trip per distinct proxmox_vm; skipped entirely when there are none.
_proxmox_preflight() -> int {
    ok = 1
    n = compose.count()
    i = 0
    while i < n {
        nm = compose.name_at(i)
        kk = compose.get_kind(nm)
        if kk == "proxmox_vm" || kk == "proxmox_ct" {
            if driver_proxmox.reachable(nm) == 0 {
                // box down / offline / away — NOT a model error; warn and continue.
                println("aeo: [${nm}] NOTE — PVE host ${compose.get_pve_host(nm)} unreachable; skipping remote preflight (the data model is validated; run `aeo check` where the box is reachable to verify host readiness)")
            } else {
                pf = driver_proxmox.preflight(nm)
                if string_length(pf) > 0 {
                    println(pf)
                    ok = 0
                }
            }
        }
        i = i + 1
    }
    return ok
}

_gpu_preflight() {
    if host.family() == "bsd" { return }
    n = compose.count()
    i = 0
    while i < n {
        nm = compose.name_at(i)
        mode = compose.get_gpu_mode(nm)
        if string_length(mode) > 0 {
            k = compose.get_kind(nm)
            if k == "container" {
                _gpu_probe_dev(nm)
            }
            if k == "lxc" {
                _gpu_probe_dev(nm)
            }
        }
        i = i + 1
    }
}

_gpu_probe_dev(nm: string) {
    dev = compose.get_gpu_device(nm)
    if string_length(dev) == 0 { dev = "/dev/dri/renderD128" }
    av = list_new()
    list_add(av, "-c")
    list_add(av, "test -e '${dev}' && echo yes || echo no")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 0 {
        println("aeo: [${nm}] gpu(\"${compose.get_gpu_mode(nm)}\") wants '${dev}' but it's absent on this host — the composition is valid; `up` it on a host with a GPU render node (this is a warning, not a failure)")
    }
}

// _gpu_cdi_device(nm) — probe the host for a CDI GPU spec and return a CDI device
// selector (e.g. "intel.com/gpu=all") if one is present, "" otherwise. The STRUCTURED
// GPU path: a CDI spec brings the whole device bundle (card + render + by-path), which
// is what the Intel UMD / VA-API media apps actually want — vs the raw render-node
// device-map. Vendor-portable (intel.com/gpu, nvidia.com/gpu, amd.com/gpu).
//
//   * An explicit gpu_device(pin) is the operator's choice — honor it, skip the probe
//     (a pin may itself BE a CDI name like "intel.com/gpu=render", or a raw path).
//   * Else scan /etc/cdi + /var/run/cdi for a "*.com/gpu" kind, prefer its `all`
//     device, fall back to `render`. Returns "" if no spec (→ raw DRI fallback).
// BSD hosts have no CDI — skip.
_gpu_cdi_device(nm: string) -> string {
    if host.family() == "bsd" { return "" }
    if string_length(compose.get_gpu_device(nm)) > 0 { return "" }
    av = list_new()
    list_add(av, "-c")
    // Emit the FIRST "<vendor>.com/gpu" kind found across the CDI dirs, then whether
    // it declares an "all" device. Format: "<vendor.com/gpu>|<all|render>". The regex
    // avoids an escaped dot (Aether string escaping + shell quoting is a footgun): a
    // bare `.` matching any char is harmless for a "com/gpu" vendor kind.
    list_add(av, "for d in /etc/cdi /var/run/cdi; do for f in \"$d\"/*.yaml \"$d\"/*.json; do [ -f \"$f\" ] || continue; k=$(grep -oE '[a-z0-9]+[.]com/gpu' \"$f\" | head -1); [ -n \"$k\" ] || continue; if grep -qE 'name:[[:space:]]*.?all' \"$f\"; then echo \"$k|all\"; else echo \"$k|render\"; fi; exit 0; done; done")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if err != "" { return "" }
    trimmed = _trim(out)
    if string_length(trimmed) == 0 { return "" }
    bar = string_index_of(trimmed, "|")
    if bar < 0 { return "" }
    vendor = string_substring(trimmed, 0, bar)
    devname = string_substring(trimmed, bar + 1, string_length(trimmed))
    return "${vendor}=${devname}"
}

// strip surrounding whitespace/newlines from a captured line.
_trim(s: string) -> string {
    n = string_length(s)
    lo = 0
    while lo < n {
        c = string_char_at(s, lo)
        if c != 32 { if c != 10 { if c != 13 { if c != 9 { break } } } }
        lo = lo + 1
    }
    hi = n
    while hi > lo {
        c = string_char_at(s, hi - 1)
        if c != 32 { if c != 10 { if c != 13 { if c != 9 { break } } } }
        hi = hi - 1
    }
    return string_substring(s, lo, hi)
}

// _confine_flags(nm, net) — render this node's confinement (limit{} caps,
// constrain{} hardening, netpolicy) to a podman flag string via confine_linux.
// The substrate-portable seam: the SAME grammar that lib/rctl renders to FreeBSD
// rctl rules, here renders to Linux cgroup/seccomp/network flags. "" if the node
// declared no confinement.
_confine_flags(nm: string, net: string, inet: string) -> string {
    rctl = compose.get_rctl(nm)
    constraints = compose.get_constraints(nm)
    netpolicy = compose.get_netpolicy(nm)
    // A node that is the TARGET of any peer egress (egress->nm) must join the
    // INTERNAL net so its internal-confined callers can reach it (peers must share
    // a network). Synthesize an internal marker into its policy for net placement
    // — unless it already opts out with deny_egress (none wins).
    if _is_egress_target(nm) == 1 {
        if string_contains(netpolicy, "egress:DENY-ALL") == 0 {
            netpolicy = "${netpolicy}, egress->_internal_peer:0"
        }
    }
    return confine_linux.confine_string2(rctl, constraints, netpolicy, net, inet)
}

// _is_egress_target(nm) — 1 if any node declares egress->nm:* (so nm serves an
// internal-confined caller and must share its internal net).
_is_egress_target(nm: string) -> int {
    needle = "egress->${nm}:"
    n = compose.count()
    i = 0
    while i < n {
        other = compose.name_at(i)
        if string_contains(compose.get_netpolicy(other), needle) == 1 {
            return 1
        }
        i = i + 1
    }
    return 0
}

// _container_image encodes a build failure as a leading "ERR:" sentinel
// (it can't return a tuple). These detect and unwrap it.
string_starts_err(s: string) -> int {
    if string_length(s) < 4 {
        return 0
    }
    if string_substring(s, 0, 4) == "ERR:" {
        return 1
    }
    return 0
}
_strip_err(s: string) -> string {
    return string_substring(s, 4, string_length(s))
}

// ---- bring-up engine ----
// Dependency-ordered, liveness-gated. Spawns one actor per declared
// resource, boots in dependency order (deferring a resource whose
// depends() target isn't up yet), blocking on each until up or failed.
// Returns 1 if every resource reached up, else 0 (partial bring-up; caller
// should tear down).
run_up() -> int {
    n = compose.count()
    // LEVEL-PARALLEL bring-up. Each pass boots a whole TOPOLOGICAL LEVEL — every
    // node whose depends() target is already up — CONCURRENTLY, then a single
    // barrier awaits the level before the next. Independent nodes no longer
    // serialize: wall-clock is the critical PATH of boots, not their SUM. (The
    // earlier engine awaited each node before dispatching the next — O(N) boots
    // even for N independent nodes; this is O(depth).) Ordering is unchanged: a
    // node is dispatched only once its dep is observably UP (BOOTING != UP), so a
    // dependent still waits for its dependency's level to complete.
    pass = 0
    while pass < n {
        // (1) FAN OUT — spawn + Boot every ready node in this level. `!` is an
        // async send and each actor's Boot handler runs on its own thread, so the
        // boots overlap; main does not await between dispatches.
        booted = list_new()
        i = 0
        while i < n {
            nm = compose.name_at(i)
            if get_state(nm) == STATE_DOWN() {
                if _deps_ready(nm) == 1 {
                    a = spawn(Resource())
                    a ! Configure { in_name: nm, in_kind: compose.get_kind(nm) }
                    a ! Boot {}
                    _ = list_add(booted, nm)
                }
            }
            i = i + 1
        }
        m = list_size(booted)
        if m == 0 {
            // Nothing dispatched: either every node is up (done) or a remaining
            // node has an unsatisfiable dep (cycle / missing). Stop; the final
            // verify decides success. (Break by exhausting the pass budget.)
            list_free(booted)
            pass = n
        } else {
            // (2) BARRIER — a SINGLE poller promotes the whole level. Each node's
            // driver already BACKGROUNDED its boot (detached), so their readiness
            // progresses concurrently; one thread probing all of them yields a
            // wall-clock of ~slowest-boot, not the sum. (A per-actor blocking poll
            // does NOT parallelize — the Aether runtime serializes blocking ops
            // inside actors; measured in test/bench_bringup.ae, ~5× at width 32.)
            up_ok = _await_level(booted, 120)
            list_free(booted)
            if up_ok == 0 {
                return 0
            }
            pass = pass + 1
        }
    }
    j = 0
    while j < n {
        if get_state(compose.name_at(j)) != STATE_UP() {
            return 0
        }
        j = j + 1
    }
    return 1
}

// 1 if `nm`'s declared dependency is satisfied (no dep, or the dep is UP).
// BOOTING != UP, so a node whose dep is booting in the SAME level is correctly
// deferred to the next pass — preserving depends() ordering under fan-out.
_deps_ready(nm: string) -> int {
    // A load_balancer IMPLICITLY depends on all its backends (children) being UP:
    // its std.http.proxy pool should start against ready upstreams, not race them
    // (a pool built before a backend is up admits it only after health checks
    // converge — correct eventually, but skews early traffic). Wait for every
    // child here so the LB is the LAST node in its subtree to boot.
    if compose.is_load_balancer(nm) == 1 {
        n = compose.count()
        i = 0
        while i < n {
            cn = compose.name_at(i)
            if compose.get_host(cn) == nm {
                if get_state(cn) != STATE_UP() {
                    return 0
                }
            }
            i = i + 1
        }
        // fall through to the explicit depends() check too
    }
    dep = compose.get_depends(nm)
    if dep == "" {
        return 1
    }
    if get_state(dep) == STATE_UP() {
        return 1
    }
    return 0
}

// Load a resource's deny-default pf policy into its own anchor, now that it's up
// and addressable. pf is FreeBSD-only, so skip elsewhere (the netpolicy is still
// generated + asserted by spec_pf_rulegen/spec_pf_enforce; only the live load is
// BSD). A no-op if the resource declared no netpolicy. Non-fatal by design:
// a pfctl failure logs loudly but doesn't tear the (already-up) node down — the
// operator sees an explicit "policy NOT enforced" line rather than a silent gap.
_enforce_netpolicy(nm: string) {
    if compose.get_netpolicy(nm) == "" {
        return
    }
    if host.family() != "bsd" {
        // On Linux, a CONTAINER's netpolicy IS enforced — confine_linux already
        // placed it on the right network (none/internal/shared) at up time. Report
        // that, don't warn. Non-container kinds have no Linux netpolicy path yet.
        k = compose.get_kind(nm)
        if _is_container(k) == 1 {
            println("aeo: [${nm}] netpolicy enforced via container network (${confine_linux.net_kind(compose.get_netpolicy(nm))})")
        } else {
            println("aeo: [${nm}] netpolicy declared but only pf(FreeBSD)/container enforce it — NOT enforced for kind=${k}")
        }
        return
    }
    // IPFW PREFLIGHT (the pf-redemption fix): ipfw shares pfil with pf and silently
    // eats bridged guest packets, so the anchor would load-but-not-bite while ipfw is
    // on. Warn loudly by default; AEO_IPFW_OFF=1 opts into disabling it.
    ipfw = pf.ipfw_conflict()
    if ipfw != "" {
        if _envc("AEO_IPFW_OFF") == "1" {
            derr = pf.ipfw_disable()
            if derr != "" {
                println("aeo: [${nm}] ${derr}")
            } else {
                println("aeo: [${nm}] ipfw disabled on the bridge path (AEO_IPFW_OFF=1) — pf netpolicy can now enforce")
            }
        } else {
            println("aeo: [${nm}] WARNING ${ipfw}")
        }
    }
    rules = compose.pf_rules_for(nm)
    err = pf.apply(compose.get_system(nm), nm, rules)
    if err != "" {
        println("aeo: [${nm}] WARNING pf policy NOT enforced: ${err}")
    } else {
        println("aeo: [${nm}] pf deny-default policy loaded (anchor ${pf.anchor_name(nm)})")
    }
}

// Apply a resource's rctl resource caps (the limit{} block), now that it's up.
// FreeBSD-only + needs kern.racct.enable=1 (see docs/bsd-host-setup.md). No-op
// if no limits declared. Subject: a jail node is jail:<name>; a bhyve VM is its
// hypervisor PROCESS — v0 caps jails only (process-PID targeting is a later
// thickening), and says so loudly rather than silently skipping a bhyve's caps.
// Non-fatal: an rctl failure warns, doesn't tear down.
_enforce_limits(nm: string) {
    if compose.get_rctl(nm) == "" {
        return
    }
    if host.family() != "bsd" {
        // On Linux, a container/wslc node's limit{} caps were ALREADY applied at
        // bring-up via cgroups (driver_linux.up_confined -> --memory/--pids-limit,
        // or the WSL engines' equivalents) — NOT via rctl. So this rctl pass is a
        // no-op for them, and must NOT claim "NOT enforced" (the cgroup enforcement
        // is real — podman inspect proves mem/pids caps). Only a NON-container
        // Linux kind (which has no cgroup limit path) is genuinely unenforced here.
        if _is_container(compose.get_kind(nm)) == 1 {
            return
        }
        println("aeo: [${nm}] limit{} declared but not enforced for kind='${compose.get_kind(nm)}' on a linux host (rctl is FreeBSD-only; cgroup caps apply to container kinds only)")
        return
    }
    k = compose.get_kind(nm)
    if k != "jail" {
        println("aeo: [${nm}] limit{} declared but v0 rctl caps jails only (kind=${k}) — NOT enforced")
        return
    }
    err = rctl.apply(nm, "jail")
    if err != "" {
        println("aeo: [${nm}] WARNING rctl caps NOT enforced: ${err}")
    } else {
        println("aeo: [${nm}] rctl resource caps applied (jail:${nm})")
    }
}

// Surface a weight/algorithm mismatch at `aeo up` (docs §5): an explicit
// algorithm() that ignores weights while some backend declares balancer_weight
// means those weights are SILENTLY dropped — the "model says something it won't
// do" failure the discipline forbids. NOT a hard error (the LB still works, just
// unweighted); we WARN loudly AND record it to the hash-chained audit trail so an
// unattended `up` still carries the signal (a bare log line scrolls past in CI).
// A no-op for every non-LB node and for LBs whose algorithm honours the weights.
_surface_lb_weight_ignored(nm: string) {
    if compose.is_load_balancer(nm) == 0 {
        return
    }
    if compose.lb_weight_ignored(nm) == 0 {
        return
    }
    algo = compose.lb_algorithm(nm)
    detail = "balancer_weight ignored by algorithm '${algo}' (not weighted_rr)"
    println("aeo: [${nm}] WARNING load_balancer weights IGNORED — ${detail}; declare weighted_rr or drop the weights")
    _ = audit.record(nm, "load_balancer", "weight-ignored", detail)
}

// ---- teardown engine ----
// LEVEL-PARALLEL teardown — the reverse mirror of run_up. Nodes are processed
// in REVERSE topological levels (most-dependent first), computed over BOTH
// edges a node can have: its depends() chain AND its containment host (a
// nested node always tears down a level before its guest). Same invariant the
// old reverse-declaration walk gave — every dependent is gone before its
// dependency is halted — minus the serialization. Within a level:
//   1. per-node BSD cleanup first (pf anchor flush + rctl cap removal) —
//      fast, best-effort, unchanged;
//   2. engine containers are halted in ONE parallel sweep per engine
//      (driver_linux.down_many): the per-container stop grace is paid once
//      per LEVEL, not once per node (measured 15.6s -> 6.3s at width 3);
//   3. every other kind fans out its actor Halt (per-node behaviour
//      byte-for-byte unchanged — sudo-gated downs stay per-node);
//   4. wait_for_idle() is the LEVEL BARRIER (state can't be — Configure sets
//      STATE_DOWN before Halt even runs);
//   5. ONE level poller verifies disappearance — the without() windows run
//      CONCURRENTLY, so a level of lingering nodes costs max(window), not sum.
run_down() {
    n = compose.count()
    // Depths computed ONCE into an int array (indexed by declaration order) —
    // the level loop reads them instead of re-walking the parent chains.
    depths = intarr.intarr_new_raw(n)
    maxd = 0
    i = 0
    while i < n {
        d = _teardown_depth(compose.name_at(i))
        intarr.intarr_set_unchecked(depths, i, d)
        if d > maxd {
            maxd = d
        }
        i = i + 1
    }
    lvl = maxd
    while lvl >= 0 {
        halted = list_new()
        i = n - 1
        while i >= 0 {             // reverse declaration order within the level
            nm = compose.name_at(i)
            if intarr.intarr_get_unchecked(depths, i) == lvl {
                // Drop this node's pf anchor BEFORE halting it, so no stale deny
                // rules outlive the node (its address returns to the ipam pool).
                // FreeBSD-only + best-effort: a flush failure doesn't block teardown.
                if compose.get_netpolicy(nm) != "" {
                    if host.family() == "bsd" {
                        _fe = pf.flush(nm)
                    }
                }
                // Drop its rctl caps too (jail subject) — best-effort, FreeBSD-only.
                if compose.get_rctl(nm) != "" {
                    if host.family() == "bsd" {
                        if compose.get_kind(nm) == "jail" {
                            _re = rctl.remove(nm, "jail")
                        }
                    }
                }
                if _engine_downable(nm) == 0 {
                    a = spawn(Resource())
                    a ! Configure { in_name: nm, in_kind: compose.get_kind(nm) }
                    a ! Halt {}
                }
                _ = list_add(halted, nm)
            }
            i = i - 1
        }
        // (2) one parallel sweep per DISTINCT engine among the level's
        // engine-downable nodes; down_many blocks until every stop+rm in the
        // sweep completed (`wait`), so those nodes are DOWN when it returns.
        _down_engine_groups(halted)
        // (3) BARRIER: drain the level's actor Halts before the next (lower)
        // level is touched. NB state can't be the barrier — Configure sets
        // STATE_DOWN immediately, before Halt even runs — but wait_for_idle
        // blocks until every dispatched handler (each driver_down) completed.
        wait_for_idle()
        // (4) verify the whole level's disappearance concurrently.
        _await_level_gone(halted)
        list_free(halted)
        lvl = lvl - 1
    }
    intarr.intarr_free(depths)
    wait_for_idle()
}

// Topological teardown depth of `nm`: 1 + max over its two possible parent
// edges (depends() target, containment host), 0 with neither. Bounded by the
// node count (eval-time gating already rejects self/undeclared deps; a
// malformed cycle saturates the guard instead of looping).
_teardown_depth(nm: string) -> int {
    return _td_depth(nm, compose.count() + 1)
}
_td_depth(nm: string, guard: int) -> int {
    if guard <= 0 {
        return 0
    }
    d = 0
    dep = compose.get_depends(nm)
    if dep != "" {
        dd = _td_depth(dep, guard - 1) + 1
        if dd > d {
            d = dd
        }
    }
    h = compose.get_host(nm)
    if h != "" {
        hd = _td_depth(h, guard - 1) + 1
        if hd > d {
            d = hd
        }
    }
    return d
}

// 1 iff `nm` tears down through driver_linux's shared container engine
// (driver_down's container/default arm with a podman/docker-class engine) —
// the nodes down_many can sweep in one call. Dedicated-driver kinds and the
// Windows-engine containers (wslc / wsl_podman) stay per-node.
_engine_downable(nm: string) -> int {
    k = compose.get_kind(nm)
    if k != "container" {
        if _kind_has_driver(k) == 1 {
            return 0
        }
        return 1                        // unknown kind -> driver_linux default arm
    }
    eng = compose.get_engine(nm)
    if eng == "wslc" {
        return 0
    }
    if eng == "wsl_podman" {
        return 0
    }
    return 1
}

// 1 iff `k` has a dedicated (non-container-engine) driver arm in driver_down.
_kind_has_driver(k: string) -> int {
    // Dedicated (non-container-engine) driver kinds. String dispatch via match
    // (the Aether idiom for value dispatch — see aether LLM.md). Any new such kind
    // (e.g. a future proxmox_* variant) adds one arm here.
    match (k) {
        "jail" -> { return 1; }
        "bhyve" -> { return 1; }
        "kvm" -> { return 1; }
        "proxmox_vm" -> { return 1; }
        "proxmox_ct" -> { return 1; }
        "lxc" -> { return 1; }
        "bwrap" -> { return 1; }
        "nspawn" -> { return 1; }
        "firecracker" -> { return 1; }
        "kata" -> { return 1; }
        _ -> { return 0; }
    }
    return 0
}

// (2) of run_down: sweep the level's engine-downable nodes, one down_many per
// DISTINCT engine preference, then record their state (no actor did it).
_down_engine_groups(halted: ptr) {
    m = list_size(halted)
    prefs = list_new()
    i = 0
    while i < m {
        nm = list_get_raw(halted, i)
        if _engine_downable(nm) == 1 {
            pref = compose.get_engine(nm)
            if _list_has(prefs, pref) == 0 {
                _ = list_add(prefs, pref)
            }
        }
        i = i + 1
    }
    p = 0
    np = list_size(prefs)
    while p < np {
        names = _names_for_pref(halted, prefs, p)
        if string_length(names) > 0 {
            derr = _down_many_for_pref(names, prefs, p)
            if derr != "" {
                println("aeo: batch teardown: ${derr}")
            }
        }
        p = p + 1
    }
    list_free(prefs)
    i = 0
    while i < m {
        nm = list_get_raw(halted, i)
        if _engine_downable(nm) == 1 {
            set_state(nm, STATE_DOWN())
        }
        i = i + 1
    }
}

// space-joined engine-downable node names matching the p-th engine pref.
// (list_get results only ever flow as raw ptrs into string params — never
// interpolated: the list_get footgun.)
_names_for_pref(halted: ptr, prefs: ptr, p: int) -> string {
    pref = list_get_raw(prefs, p)
    names = ""
    m = list_size(halted)
    i = 0
    while i < m {
        nm = list_get_raw(halted, i)
        if _engine_downable(nm) == 1 {
            if _eq(compose.get_engine(nm), pref) == 1 {
                names = _sp_join(names, nm)
            }
        }
        i = i + 1
    }
    return names
}
_down_many_for_pref(names: string, prefs: ptr, p: int) -> string {
    pref = list_get_raw(prefs, p)
    return driver_linux.down_many(names, pref)
}

// membership test over a string list (raw ptrs passed as string params).
_list_has(lst: ptr, s: string) -> int {
    n = list_size(lst)
    i = 0
    while i < n {
        if _eq(list_get_raw(lst, i), s) == 1 {
            return 1
        }
        i = i + 1
    }
    return 0
}

_sp_join(acc: string, piece: string) -> string {
    if string_length(acc) == 0 {
        return piece
    }
    return "${acc} ${piece}"
}

// _await_level_gone — the without(d) retry-until-GONE verification for a whole
// level in ONE poller. Per-node window semantics preserved: a node with no
// without() is skipped (back-compat) — except engine-swept nodes, which get a
// small floor window so a failed rm still surfaces (their per-node stop/rm
// output was discarded; this is the honest failure detector). Engine nodes are
// gone-checked against ONE `ps` per engine per tick (the _alive_set shape);
// everything else keeps its per-node driver probe. A node still present at its
// deadline is reported loudly — teardown is not fire-and-assume.
_await_level_gone(halted: ptr) {
    m = list_size(halted)
    budget = 0
    i = 0
    while i < m {
        w = _gone_window(list_get_raw(halted, i))
        if w > budget {
            budget = w
        }
        i = i + 1
    }
    if budget <= 0 {
        return
    }
    waited = 0
    step = 250
    while waited < budget {
        alive = _gone_alive_set(halted)
        pending = 0
        i = 0
        while i < m {
            nm = list_get_raw(halted, i)
            if _gone_state(nm) == 0 {          // not yet verified/skipped
                w = _gone_window(nm)
                gone = 0
                if _engine_gonecheckable(nm) == 1 {
                    if string_index_of(alive, " ${nm} ") < 0 {
                        gone = 1
                    }
                } else {
                    if driver_probe(nm, compose.get_kind(nm), "") == 0 {
                        gone = 1
                    }
                }
                if gone == 1 {
                    _mark_gone(nm)
                    println("aeo: [${nm}] gone (verified within without window)")
                } else {
                    if waited + step >= w {
                        // this node's own window is exhausted — report + stop
                        // polling it; the level keeps verifying the others.
                        _mark_gone(nm)
                        println("aeo: [${nm}] WARNING still present after without window (${string_from_int(w)}ms) — lingering")
                    } else {
                        pending = 1
                    }
                }
            }
            i = i + 1
        }
        if pending == 0 {
            return
        }
        sleep(step)
        waited = waited + step
    }
}

// A node's gone-verification window: its declared without() ms; engine-swept
// nodes get a 2s floor (failure visibility), non-engine nodes without a
// without() keep the old skip (window 0).
_gone_window(nm: string) -> int {
    w = compose.get_without_ms(nm)
    if _engine_downable(nm) == 1 {
        if w < 2000 {
            w = 2000
        }
    }
    return w
}

// gone-verified bookkeeping via the config bridge (main-side state, like
// set_state). 0 = still pending, 1 = verified or reported.
_gone_state(nm: string) -> int {
    if config.get("aeo.gone.${nm}") == "1" {
        return 1
    }
    // window-0 non-engine nodes are "skipped" — treat as verified silently.
    if _gone_window(nm) <= 0 {
        return 1
    }
    return 0
}
_mark_gone(nm: string) {
    config.put("aeo.gone.${nm}", "1")
}

// 1 iff `nm` can be gone-checked from the batched engine `ps` — engine-downable
// AND top-level (a NESTED container's probe goes through the guest's agent, so
// it keeps the per-node driver_probe path).
_engine_gonecheckable(nm: string) -> int {
    if _engine_downable(nm) == 0 {
        return 0
    }
    if compose.get_host(nm) != "" {
        return 0
    }
    return 1
}

// The " a b c "-padded set of still-running engine containers relevant to this
// level — ONE `ps` per DISTINCT engine present, per tick (the teardown twin of
// _alive_set).
_gone_alive_set(halted: ptr) -> string {
    s = " "
    m = list_size(halted)
    prefs = list_new()
    i = 0
    while i < m {
        nm = list_get_raw(halted, i)
        if _engine_gonecheckable(nm) == 1 {
            if _gone_state(nm) == 0 {
                pref = compose.get_engine(nm)
                if _list_has(prefs, pref) == 0 {
                    _ = list_add(prefs, pref)
                }
            }
        }
        i = i + 1
    }
    p = 0
    np = list_size(prefs)
    while p < np {
        running = _running_for_pref(prefs, p)
        s = "${s}${_nl2sp(running)} "
        p = p + 1
    }
    list_free(prefs)
    return s
}

// running_names for the p-th pref in the list (raw ptr passed as a string arg —
// never interpolated).
_running_for_pref(prefs: ptr, p: int) -> string {
    pref = list_get_raw(prefs, p)
    return driver_linux.running_names(pref)
}

// The " a b c "-padded still-running set across ALL host-visible container
// nodes of the composition — one `ps` per distinct engine. The status walk's
// batch source (same shape as _alive_set / _gone_alive_set).
_status_alive_set() -> string {
    s = " "
    n = compose.count()
    prefs = list_new()
    i = 0
    while i < n {
        nm = compose.name_at(i)
        if _engine_gonecheckable(nm) == 1 {
            pref = compose.get_engine(nm)
            if _list_has(prefs, pref) == 0 {
                _ = list_add(prefs, pref)
            }
        }
        i = i + 1
    }
    p = 0
    np = list_size(prefs)
    while p < np {
        running = _running_for_pref(prefs, p)
        s = "${s}${_nl2sp(running)} "
        p = p + 1
    }
    list_free(prefs)
    return s
}

// Liveness for the status walk: host-visible engine containers consult the
// batched `alive` set; every other kind (VMs, jails, sandboxes, WSL engines,
// nested containers) keeps its per-node driver probe.
_live_state(nm: string, k: string, alive: string) -> int {
    if _engine_gonecheckable(nm) == 1 {
        if string_index_of(alive, " ${nm} ") >= 0 {
            return 1
        }
        return 0
    }
    return driver_probe(nm, k, "")
}


// Block until `nm` reports down (best-effort; bounded).
_await_down(nm: string, secs: int) {
    waited = 0
    step = 250
    budget = secs * 1000
    while waited < budget {
        if get_state(nm) == STATE_DOWN() {
            return
        }
        sleep(step)
        waited = waited + step
    }
}

// Print the declared tree and each resource's LIVE state. State is probed
// from the driver (not the in-memory bridge), so `aeo status` reports the
// truth about an already-running stack even though each invocation is a
// fresh process with empty in-memory state.
_status() {
    if _status_json_on() == 1 {
        _status_json()
        return
    }
    sys = compose.syscount()
    n = compose.count()
    println("aeo: ${sys} system(s), ${n} resource(s) declared")
    // ONE `ps` per distinct engine for all the host-visible container nodes;
    // the walk consults the membership set instead of probing each one.
    alive = _status_alive_set()
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        dep = compose.get_depends(nm)
        host = compose.get_host(nm)
        sysn = compose.get_system(nm)
        live = _live_state(nm, k, alive)
        st = "down"
        if live == 1 {
            st = "up"
        }
        // Tag the resource with its system and, when nested, its host VM.
        loc = "{${sysn}}"
        if host != "" {
            loc = "{${sysn}} inside ${host}"
        }
        if dep == "" {
            println("  ${nm} [${k}] ${loc} state=${st}")
        } else {
            println("  ${nm} [${k}] ◄ ${dep} ${loc} state=${st}")
        }
        _status_detail(nm, k)
        i = i + 1
    }
}

// Per-node detail line(s) for `aeo status` — the Proxmox-rich part: surface what
// aeo already knows but didn't show. Each fact prints only if SET, so a plain
// node stays a one-liner. ip / caps (rctl) / confinement (pf netpolicy or
// Capsicum grants) / snapshots available.
_status_detail(nm: string, k: string) {
    ip = compose.get_ip(nm)
    if ip != "" {
        println("      ip:    ${ip}")
    }
    caps = compose.get_rctl(nm)
    if caps != "" {
        println("      caps:  ${caps}")          // rctl resource limits
    }
    np = compose.get_netpolicy(nm)
    if np != "" {
        println("      net:   ${np}")            // pf deny-default policy
    }
    grants = compose.get_constraints(nm)
    if grants != "" {
        println("      grant: ${grants}")        // Capsicum fd grants
    }
    snaps = snapshot.list_snaps(nm, k, compose.get_dataset(nm))
    if snaps != "" {
        println("      snaps: ${_oneline(snaps)}")
    }
    // ATTESTATION posture — shown for EVERY container node, including the
    // unattested ones (an "unattestable" / "unpinned" node is exactly what a
    // supply-chain audit greps for; silence would hide it).
    if _is_container(k) == 1 {
        st = _attest_state(nm)
        pin = compose.get_attest(nm)
        if pin != "" {
            println("      attest: ${st} (${pin})")
        } else {
            println("      attest: ${st}")
        }
    }
}

// a node whose image is built locally (entrypoint/dockerfile) has no upstream
// digest -> "unattestable". A pulled image() with no pin -> "unpinned".
_attest_state(nm: string) -> string {
    built = 0
    if compose.get_entrypoint(nm) != "" {
        built = 1
    }
    if compose.get_dockerfile(nm) != "" {
        built = 1
    }
    return attest.attest_state(compose.get_attest(nm), compose.get_image(nm), built)
}
_is_container(k: string) -> int {
    if k == "container" { return 1 }
    return 0
}

// Collapse a newline-separated list to a comma-joined one-liner for status.
_oneline(s: string) -> string {
    out = ""
    n = string_length(s)
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c == 10 {
            if i + 1 < n {
                out = "${out}, "
            }
        } else {
            out = "${out}${string_from_char(c)}"
        }
        i = i + 1
    }
    return out
}

// `aeo status --json` toggle — the front-door sets AEO_STATUS_JSON=1.
_status_json_on() -> int {
    v = config.get("AEO_STATUS_JSON")
    if v == "" {
        v = os_getenv("AEO_STATUS_JSON")
    }
    if v == "1" {
        return 1
    }
    return 0
}

// JSON status — a flat array of node objects, machine-readable for tooling.
// The Proxmox-API value without the web server: pipe `aeo status --json` into
// jq, a dashboard, a CI gate. Same data as the human view; only the format
// differs. Hand-built (the fields are known strings) with JSON escaping.
_status_json() {
    n = compose.count()
    alive = _status_alive_set()          // one `ps` per engine, not one per node
    out = "["
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        live = _live_state(nm, k, alive)
        st = "down"
        if live == 1 {
            st = "up"
        }
        // object fields — name, kind, system, host, depends, state always; the
        // optional confinement/addr fields included as "" when unset (stable
        // shape for consumers > omitting keys).
        obj = "{"
        obj = "${obj}\"name\":\"${_jq(nm)}\","
        obj = "${obj}\"kind\":\"${_jq(k)}\","
        obj = "${obj}\"system\":\"${_jq(compose.get_system(nm))}\","
        obj = "${obj}\"host\":\"${_jq(compose.get_host(nm))}\","
        obj = "${obj}\"depends\":\"${_jq(compose.get_depends(nm))}\","
        obj = "${obj}\"state\":\"${st}\","
        obj = "${obj}\"ip\":\"${_jq(compose.get_ip(nm))}\","
        obj = "${obj}\"caps\":\"${_jq(compose.get_rctl(nm))}\","
        obj = "${obj}\"netpolicy\":\"${_jq(compose.get_netpolicy(nm))}\","
        obj = "${obj}\"grants\":\"${_jq(compose.get_constraints(nm))}\","
        // attestation posture: "attested"|"unpinned"|"unattestable" + the pin.
        // A CI gate / audit can fail on attestation!="attested" for prod nodes.
        obj = "${obj}\"attestation\":\"${_jq(_attest_state(nm))}\","
        obj = "${obj}\"attest_digest\":\"${_jq(compose.get_attest(nm))}\""
        obj = "${obj}}"
        if i == 0 {
            out = "${out}${obj}"
        } else {
            out = "${out},${obj}"
        }
        i = i + 1
    }
    out = "${out}]"
    println(out)
}

// Minimal JSON string escape: backslash and double-quote (the chars that break
// a JSON string). aeo's status values are paths/policies — no control chars
// expected, so these two cover it.
_jq(s: string) -> string {
    out = ""
    n = string_length(s)
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c == 34 {                       // "
            out = "${out}\\\""
        } else {
            if c == 92 {                   // backslash
                out = "${out}\\\\"
            } else {
                out = "${out}${string_from_char(c)}"
            }
        }
        i = i + 1
    }
    return out
}

// run_snapshot(tag) — snapshot every node's ZFS dataset at @tag (the
// Proxmox-style point-in-time). Per node: resolve its dataset (jail=declared,
// bhyve=zroot/vm/<name>), `zfs snapshot <ds>@<tag>`. Dataset-less kinds
// (container) are skipped. Reports per node; non-fatal (one node's failure
// doesn't abort the rest).
run_snapshot(tag: string) {
    n = compose.count()
    println("aeo: snapshot @${tag}")
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        ds = snapshot.dataset_for(nm, k, compose.get_dataset(nm))
        if ds != "" {
            err = snapshot.snapshot(nm, k, compose.get_dataset(nm), tag)
            if err != "" {
                println("  ${nm} [${k}] FAILED: ${err}")
            } else {
                println("  ${nm} [${k}] snapped ${ds}@${tag}")
            }
        } else {
            if snapshot_linux.supports(k) == 1 {
                lerr = snapshot_linux.snapshot(nm, k, compose.get_image(nm), tag)
                if lerr != "" {
                    println("  ${nm} [${k}] FAILED: ${lerr}")
                } else {
                    println("  ${nm} [${k}] snapped (${k}) @${tag}")
                }
            } else {
                println("  ${nm} [${k}] — no snapshot mechanism, skipped")
            }
        }
        i = i + 1
    }
}

// run_rollback(tag) — restore every node's dataset to its @tag snapshot
// (`zfs rollback -r`). REVERSE declaration order, so a dependency is rolled back
// after its dependents (mirrors teardown ordering). Each node should be DOWN
// first (rolling back a live jail/VM's dataset under it is unsafe); we warn but
// don't enforce — the operator runs `aeo down` then `aeo rollback`.
run_rollback(tag: string) {
    n = compose.count()
    println("aeo: rollback @${tag} (reverse order)")
    i = n - 1
    while i >= 0 {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        ds = snapshot.dataset_for(nm, k, compose.get_dataset(nm))
        if ds != "" {
            err = snapshot.rollback(nm, k, compose.get_dataset(nm), tag)
            if err != "" {
                println("  ${nm} [${k}] FAILED: ${err}")
            } else {
                println("  ${nm} [${k}] rolled back to ${ds}@${tag}")
            }
        } else {
            if snapshot_linux.supports(k) == 1 {
                lerr = snapshot_linux.rollback(nm, k, compose.get_image(nm), tag)
                if lerr != "" {
                    println("  ${nm} [${k}] FAILED: ${lerr}")
                } else {
                    println("  ${nm} [${k}] rolled back (${k}) @${tag}")
                }
            } else {
                println("  ${nm} [${k}] — no snapshot mechanism, skipped")
            }
        }
        i = i - 1
    }
}

// run_backup(tag, dir) — `zfs send` each node's @tag snapshot to a portable
// file under `dir`. The operator snapshots first (`aeo snapshot`), then backs up
// (composable). Per node; non-fatal. Restore is `zfs receive < <file>`.
run_backup(tag: string, dir: string) {
    n = compose.count()
    println("aeo: backup @${tag} -> ${dir}")
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        ds = snapshot.dataset_for(nm, k, compose.get_dataset(nm))
        if ds != "" {
            err = snapshot.backup(nm, k, compose.get_dataset(nm), tag, dir)
            if err != "" {
                println("  ${nm} [${k}] FAILED: ${err}")
            } else {
                println("  ${nm} [${k}] -> ${snapshot.backup_file(dir, nm, tag)}")
            }
        } else {
            if snapshot_linux.supports(k) == 1 {
                lerr = snapshot_linux.backup(nm, k, compose.get_image(nm), tag, dir)
                if lerr != "" {
                    println("  ${nm} [${k}] FAILED: ${lerr}")
                } else {
                    println("  ${nm} [${k}] -> ${snapshot_linux.backup_file(dir, nm, tag, k)}")
                }
            } else {
                println("  ${nm} [${k}] — no backup mechanism, skipped")
            }
        }
        i = i + 1
    }
}

// run_prune(keep) — retention: keep the `keep` most-recent snapshots per node,
// destroy older (by creation time). Per node; non-fatal.
run_prune(keep: int) {
    n = compose.count()
    println("aeo: prune (keep ${string_from_int(keep)} newest per node)")
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        ds = snapshot.dataset_for(nm, k, compose.get_dataset(nm))
        if ds != "" {
            err = snapshot.prune(nm, k, compose.get_dataset(nm), keep)
            if err != "" {
                println("  ${nm} [${k}] FAILED: ${err}")
            } else {
                println("  ${nm} [${k}] pruned (kept ${string_from_int(keep)})")
            }
        } else {
            if snapshot_linux.supports(k) == 1 {
                lerr = snapshot_linux.prune(nm, k, compose.get_image(nm), keep)
                if lerr != "" {
                    println("  ${nm} [${k}] FAILED: ${lerr}")
                } else {
                    println("  ${nm} [${k}] pruned (kept ${string_from_int(keep)})")
                }
            } else {
                println("  ${nm} [${k}] — no prune mechanism, skipped")
            }
        }
        i = i + 1
    }
}

// run_audit — `aeo audit <compose.ae>`: VERIFY the tamper-evident audit trail
// (the hash chain) and report. Each recorded security decision (attest verdict,
// confine posture) is hash-chained; a broken chain means the log was edited /
// truncated. Prints the path, the chain verdict, and the entry count.
run_audit() {
    p = audit.path()
    println("aeo: audit trail ${p}")
    cnt = _count_lines(p)
    println("  entries: ${cnt}")
    v = audit.verify(p)
    if v == "" {
        println("  chain:   INTACT (tamper-evident hash chain verified)")
    } else {
        println("  chain:   ${v}")
    }
}
// ---- reconcile: give aeo a life between up and down (Formae-envy item 1) ----
//
// `aeo reconcile <compose>` (one-shot) / `aeo watch <compose>` (loop): re-probe
// each node, read its ACTUAL rendered properties off the substrate, diff against
// what the composition NOW declares (lib/reconcile), and report/converge drift.
// State is NONE — desired = the composition, actual = live probes (no datastore).
//
// DEFAULT IS ALERT, NOT MUTATE (the doc's rule: containment tools must not silently
// mutate). Drift is audit-logged + printed; convergence only happens with
// AEO_CONVERGE=1 (the front-door sets it from `--converge`). A confined node
// drifting out of its declared envelope is a SECURITY EVENT — every detection and
// action is written to the lib/audit hash chain.
//
// v1 scope: the `container` kind (the one with inspect_state). Other kinds report
// "reconcile not yet supported for kind=X" — honest, not silent.

// _desired_line(nm) — the composition's desired canonical property line for a
// container node (the reconcile diff LHS), matching driver_linux.inspect_state's
// shape. Reads image + limit{} (memoryuse/maxproc from get_rctl) + the shared net.
_desired_line(nm: string) -> string {
    img = compose.get_image(nm)
    rctl = compose.get_rctl(nm)
    mem = confine_linux._kv_value(rctl, "memoryuse")
    pids = confine_linux._kv_value(rctl, "maxproc")
    // net: a node on the shared aeo net (unless deny_egress -> none). We report the
    // shared net name with the trailing comma podman's inspect range emits. A node
    // with a bridge net shows it; default-net (pasta) shows empty on both sides.
    net = ""
    return reconcile.render_desired(img, mem, pids, "0", net)
}

// _reconcile_node(nm, converge) — reconcile ONE container node. Returns the number
// of drift/failure events observed (0 = coherent). Audits every event + action.
_reconcile_node(nm: string, converge: int) -> int {
    k = compose.get_kind(nm)
    if k != "container" {
        println("aeo: [${nm}] reconcile not yet supported for kind='${k}' (container only in v1)")
        return 0
    }
    // POLICY (item 5): a node's own policy{ on_drift("converge") } opts IT into
    // convergence even without the global --converge flag. The global flag is an
    // operator override that forces convergence tree-wide; the per-node policy is the
    // composition's own declared intent. Either one arms this node. Default (no
    // policy, no flag) stays alert-only.
    if converge == 0 {
        pod = compose.get_policy_on_drift(nm)
        if pod == "converge" { converge = 1 }
    }
    eng = compose.get_engine(nm)
    // 1. LIVENESS: is the node even up?
    alive = driver_linux.probe(nm, compose.get_health(nm), eng)
    if alive == 0 {
        println("aeo: [${nm}] DRIFT: node is not running (down or unhealthy)")
        _ = audit.record(nm, k, "drift", "node not running")
        if converge == 1 {
            println("aeo: [${nm}] converge: restarting")
            err = driver_up(nm, k)
            if string_starts_err(err) == 1 {
                println("aeo: [${nm}] converge FAILED: ${_strip_err(err)}")
                _ = audit.record(nm, k, "converge-fail", _strip_err(err))
            } else {
                _ = audit.record(nm, k, "converge", "restarted (was not running)")
            }
        }
        return 1
    }
    // 2. PROPERTY DRIFT: diff the live envelope against the composition.
    actual = driver_linux.inspect_state(nm, eng)
    if string_length(actual) == 0 {
        // running per probe but not inspectable (a Windows/wsl engine, or a race).
        return 0
    }
    desired = _desired_line(nm)
    d = reconcile.state_diff(desired, actual)
    if string_length(d) == 0 {
        return 0
    }
    // A confined node OUT of its declared envelope is a security event.
    println("aeo: [${nm}] DRIFT: ${d}")
    _ = audit.record(nm, k, "drift", d)
    if converge == 1 {
        // Property drift on a container is corrected by RECREATE (podman can't
        // re-cap a running container). driver_up short-circuits on an already-running
        // node (its up idempotency guard), so we DOWN first to clear the drifted
        // container, then UP recreates it with the composition's flags — re-attesting
        // fail-closed, exactly as `up` does. (down+up, not a raw --replace, so the
        // recreate goes through the SAME confined bring-up path as a fresh up.)
        println("aeo: [${nm}] converge: recreating to the declared envelope")
        _ = driver_down(nm, k)
        err = driver_up(nm, k)
        if string_starts_err(err) == 1 {
            println("aeo: [${nm}] converge FAILED: ${_strip_err(err)}")
            _ = audit.record(nm, k, "converge-fail", _strip_err(err))
        } else {
            _ = audit.record(nm, k, "converge", "recreated to envelope (${d})")
        }
    }
    return 1
}

// run_reconcile — one pass over every node in declaration order (which honors
// depends: run_up ordered them). Prints a summary; exits non-zero if any drift was
// seen (so `aeo reconcile` is a CI-usable coherence gate). AEO_CONVERGE=1 acts.
run_reconcile() {
    converge = 0
    if _envc("AEO_CONVERGE") == "1" { converge = 1 }
    mode = "detect"
    if converge == 1 { mode = "converge" }
    println("aeo: reconcile (${mode}) — desired=composition, actual=live probes")
    n = compose.count()
    i = 0
    events = 0
    while i < n {
        events = events + _reconcile_node(compose.name_at(i), converge)
        i = i + 1
    }
    if events == 0 {
        println("aeo: reconcile — COHERENT (no drift)")
        exit(0)
    }
    println("aeo: reconcile — ${string_from_int(events)} drift/failure event(s) (see the audit trail)")
    exit(1)
}

// run_watch — `aeo watch <compose>`: run_reconcile's pass on a loop, every
// AEO_WATCH_INTERVAL seconds (default 30), until interrupted (Ctrl-C). The
// long-running mode of the runner — NOT a new daemon. Never exits on its own; each
// pass reports drift + (if AEO_CONVERGE=1) converges. In-memory pass counter only.
run_watch() {
    converge = 0
    if _envc("AEO_CONVERGE") == "1" { converge = 1 }
    interval = _watch_interval_ms()
    mode = "detect"
    if converge == 1 { mode = "converge" }
    println("aeo: watch (${mode}) — reconciling every ${string_from_int(interval / 1000)}s (Ctrl-C to stop)")
    pass = 0
    keep = 1
    while keep == 1 {
        pass = pass + 1
        n = compose.count()
        i = 0
        events = 0
        while i < n {
            events = events + _reconcile_node(compose.name_at(i), converge)
            i = i + 1
        }
        if events == 0 {
            println("aeo: watch pass ${string_from_int(pass)} — coherent")
        } else {
            println("aeo: watch pass ${string_from_int(pass)} — ${string_from_int(events)} drift event(s)")
        }
        sleep(interval)
    }
}

// The watch-loop cadence in ms. Precedence: explicit AEO_WATCH_INTERVAL (operator
// override) > the SMALLEST reprobe_every declared by any node's policy{} (so a node
// asking to be checked every 5s isn't starved by a 30s default) > 30s default. Every
// node is reconciled each pass; per-node reprobe_every sets the FLOOR on how often
// the loop runs, honoring the most-eager node. (True per-node independent scheduling
// is a follow-up; this keeps the composition's declared intent without under-serving.)
_watch_interval_ms() -> int {
    v = _envc("AEO_WATCH_INTERVAL")
    if string_length(v) > 0 {
        s = _atoi_simple(v)
        if s >= 1 { return s * 1000 }
    }
    // smallest declared per-node reprobe_every (ms), 0 if none declared.
    n = compose.count()
    i = 0
    best = 0
    while i < n {
        r = compose.get_policy_reprobe_ms(compose.name_at(i))
        if r > 0 {
            if best == 0 { best = r }
            if r < best { best = r }
        }
        i = i + 1
    }
    if best > 0 { return best }
    return 30000
}

// ---- aeo-supervisor client (docs/aeo-supervisor.md) --------------------------
//
// `aeo up` hands the tree to a resident supervisor BY DEFAULT so `down`/`status` latch
// onto a live registry (not a re-handed composition). `--no-supervisor` (front-door ->
// AEO_NO_SUPERVISOR=1) reverts to the ephemeral fire-and-exit path. Default-up with no
// supervisor present is an ERROR — never a silent downgrade.

// the supervisor base URL (AEO_SUP_URL, default the local daemon).
_sup_base() -> string {
    v = _envc("AEO_SUP_URL")
    if string_length(v) == 0 { return "http://127.0.0.1:9460" }
    return v
}

// the shared token (AEO_SUP_TOKEN) — the front-door and the daemon must agree.
_sup_token() -> string { return _envc("AEO_SUP_TOKEN") }

// supervised mode is the default; AEO_NO_SUPERVISOR=1 opts out.
_supervised() -> int {
    if _envc("AEO_NO_SUPERVISOR") == "1" { return 0 }
    return 1
}

// 1 if a supervisor answers /health at the base URL.
_sup_present() -> int { return probe_health(_sup_base()) }

// _sup_post — POST body to a supervisor path, return the body ("" on error / non-200).
// The reply is "STATUS\tBODY"; we split + gate on 200.
_sup_post(path: string, body: string) -> string {
    r = post_path(_sup_base(), path, body)
    if string_length(r) == 0 { return "" }
    tab = string_index_of(r, "\t")
    if tab < 0 { return "" }
    st = string_substring(r, 0, tab)
    bd = string_substring(r, tab + 1, string_length(r))
    if st != "200" { return "" }
    return bd
}

// _sup_adopt — hand the just-brought-up tree to the supervisor. Body:
// "<token>\n<system>\n<node>:<kind>...". One adopt per system in the composition.
// Returns "" on success, an error string otherwise.
_sup_adopt() -> string {
    tok = _sup_token()
    // group nodes by system (a composition can declare more than one).
    scount = compose.syscount()
    si = 0
    while si < scount {
        sys = compose.sysname_at(si)
        body = "${tok}\n${sys}"
        n = compose.count()
        i = 0
        any = 0
        while i < n {
            nm = compose.name_at(i)
            if compose.get_system(nm) == sys {
                // top-level nodes only (nested nodes are held by their guest's agent).
                if compose.get_host(nm) == "" {
                    body = "${body}\n${nm}:${compose.get_kind(nm)}"
                    any = 1
                }
            }
            i = i + 1
        }
        if any == 1 {
            r = _sup_post("/adopt", body)
            if string_length(r) == 0 {
                return "aeo: supervisor /adopt failed for system '${sys}'"
            }
            println("aeo: [${sys}] adopted by supervisor (${_sup_base()})")
        }
        si = si + 1
    }
    return ""
}

// _sup_release_all — release every system in the composition from the supervisor
// (it tears the nodes down + forgets). Returns "" on success.
_sup_release_all() -> string {
    tok = _sup_token()
    scount = compose.syscount()
    si = 0
    while si < scount {
        sys = compose.sysname_at(si)
        r = _sup_post("/release", "${tok}\n${sys}")
        if string_length(r) == 0 {
            println("aeo: [${sys}] supervisor release returned nothing (may not have held it)")
        } else {
            println("aeo: ${r}")
        }
        si = si + 1
    }
    return ""
}

// run_extract — `aeo extract`: walk the host's LIVE containers and print a valid aeo
// composition (.ae) to stdout that would reproduce them (Formae-envy item 2, the
// brownfield-adoption path). Each node gets an attest() pre-filled with the image's
// CURRENT digest — extraction doubles as an attestation baseline. Container kind v1.
run_extract() {
    if host.family() == "bsd" {
        println("// aeo extract: container walk is Linux-only in v1 (jail/bhyve extract is a follow-up)")
        return
    }
    names = driver_linux.list_running("")
    nodes = ""
    seen = 0
    i = 0
    n = string_length(names)
    line = ""
    while i <= n {
        c = 10
        if i < n { c = string_char_at(names, i) }
        if c == 10 {
            if string_length(line) > 0 {
                nb = _extract_one(line)
                if string_length(nb) > 0 {
                    nodes = "${nodes}${nb}"
                    seen = seen + 1
                }
            }
            line = ""
        } else {
            line = "${line}${string_from_char(c)}"
        }
        i = i + 1
    }
    if seen == 0 {
        println("// aeo extract: no running containers found")
        return
    }
    print(extract.render_composition("extracted", nodes))
}

// _extract_one(name) — inspect one container + resolve its digest, render its node.
_extract_one(name: string) -> string {
    facts = driver_linux.extract_facts(name, "")
    if string_length(facts) == 0 { return "" }
    img = reconcile.field_of(facts, "img")
    mem = reconcile.field_of(facts, "mem")
    pids = reconcile.field_of(facts, "pids")
    // omit podman's DEFAULT PidsLimit (2048) — it's not a declared cap, so re-emitting
    // it would fabricate a limit_maxproc the operator never wrote (same class as the
    // reconcile unset-cap rule).
    if pids == "2048" { pids = "0" }
    // aeo runs command() under `/bin/sh -c CMD`; strip that wrapper so the extracted
    // command() is the bare command the operator would write (round-trips through up).
    cmd = _strip_sh_c(_trim(reconcile.field_of(facts, "cmd")))
    port = _port_num(reconcile.field_of(facts, "port"))
    digest = ""
    if string_length(img) > 0 {
        digest = driver_linux.image_digest(img, "")
    }
    return extract.render_node(name, img, digest, mem, pids, port, cmd)
}

// "8080/tcp" -> "8080" (strip the /proto); "" -> "". The published-port number.
_port_num(p: string) -> string {
    slash = string_index_of(p, "/")
    if slash < 0 { return p }
    return string_substring(p, 0, slash)
}

// strip a leading `/bin/sh -c ` wrapper (aeo adds it at up-time via command()).
_strip_sh_c(c: string) -> string {
    pre = "/bin/sh -c "
    if string_starts_with(c, pre) == 1 {
        return string_substring(c, string_length(pre), string_length(c))
    }
    return c
}

// run_inventory — `aeo inventory`: the same live walk as a TABLE (name, image, caps),
// and — when a composition is loaded — a "declared? yes/no" column (the coexistence
// story: which running containers this composition manages vs which it doesn't).
run_inventory() {
    if host.family() == "bsd" {
        println("aeo inventory: container walk is Linux-only in v1")
        return
    }
    names = driver_linux.list_running("")
    if string_length(names) == 0 {
        println("aeo inventory: no running containers")
        return
    }
    have_comp = 0
    if compose.count() > 0 { have_comp = 1 }
    if have_comp == 1 {
        println("NAME                 IMAGE                                    MEM        DECLARED")
    } else {
        println("NAME                 IMAGE                                    MEM")
    }
    i = 0
    n = string_length(names)
    line = ""
    while i <= n {
        c = 10
        if i < n { c = string_char_at(names, i) }
        if c == 10 {
            if string_length(line) > 0 {
                _inventory_row(line, have_comp)
            }
            line = ""
        } else {
            line = "${line}${string_from_char(c)}"
        }
        i = i + 1
    }
}

_inventory_row(name: string, have_comp: int) {
    facts = driver_linux.extract_facts(name, "")
    if string_length(facts) == 0 { return }
    img = reconcile.field_of(facts, "img")
    mem = reconcile.field_of(facts, "mem")
    memh = extract.bytes_to_human(mem)
    row = "${_pad(name, 20)} ${_pad(img, 40)} ${_pad(memh, 10)}"
    if have_comp == 1 {
        decl = "no"
        if _is_declared(name) == 1 { decl = "yes" }
        row = "${row} ${decl}"
    }
    println(row)
}

// 1 if `name` is a node in the loaded composition.
_is_declared(name: string) -> int {
    n = compose.count()
    i = 0
    while i < n {
        if compose.name_at(i) == name { return 1 }
        i = i + 1
    }
    return 0
}

// right-pad `s` to `w` chars (table columns). Truncates if longer.
_pad(s: string, w: int) -> string {
    n = string_length(s)
    if n >= w { return s }
    out = s
    k = n
    while k < w {
        out = "${out} "
        k = k + 1
    }
    return out
}

// run_apply_node — `aeo apply-node <compose.ae> <node>`: patch ONE node on a
// standing tree (Formae-envy item 3, small blast radius). Re-render THAT node's
// flags from the (edited) composition, diff against the live node, and apply only
// if it drifted — recreating just that node, touching nothing else. The on-call
// "change one property at 3am without owning the whole tree" workflow.
//
// It IS a single-node, always-converge reconcile: the diff + recreate machinery is
// _reconcile_node(node, converge=1). Coherent node -> a clear no-op (not an error).
// The node comes from AEO_NODE (front-door sets it). A confined node's patch is
// audit-recorded exactly as reconcile's convergence is.
run_apply_node() {
    node = _envc("AEO_NODE")
    if node == "" {
        println("aeo: apply-node needs a node (usage: aeo apply-node <compose.ae> <node>)")
        exit(2)
    }
    // verify the node is declared.
    n = compose.count()
    found = 0
    i = 0
    while i < n {
        if compose.name_at(i) == node { found = 1 }
        i = i + 1
    }
    if found == 0 {
        println("aeo: apply-node — no node '${node}' in this composition")
        exit(2)
    }
    println("aeo: apply-node [${node}] — diff vs live, apply only the delta")
    events = _reconcile_node(node, 1)
    if events == 0 {
        println("aeo: apply-node [${node}] — already coherent, nothing to apply")
        exit(0)
    }
    println("aeo: apply-node [${node}] — applied (see the audit trail)")
    exit(0)
}

_count_lines(p: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "wc -l < '${p}' 2>/dev/null | tr -d ' \\n' || echo 0")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_length(out) == 0 {
        return "0"
    }
    return out
}

// run_pasta — `aeo pasta <compose.ae> <on|off|status>`: manage the rootless pasta
// port-forwarder drop-in (preserve the client source IP). A HOST-level posture op
// (not per-node) — but bound to a composition so the change is recorded in that
// composition's audit trail. Linux-only (rootless podman); a no-op elsewhere.
//
// HONEST CONTRACT: `on` switches the active forwarder to pasta. On the BRIDGE net
// aeo uses, the pesto source-preserving path fully engages (verified: the shared
// pasta control socket is present — podman 6.0.0 ships this, it is NOT upstream-
// pending). The one unproven arm on our test box: a genuine EXTERNAL LAN client's
// source surviving — host-originated traffic to a published port is mapped to pasta's
// guest-addr by design, and we had no third LAN host to test the external/TAP path.
// So `on` never claims a preservation we observed; it reports what took effect.
run_pasta() {
    mode = _envc("AEO_NODE")
    if mode == "" { mode = "status" }
    if host.family() == "bsd" {
        println("aeo: pasta forwarder is a rootless-podman (Linux) feature — nothing to do on a BSD host")
        return
    }
    if mode == "status" {
        if driver_linux.pasta_forwarder_active("") == 1 {
            println("aeo: pasta forwarder ACTIVE (${driver_linux.pasta_dropin_path()}) — rootless published ports forward via pasta")
            println("     on a bridge net the pesto source-preserving path engages (pasta.sock present); external-client preservation is pasta's behavior on the TAP path")
        } else {
            println("aeo: pasta forwarder OFF — rootless published ports use rootlessport (masks the client source IP as the gateway)")
        }
        return
    }
    if mode == "on" {
        err = driver_linux.pasta_forwarder_ensure("")
        if err != "" {
            println(err)
            exit(1)
        }
        _ = audit.record("_host", "pasta", "forwarder", "on (${driver_linux.pasta_dropin_path()})")
        println("aeo: pasta forwarder ON — wrote ${driver_linux.pasta_dropin_path()}")
        println("     rootless published ports on a bridge net now forward via pasta+pesto (kernel-level, source-IP-preserving for external clients)")
        return
    }
    if mode == "off" {
        _ = driver_linux.pasta_forwarder_clear("")
        _ = audit.record("_host", "pasta", "forwarder", "off")
        println("aeo: pasta forwarder OFF — removed ${driver_linux.pasta_dropin_path()} (reverted to rootlessport)")
        return
    }
    println("aeo: pasta wants a mode — usage: aeo pasta <compose.ae> <on|off|status>")
    exit(2)
}

// run_exec — `aeo exec <compose.ae> <node> <cmd>`: run cmd IN one node, print its
// stdout. The per-node operability primitive. Node + cmd come from AEO_NODE /
// AEO_EXEC_CMD (the front-door sets them). Errors loudly if the node isn't in the
// composition; prints whatever the node returned (empty if it failed/unreachable).
run_exec() {
    node = _envc("AEO_NODE")
    cmd = _envc("AEO_EXEC_CMD")
    if node == "" {
        println("aeo: exec needs a node (usage: aeo exec <compose.ae> <node> <cmd>)")
        return
    }
    if cmd == "" {
        println("aeo: exec needs a command")
        return
    }
    // verify the node is declared.
    n = compose.count()
    found = 0
    k = ""
    i = 0
    while i < n {
        if compose.name_at(i) == node {
            found = 1
            k = compose.get_kind(node)
        }
        i = i + 1
    }
    if found == 0 {
        println("aeo: no node '${node}' in this composition")
        return
    }
    out = driver_exec(node, k, cmd)
    println(out)
}

// run_restart — `aeo restart <compose.ae> <node>`: down then up a SINGLE node,
// without touching the rest of the tree (Proxmox's per-VM stop/start). Reuses
// driver_down + driver_up. Node from AEO_NODE.
run_restart() {
    node = _envc("AEO_NODE")
    if node == "" {
        println("aeo: restart needs a node (usage: aeo restart <compose.ae> <node>)")
        return
    }
    n = compose.count()
    found = 0
    k = ""
    i = 0
    while i < n {
        if compose.name_at(i) == node {
            found = 1
            k = compose.get_kind(node)
        }
        i = i + 1
    }
    if found == 0 {
        println("aeo: no node '${node}' in this composition")
        return
    }
    println("aeo: restart ${node} [${k}]")
    de = driver_down(node, k)
    if de != "" {
        println("  down: ${de}")
    }
    ue = driver_up(node, k)
    if ue != "" {
        println("  up FAILED: ${ue}")
    } else {
        println("  ${node} restarted")
    }
}

// run_cutover — `aeo cutover <compose.ae> <node> [new-image]`: zero-downtime
// blue-green swap of a single CONTAINER node. blue = the running <node>; green is
// stood up beside it (new image from AEO_CUTOVER_IMAGE / arg, else blue's own
// image = a rolling restart) on the shared aeo-<system> net, CONFINED identically,
// health-gated; then the service alias (<node>) moves blue->green and blue is
// retired. Rollback: if green fails health, green is torn down and blue keeps
// serving. Proven mechanism (network-alias swap on podman 6).
run_cutover() {
    node = _envc("AEO_NODE")
    if node == "" {
        println("aeo: cutover needs a node (usage: aeo cutover <compose.ae> <node> [new-image])")
        return
    }
    // find + kind-gate: cutover is container-only (the alias-swap mechanism).
    n = compose.count()
    found = 0
    i = 0
    while i < n {
        if compose.name_at(i) == node {
            found = 1
        }
        i = i + 1
    }
    if found == 0 {
        println("aeo: no node '${node}' in this composition")
        return
    }
    k = compose.get_kind(node)
    if k != "container" {
        println("aeo: cutover only supports container nodes (got kind='${k}')")
        return
    }
    eng = compose.get_engine(node)
    if eng == "wslc" {
        println("aeo: cutover not supported for the wslc engine yet (host podman/docker only)")
        return
    }
    if eng == "wsl_podman" {
        println("aeo: cutover not supported for the wsl_podman engine yet (host podman/docker only)")
        return
    }

    // green's image: AEO_CUTOVER_IMAGE if set, else blue's declared image (rolling).
    green_img = _envc("AEO_CUTOVER_IMAGE")
    if green_img == "" {
        green_img = _container_image(node, eng)
        if string_starts_err(green_img) == 1 {
            println("aeo: ${_strip_err(green_img)}")
            return
        }
    }
    green = "${node}-green"
    net = "aeo-${compose.get_system(node)}"
    inet = "aeo-${compose.get_system(node)}-int"
    confine = _confine_flags(node, net, inet)

    println("aeo: cutover ${node} -> green (${green}) image=${green_img}")

    // ATTEST the green image BEFORE it serves (the security invariant: a cutover
    // must not briefly serve an un-attested node). If blue pinned attest(), green
    // must match too; a mismatch refuses the cutover, blue keeps serving.
    pin = compose.get_attest(node)
    if attest.is_attested(pin) == 1 {
        averr = attest.verify(green_img, pin)
        if averr != "" {
            _ = audit.record(green, k, "attest-refuse", pin)
            println("aeo: cutover REFUSED — green image ${averr}")
            return
        }
        _ = audit.record(green, k, "attest-pass", pin)
        green_img = attest.pinned_ref(green_img, pin)
    }

    // ensure the shared nets exist (idempotent), then stand green up CONFINED.
    _ = driver_linux.network_ensure(net, eng)
    _ = driver_linux.network_ensure_internal(inet, eng)
    if string_length(confine) > 0 {
        _ = audit.record(green, k, "confine", confine)   // green booted WITH the posture
    }
    ge = driver_linux.up_green(green, green_img, compose.get_command(node), net, compose.get_env(node), confine, eng)
    if ge != "" {
        println("aeo: cutover ABORTED — green did not start: ${ge}")
        driver_linux.down(green, eng)
        return
    }

    // HEALTH-GATE green before the cut (poll its own name up to the node's window).
    health = compose.get_health(node)
    if _cutover_health_wait(green, health, eng) == 0 {
        println("aeo: cutover ROLLBACK — green failed health; retiring green, blue keeps serving")
        driver_linux.down(green, eng)
        return
    }
    println("  green healthy — cutting the '${node}' alias over")

    // THE CUT: move the service alias (the node's declared name) blue->green,
    // then blue no longer answers it.
    me = driver_linux.alias_move(net, node, green, node, eng)
    if me != "" {
        println("aeo: cutover FAILED at the alias swap: ${me} — rolling back green")
        driver_linux.down(green, eng)
        return
    }
    _ = audit.record(node, k, "cutover", "alias '${node}' blue->green (${green})")

    // retire blue (the old version). green now serves under the node's name.
    driver_linux.down(node, eng)
    println("aeo: cutover complete — '${node}' now served by green (${green}); blue retired")
}

// Poll green on its own container name until healthy or the node's up_within window
// elapses. 1 if healthy, 0 on timeout. Uses the same driver probe as bring-up.
_cutover_health_wait(green: string, health: string, eng: string) -> int {
    budget = 30000
    waited = 0
    tick = 1000
    while waited < budget {
        if driver_linux.probe(green, health, eng) == 1 {
            return 1
        }
        sleep(tick)
        waited = waited + tick
    }
    return 0
}

// env read with config-bridge fallback (matches _tag's pattern). Guards the
// getenv-returns-null footgun: os_getenv returns null (not "") when unset, and
// null != "" — so normalize a zero-length result to "".
_envc(key: string) -> string {
    v = config.get(key)
    if string_length(v) == 0 {
        v = os_getenv(key)
    }
    if string_length(v) == 0 {
        return ""
    }
    return v
}

// --- agent-path courier reads (the vertical slice; boot-side bake productizes
// these later). Opt-in + the per-guest secret/port the host uses to reach a
// guest's resident agent. AEO_AGENT_PATH=1 turns the whole path on. ---
_agent_path_on() -> int {
    v = _envc("AEO_AGENT_PATH")
    if string_length(v) == 0 {
        return 0
    }
    return 1
}
// Per-guest couriered secret: AEO_TOKEN_<host>, else the shared AEO_TOKEN.
// The value may be a SEALED envelope (lib/secrets) — the operator keeps
// ciphertext in env/state; it becomes plaintext HERE, the boundary where the
// courier uses it. secrets.resolve is fail-closed: sealed-but-unresolvable
// yields "" (no token -> the agent path denies), never the raw envelope.
_agent_token(host: string) -> string {
    v = _envc(_envkey("AEO_TOKEN_", host))
    if string_length(v) > 0 {
        return secrets.resolve(v)
    }
    return secrets.resolve(_envc("AEO_TOKEN"))
}
// Poll driver_proxmox.guest_ip(host) until it resolves, up to `tries` (3s apart).
// The container-delegate fires right after the VM up() returns, but the guest's
// DHCP IP + guest-agent take ~45-90s of cloud-init to appear. Returns the IP or "".
_wait_guest_ip(host: string, tries: int) -> string {
    i = 0
    while i < tries {
        gip = driver_proxmox.guest_ip(host)
        if string_length(gip) > 0 { return gip }
        sleep(3000)
        i = i + 1
    }
    return ""
}

// Host-side forwarded port to the guest's agent (:9450 in-guest). Per-guest
// AEO_AGENT_PORT_<host>, else AEO_AGENT_PORT, else the convention default 9450.
_agent_port(host: string) -> int {
    v = _envc(_envkey("AEO_AGENT_PORT_", host))
    if string_length(v) == 0 {
        v = _envc("AEO_AGENT_PORT")
    }
    if string_length(v) == 0 {
        return 9450
    }
    return _atoi_env(v)
}
// Sanitize a node name into a valid shell env-var suffix (hyphens etc. -> _).
// Env var names can't contain hyphens, so AEO_TOKEN_<host> must sanitize <host>.
_envkey(prefix: string, name: string) -> string {
    safe = ""
    n = string_length(name)
    i = 0
    while i < n {
        c = string_char_at(name, i)
        ok = 0
        if c >= 48 { if c <= 57 { ok = 1 } }
        if c >= 65 { if c <= 90 { ok = 1 } }
        if c >= 97 { if c <= 122 { ok = 1 } }
        if c == 95 { ok = 1 }
        if ok == 1 {
            safe = "${safe}${string_from_char(c)}"
        } else {
            safe = "${safe}_"
        }
        i = i + 1
    }
    return "${prefix}${safe}"
}
_atoi_env(s: string) -> int {
    n = string_length(s)
    acc = 0
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c >= 48 {
            if c <= 57 {
                acc = acc * 10 + (c - 48)
            }
        }
        i = i + 1
    }
    return acc
}

// Host-gating preflight (design § Host adaptation rule 2): every declared
// kind is checked against the host family BEFORE any resource is touched.
// A kind the host can't run is a fast, loud error at composition-eval
// time — not a silent no-op, not a failure three nodes deep. Returns ""
// if all kinds are runnable here, else the first offending error.
_preflight() -> string {
    // Load-balancer model checks FIRST (docs §3/§4/§7): publish-only-on-boundary,
    // balancer_weight-only-under-an-LB, backend-port agreement, supported
    // substrate. A loud eval-time error before any resource is touched — the same
    // discipline as the host-kind gate below.
    lberr = compose.lb_model_errors()
    if string_length(lberr) > 0 {
        return "aeo: load_balancer model error(s):\n${lberr}"
    }
    // Proxmox model checks: each proxmox_vm needs host()/node()/auth_token()/
    // template(). An empty auth_token most often means PVE_TOKEN is unset — fail
    // LOUD here (a remote substrate can otherwise silently do nothing). NOTE:
    // driver_proxmox (live create/start) is the documented frontier; this gate
    // validates the model so the file never claims a deploy it can't perform.
    pverr = compose.proxmox_model_errors()
    if string_length(pverr) > 0 {
        return "aeo: proxmox_vm model error(s):\n${pverr}"
    }
    fam = family()
    n = compose.count()
    i = 0
    while i < n {
        nm = compose.name_at(i)
        k = compose.get_kind(nm)
        // A resource nested INSIDE a VM (get_host != "") gates against that
        // VM's GUEST substrate, not the orchestrator host — a Linux
        // container inside a bhyve Linux VM is fine on a FreeBSD host. aeo
        // doesn't probe the guest OS yet, so for now a nested resource
        // skips the orchestrator-host kind gate (its substrate is the
        // guest's). Top-level (non-nested) resources gate against the host.
        host = compose.get_host(nm)
        if host == "" {
            // A `container` realized by a WSL engine (wslc / wsl_podman) runs on a
            // WINDOWS host, not Linux — the family gate (which linux-blocks
            // `container`) would wrongly reject it. Skip the family gate for those;
            // the driver's own available() is the real check at up-time.
            if _wsl_engined(nm, k) == 0 {
                runnable = _kind_runnable(k, fam)
                if runnable == 0 {
                    return "aeo: resource '${nm}' kind '${k}' cannot run on this host (family: ${fam})"
                }
                // container kinds are ENGINE-gated: fast-fail here (eval time)
                // when no engine binary resolves, instead of three nodes deep.
                // WSL engines gate through their own driver's available().
                if k == "container" {
                    ceng = compose.get_engine(nm)
                    if ceng != "wslc" {
                        if ceng != "wsl_podman" {
                            if driver_linux.engine_resolve(ceng) == "" {
                                return "aeo: resource '${nm}' kind 'container' cannot run here — no container engine on PATH (install podman or docker)"
                            }
                        }
                    }
                }
            }
        }
        // A depends() target that was never declared would leave this
        // resource un-ready forever — the bring-up loop would just fail
        // with no clue why. Catch it loudly at eval time instead.
        dep = compose.get_depends(nm)
        if dep != "" {
            if _declared(dep) == 0 {
                return "aeo: resource '${nm}' depends on '${dep}', which is not declared"
            }
            if dep == nm {
                return "aeo: resource '${nm}' depends on itself"
            }
        }
        i = i + 1
    }
    return ""
}

// 1 if `target` is one of the declared resource names, else 0.
_declared(target: string) -> int {
    n = compose.count()
    i = 0
    while i < n {
        if compose.name_at(i) == target {
            return 1
        }
        i = i + 1
    }
    return 0
}

// Emit a non-fatal warning for any system that mixes podman-plane and docker-plane
// container nodes. podman and docker maintain SEPARATE networks — peers on
// different engines in the same system can't resolve each other by name (only via
// published host ports). WSL engines (wslc/wsl_podman) own their own nets and don't
// participate in the host system network, so they're not part of this check.
_warn_mixed_engines() {
    sc = compose.syscount()
    si = 0
    while si < sc {
        sys = compose.sysname_at(si)
        has_podman = 0
        has_docker = 0
        n = compose.count()
        i = 0
        while i < n {
            nm = compose.name_at(i)
            if compose.get_system(nm) == sys {
                if compose.get_kind(nm) == "container" {
                    if compose.get_host(nm) == "" {          // host-level only
                        eng = compose.get_engine(nm)
                        if eng == "docker" {
                            has_docker = 1
                        } else {
                            if eng == "" {
                                has_podman = 1
                            } else {
                                if eng == "podman" {
                                    has_podman = 1
                                }
                            }
                        }
                    }
                }
            }
            i = i + 1
        }
        if has_podman == 1 {
            if has_docker == 1 {
                println("aeo: WARNING system '${sys}' mixes podman + docker container engines — separate network planes; peers CANNOT resolve each other by name (published host ports only). Pin one engine per system for name resolution.")
            }
        }
        si = si + 1
    }
}

// 1 if `nm` is a `container` node realized by a WSL engine (wslc / wsl_podman) —
// which runs on a Windows host, so it must bypass the linux family gate (its real
// gate is the driver's available()). All other nodes → 0 (gate normally).
_wsl_engined(nm: string, k: string) -> int {
    if k != "container" {
        return 0
    }
    eng = compose.get_engine(nm)
    if eng == "wslc" {
        return 1
    }
    if eng == "wsl_podman" {
        return 1
    }
    return 0
}

// Which host family each kind requires. jail/bhyve → bsd; lxc/container/kvm →
// linux (a WSL-engined container is exempted in _preflight). Unknown kinds
// rejected.
_kind_runnable(k: string, fam: string) -> int {
    // Can this ORCHESTRATOR host run kind `k`? Family-gated kinds return
    // _eq(fam,...); host-family-agnostic kinds (container/engine-gated, the remote
    // proxmox_* substrates, the local load_balancer front-door) return 1 and defer
    // to the driver's own available(). String dispatch via match (aether LLM.md).
    match (k) {
        "jail" -> { return _eq(fam, "bsd"); }
        "bhyve" -> { return _eq(fam, "bsd"); }
        "lxc" -> { return _eq(fam, "linux"); }
        "kvm" -> { return _eq(fam, "linux"); }
        "bwrap" -> { return _eq(fam, "linux"); }
        "nspawn" -> { return _eq(fam, "linux"); }
        "firecracker" -> { return _eq(fam, "linux"); }
        "kata" -> { return _eq(fam, "linux"); }
        // container: ENGINE-gated, not family-gated (podman/docker resolve on Linux
        // natively, macOS via Docker Desktop / podman machine; wslc/wsl_podman on
        // Windows). The engine's resolve IS the gate — so runnable everywhere, the
        // eval-time fast-fail happens at engine_resolve. Demoable on a stock Mac.
        "container" -> { return 1; }
        // proxmox_vm / proxmox_ct: REMOTE substrates driven over the PVE HTTPS API,
        // so the orchestrator's family is irrelevant. The real gate is reachability
        // of host()/auth_token() (proxmox_model_errors + the driver at up).
        "proxmox_vm" -> { return 1; }
        "proxmox_ct" -> { return 1; }
        // load_balancer: the L7 aeo-lb front-door runs locally, host-family-agnostic;
        // the driver's available() (is aeo-lb built?) is the real gate.
        "load_balancer" -> { return 1; }
        _ -> { return 0; }
    }
    return 0
}

_eq(a: string, b: string) -> int {
    if a == b {
        return 1
    }
    return 0
}

// Print the planned bring-up order WITHOUT touching any resource. Mirrors
// run_up's dependency-resolution passes but only prints; the same order
// run_up would boot in. Resources whose depends() target appears later in
// declaration order still sort correctly because the pass loop defers
// them until the target has been "planned".
_plan() {
    n = compose.count()
    println("aeo: dry-run — would bring up ${n} resource(s) in this order:")
    // planned[] tracked via config flags so we can reuse get_state-free
    // logic; here just simulate the same convergence the engine uses.
    seen = 0
    step = 1
    pass = 0
    while pass < n {
        i = 0
        while i < n {
            nm = compose.name_at(i)
            if config.get("aeo.plan.${nm}") == "" {
                dep = compose.get_depends(nm)
                ready = 0
                if dep == "" {
                    ready = 1
                } else {
                    if config.get("aeo.plan.${dep}") == "done" {
                        ready = 1
                    }
                }
                if ready == 1 {
                    config.put("aeo.plan.${nm}", "done")
                    k = compose.get_kind(nm)
                    health = compose.get_health(nm)
                    if dep == "" {
                        println("  ${step}. ${nm} [${k}]  health='${health}'")
                    } else {
                        println("  ${step}. ${nm} [${k}] ◄ ${dep}  health='${health}'")
                    }
                    step = step + 1
                    seen = seen + 1
                }
            }
            i = i + 1
        }
        pass = pass + 1
    }
    println("aeo: teardown would be the reverse of the above")
}

// _plan_live_diff — when the tree is ALREADY UP, dry-run also shows the
// property-level diff of each container node against live state (Formae-envy item 3:
// "dry-run should grow the same property-level diff against live state"). Reuses the
// reconcile diff. Silent when a node isn't up (nothing live to compare) or is
// coherent — so on a fresh host dry-run reads exactly as before (plan only).
_plan_live_diff() {
    if host.family() == "bsd" { return }
    n = compose.count()
    header = 0
    i = 0
    while i < n {
        nm = compose.name_at(i)
        if compose.get_kind(nm) == "container" {
            eng = compose.get_engine(nm)
            actual = driver_linux.inspect_state(nm, eng)
            if string_length(actual) > 0 {
                d = reconcile.state_diff(_desired_line(nm), actual)
                if string_length(d) > 0 {
                    if header == 0 {
                        println("aeo: LIVE DRIFT (this composition differs from the running tree):")
                        header = 1
                    }
                    println("  ${nm}: ${d}")
                }
            }
        }
        i = i + 1
    }
    if header == 1 {
        println("  (apply per-node with `aeo apply-node <compose> <node>`, or all with `aeo reconcile --converge`)")
    }
}

// ---- front-door entry ----
// Subcommand comes from AEO_CMD (the front-door sets it): "up" (default),
// "down", "status", or "dry-run". The operator's declaration is run first
// so the resource tree exists for every subcommand.
main() {
    aeo_orchestration()          // operator compose populates the tree (data)
    cmd = config.get("AEO_CMD")
    if cmd == "" {
        cmd = os_getenv("AEO_CMD")
    }

    if cmd == "status" {
        _status()
        return
    }

    // check — run the composition's declared check() specs, NO deploy. Data-model
    // assertions run anywhere (before the host gate), like status. Exit non-zero if
    // any spec fails, so `aeo check <file>` is a CI-usable pre-flight.
    if cmd == "check" {
        // GPU allocation gate (§G): a data-model check (exclusive-conflict, kind
        // gating) — runs anywhere, before the host gate, like the specs. A bad
        // claim fails `aeo check` with the reasoning as the error text, so the
        // human tier-choice becomes a machine-checked constraint.
        gerr = compose.gpu_alloc_error()
        if gerr != "" {
            println(gerr)
            exit(1)
        }
        // Load-balancer model gate (docs §3/§4/§7): the same data-model check the
        // up/down path runs, applied at `check` too so a bad balancer (publish on
        // a backend, weight without an LB parent, backend-port mismatch,
        // unsupported substrate) fails BEFORE any deploy.
        lberr = compose.lb_model_errors()
        if lberr != "" {
            println("aeo: load_balancer model error(s):\n${lberr}")
            exit(1)
        }
        // Proxmox model gate: each proxmox_vm must carry host/node/auth_token/
        // template. Fires at `check` too (like the LB gate) so a missing PVE_TOKEN
        // or endpoint fails BEFORE any attempt to reach the remote host.
        pverr = compose.proxmox_model_errors()
        if pverr != "" {
            println("aeo: proxmox_vm model error(s):\n${pverr}")
            exit(1)
        }
        // Proxmox REMOTE-HOST preflight: for each proxmox_vm, reach the PVE box
        // with its token and verify it's deploy-ready (template in pool, storage +
        // bridge present). A reachable-but-misconfigured host is a real deploy
        // blocker -> FAIL. An UNREACHABLE host (checking offline / away from the
        // box) is not a model error -> WARN and continue, so `aeo check` still
        // validates the composition's shape anywhere (the GPU-preflight discipline).
        if _proxmox_preflight() == 0 {
            exit(1)
        }
        // Host preflight: if any container gpu() claim needs a DRI render node,
        // warn (not fail) when it's absent — the data model is sound; the host may
        // simply be the wrong one to `up` on. Non-fatal so CI on a GPU-less runner
        // still validates the composition's SHAPE.
        _gpu_preflight()
        rc = _run_phase_specs("check")
        exit(rc)
    }

    // snapshot / rollback — ZFS point-in-time over each node's dataset. The tag
    // comes from AEO_TAG (the front-door sets it from the CLI arg); default
    // "snap" if unset. Dataset ops, not bring-up — run before the host gate.
    if cmd == "snapshot" {
        run_snapshot(_tag())
        return
    }
    if cmd == "rollback" {
        run_rollback(_tag())
        return
    }
    if cmd == "exec" {
        run_exec()
        return
    }
    if cmd == "cutover" {
        run_cutover()
        return
    }
    if cmd == "restart" {
        run_restart()
        return
    }
    if cmd == "backup" {
        run_backup(_tag(), _backup_dir())
        return
    }
    if cmd == "prune" {
        run_prune(_keep())
        return
    }
    if cmd == "audit" {
        run_audit()
        return
    }
    if cmd == "pasta" {
        run_pasta()
        return
    }
    if cmd == "reconcile" {
        run_reconcile()
        return
    }
    if cmd == "watch" {
        run_watch()
        return
    }
    if cmd == "apply-node" {
        run_apply_node()
        return
    }
    if cmd == "extract" {
        run_extract()
        return
    }
    if cmd == "inventory" {
        run_inventory()
        return
    }

    // Fast-fail host gating before any bring-up or teardown touches a
    // resource. Applies to up, down, and dry-run alike — dry-run is the
    // operator's pre-flight check, so it MUST surface the same gating.
    gate = _preflight()
    if gate != "" {
        println(gate)
        exit(2)
    }
    // Non-fatal WARNING: a system that mixes container engines (e.g. podman + docker
    // nodes in one system) can't resolve peers by NAME across them — podman and
    // docker networks are separate planes. Surface it loudly; don't block (the
    // operator may intend published-port bridging).
    _warn_mixed_engines()

    if cmd == "dry-run" {
        println(profile())
        _plan()
        _plan_live_diff()
        return
    }

    if cmd == "down" {
        println(profile())
        // SUPERVISED down: if a supervisor holds this tree, ask IT to release (it
        // tears the nodes down from its live registry — no dependence on this .ae
        // matching what's live). Falls through to the local run_down if unsupervised
        // or no supervisor answers (so --no-supervisor and supervisor-less hosts work).
        if _supervised() == 1 {
            if _sup_present() == 1 {
                _ = _sup_release_all()
                println("aeo: torn down (via supervisor)")
                return
            }
        }
        run_down()
        println("aeo: torn down")
        return
    }

    // up / smoke / suite all bring the tree up first. smoke + suite then run their
    // declared specs against the LIVE tree; suite tears down after, smoke leaves it
    // standing. Plain up just deploys.
    println(profile())
    ok = run_up()
    if ok == 0 {
        // AEO_KEEP_ON_FAIL=1 leaves the partial tree standing for post-mortem
        // (inspect a half-converged guest/agent) instead of tearing it down.
        if string_length(_envc("AEO_KEEP_ON_FAIL")) > 0 {
            println("aeo: bring-up failed — KEEPING partial tree (AEO_KEEP_ON_FAIL)")
            exit(1)
        }
        println("aeo: bring-up failed — tearing down partial tree")
        run_down()
        exit(1)
    }
    println("aeo: stack up")

    // SUPERVISOR (docs/aeo-supervisor.md): by default, hand the just-brought-up tree
    // to the resident supervisor so `aeo down`/`status` latch onto a live registry.
    // --no-supervisor (AEO_NO_SUPERVISOR=1) skips this (ephemeral fire-and-exit).
    // smoke/suite run their own specs + may tear down, so they skip adoption.
    if cmd == "up" {
        if _supervised() == 1 {
            if _sup_present() == 0 {
                println("aeo: no aeo-supervisor at ${_sup_base()} — start one, or pass --no-supervisor for the ephemeral path (tree is UP; not adopted)")
                exit(1)
            }
            aerr = _sup_adopt()
            if aerr != "" {
                println(aerr)
                exit(1)
            }
        }
    }

    // smoke — deploy + run smoke() specs against the live tree, LEAVE IT STANDING.
    if cmd == "smoke" {
        rc = _run_phase_specs("smoke")
        exit(rc)
    }
    // suite — deploy + run suite() specs, then TEAR DOWN (the CI shape). The teardown
    // runs regardless of spec result so a failed suite doesn't leak a live tree; the
    // spec's exit code is what the operator (CI) sees.
    if cmd == "suite" {
        rc = _run_phase_specs("suite")
        println("aeo: suite complete — tearing down")
        run_down()
        exit(rc)
    }
}

// _run_phase_specs(phase) — run every spec declared for `phase` across all systems,
// each as a SEPARATE process (`ae run <spec>`), so aeocha stays out of this runner.
// Returns 0 if all specs passed (or none declared), else the first non-zero rc — so
// `aeo check/smoke/suite` is CI-usable. Prints what it runs (no silent skips).
_run_phase_specs(phase: string) -> int {
    worst = 0
    ran = 0
    sc = compose.syscount()
    si = 0
    while si < sc {
        sys = compose.sysname_at(si)
        n = compose.get_phase_spec_count(sys, phase)
        i = 0
        while i < n {
            spec = compose.get_phase_spec_at(sys, phase, i)
            if string_length(spec) > 0 {
                println("aeo: ${phase} — running spec ${spec}")
                rc = _run_one_spec(spec)
                ran = ran + 1
                if rc != 0 {
                    if worst == 0 {
                        worst = rc
                    }
                }
            }
            i = i + 1
        }
        si = si + 1
    }
    if ran == 0 {
        println("aeo: ${phase} — no ${phase}() specs declared (nothing to run)")
    }
    return worst
}

// Run one spec file as a child process. Uses the spec runner if present (it wires
// the aeocha module path), else a bare `ae run`. Returns the child's exit status.
_run_one_spec(spec: string) -> int {
    av = list_new()
    list_add(av, "-c")
    // Prefer the project's spec harness (sets AEOCHA + lib path); fall back to a
    // direct `ae run` with aeo's own lib. AEO_HOME is the aeo tree root.
    home = _envc("AEO_HOME")
    if string_length(home) == 0 {
        home = os_getenv("AEO_HOME")
    }
    list_add(av, "cd ${home} && sh test/run-spec.sh ${spec}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    println(out)
    return status
}

// The snapshot/rollback/backup tag (AEO_TAG, set by the front-door from the CLI
// arg). Defaults to "snap" so a bare `aeo snapshot` still works.
_tag() -> string {
    t = config.get("AEO_TAG")
    if t == "" {
        t = os_getenv("AEO_TAG")
    }
    if t == "" {
        return "snap"
    }
    return t
}

// Backup output dir (AEO_BACKUP_DIR). Default /var/backups/aeo.
_backup_dir() -> string {
    d = _envc("AEO_BACKUP_DIR")
    if d == "" {
        return "/var/backups/aeo"
    }
    return d
}

// Retention keep-count (AEO_KEEP). Default 3.
_keep() -> int {
    v = _envc("AEO_KEEP")
    if v == "" {
        return 3
    }
    return _atoi_simple(v)
}
_atoi_simple(s: string) -> int {
    n = string_length(s)
    acc = 0
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c >= 48 {
            if c <= 57 {
                acc = acc * 10 + (c - 48)
            }
        }
        i = i + 1
    }
    return acc
}

import std.os (os_getenv, run_capture)
extern exit(code: int)
