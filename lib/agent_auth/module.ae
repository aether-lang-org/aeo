// lib/agent_auth — the bank-courier auth for the aeo-agent channel.
//
// The 1970s inter-bank key courier, not PKI: ssh is the motorbike. The host
// MINTS a fresh one-time secret (CSPRNG), the bootstrap ssh hand-DELIVERS it
// into the agent, and the standing channel is authed by it. Symmetric
// pre-shared key — no CA, no keypair, nothing to pin. The secret is per-agent,
// per-boot, and dies with the agent.
//
// This module is the auth CORE, transport-agnostic: mint + constant-time
// verify. transport_http carries it on the wire (under TLS for confidentiality);
// transport_file uses it for the warn/deny token check. All crypto is stock
// Aether stdlib (cryptography.random_bytes via nanoid; cryptography.hmac) — this
// is wiring, not new crypto.
//
//   mint_secret()              -> a fresh CSPRNG secret string ("" on failure)
//   verify(secret, presented)  -> 1 if presented matches, else 0 (CONSTANT-TIME)
//
// verify is constant-time so a network attacker can't byte-by-byte guess the
// secret by timing: we HMAC a fixed challenge under each side's secret and
// compare the two hex MACs with no early exit. Equal secrets -> equal MACs;
// unequal -> unequal, in the same time. (HMAC also means we compare 64 hex
// chars of fixed length regardless of secret length.)

import std.nanoid
import std.cryptography (hmac_sha256_hex)
import std.string (string_length, string_char_at)

exports ( mint_secret, verify, mac )

// A stable challenge MAC'd under the secret for the constant-time compare. Any
// fixed non-empty string works; the point is both sides MAC the SAME bytes so
// equal secrets give equal MACs. (A function, not a module-level `const`:
// module-level statics are fragile across the import+closure boundary in Aether
// — see LLM.md "state, never in a module var" — so we keep it a pure return.)
_challenge() -> string {
    return "aeo-agent-courier-v1"
}

// Mint a fresh one-time secret from the OS CSPRNG (nanoid: 126 bits, URL-safe).
// "" on failure — caller must treat that as fail-closed (no secret = deny).
mint_secret() -> string {
    s, err = nanoid.generate()
    if err != "" {
        return ""
    }
    return s
}

// HMAC-SHA256(secret, CHALLENGE) as hex. Fixed 64-char output regardless of
// secret length — the value the constant-time compare runs over. The top-level
// std.cryptography surface takes strings directly and returns (hex, err).
mac(secret: string) -> string {
    chal = _challenge()
    h, err = hmac_sha256_hex(secret, string_length(secret), chal, string_length(chal))
    if err != "" {
        return ""
    }
    return h
}

// Constant-time match of `presented` against `secret`. Returns 1 if equal, 0
// otherwise. Fail-closed: an empty configured secret denies everything (an
// agent with no couriered key trusts no one).
verify(secret: string, presented: string) -> int {
    if string_length(secret) == 0 {
        return 0                       // no courier key configured -> deny all
    }
    want = mac(secret)
    got = mac(presented)
    return _ct_eq(want, got)
}

// Constant-time string equality over two hex MACs (always 64 chars here).
// Accumulate the XOR of every byte pair; never early-exit. Returns 1 if all
// bytes matched, else 0.
_ct_eq(a: string, b: string) -> int {
    la = string_length(a)
    lb = string_length(b)
    diff = la - lb                     // length mismatch -> nonzero (but MACs are
    if diff < 0 {                      // fixed-length, so this is belt-and-braces)
        diff = 0 - diff
    }
    n = la
    if lb < n {
        n = lb
    }
    i = 0
    while i < n {
        ca = string_char_at(a, i)
        cb = string_char_at(b, i)
        x = ca - cb
        if x < 0 {
            x = 0 - x
        }
        diff = diff | x
        i = i + 1
    }
    if diff == 0 {
        return 1
    }
    return 0
}
