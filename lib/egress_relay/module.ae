// lib/egress_relay — minimal CONNECT-gateway core for egress_fqdn.
//
// This module keeps the CONNECT decision pure and exposes the small binary-safe
// relay primitives needed by the runtime gateway. Namespace/routing enforcement
// lives above this module; this layer only decides before 200 and pumps bytes.

import std.string (
    string_length, string_index_of, string_substring, string_contains,
    string_char_at, string_get_int, string_to_lower
)
import std.tcp (read_n, write_n, poll2)

exports (
    is_connect, connect_host, connect_port, host_allowed,
    decision_status, decision_reason, response_for_status,
    splice_supported, splice_blocker, relay_once, write_all, splice
)

is_connect(req: string) -> int {
    line = _first_line(req)
    if string_length(line) < 8 {
        return 0
    }
    if string_substring(line, 0, 8) == "CONNECT " {
        return 1
    }
    return 0
}

connect_host(req: string) -> string {
    line = _first_line(req)
    if is_connect(line) == 0 {
        return ""
    }
    rest = string_substring(line, 8, string_length(line))
    sp = string_index_of(rest, " ")
    if sp < 0 {
        return ""
    }
    authority = string_substring(rest, 0, sp)
    colon = string_index_of(authority, ":")
    if colon <= 0 {
        return ""
    }
    return string_to_lower(string_substring(authority, 0, colon))
}

connect_port(req: string) -> int {
    line = _first_line(req)
    if is_connect(line) == 0 {
        return 0
    }
    rest = string_substring(line, 8, string_length(line))
    sp = string_index_of(rest, " ")
    if sp < 0 {
        return 0
    }
    authority = string_substring(rest, 0, sp)
    colon = string_index_of(authority, ":")
    if colon <= 0 {
        return 0
    }
    port_s = string_substring(authority, colon + 1, string_length(authority))
    if _all_digits(port_s) == 0 {
        return 0
    }
    port = string_get_int(port_s)
    if port < 1 {
        return 0
    }
    if port > 65535 {
        return 0
    }
    return port
}

// Exact host allowlist. `csv` is the compose helper shape:
// "api.github.com, api.anthropic.com". No wildcards, suffixes, or trailing-dot
// normalization yet; those are separate policy decisions.
host_allowed(csv: string, host: string) -> int {
    h = string_to_lower(host)
    rest = csv
    more = 1
    while more == 1 {
        idx = string_index_of(rest, ",")
        entry = rest
        if idx >= 0 {
            entry = string_substring(rest, 0, idx)
            rest = string_substring(rest, idx + 1, string_length(rest))
        } else {
            more = 0
        }
        e = string_to_lower(_trim(entry))
        if string_length(e) > 0 {
            if e == h {
                return 1
            }
        }
    }
    return 0
}

decision_status(req: string, allow_csv: string) -> int {
    if is_connect(req) == 0 {
        return 400
    }
    host = connect_host(req)
    port = connect_port(req)
    if string_length(host) == 0 {
        return 400
    }
    if port == 0 {
        return 400
    }
    if host_allowed(allow_csv, host) == 1 {
        return 200
    }
    return 403
}

decision_reason(req: string, allow_csv: string) -> string {
    st = decision_status(req, allow_csv)
    if st == 200 {
        return "allow"
    }
    if st == 403 {
        return "deny:not-allowlisted"
    }
    return "deny:bad-connect"
}

response_for_status(status: int) -> string {
    if status == 200 {
        return "HTTP/1.1 200 Connection Established\r\n\r\n"
    }
    if status == 403 {
        return "HTTP/1.1 403 Forbidden\r\nConnection: close\r\n\r\n"
    }
    return "HTTP/1.1 400 Bad Request\r\nConnection: close\r\n\r\n"
}

splice_supported() -> int {
    return 1
}

splice_blocker() -> string {
    return ""
}

// Copy one binary-safe chunk from `src` to `dst`. The caller owns the loop and
// directionality: a CONNECT tunnel runs one pump per direction until EOF/error.
// Returns (bytes_written, err); EOF/receive failure is surfaced from std.tcp.
relay_once(src: ptr, dst: ptr, max_bytes: int) -> {
    data, n, rerr = read_n(src, max_bytes)
    if string_length(rerr) > 0 {
        return 0, rerr
    }
    if n <= 0 {
        return 0, "eof"
    }
    wrote, werr = write_all(dst, data, n)
    return wrote, werr
}

// Full-duplex opaque splice between two connected sockets (the CONNECT-tunnel
// data plane). Waits on BOTH sides at once with std.tcp.poll2 (#1092), services
// whichever direction is readable, and pumps until one side sends FIN or a hard
// error. This replaces the half-duplex alternating pump: neither direction has
// to speak before the other, so server-speaks-first / both-streaming protocols
// (WebSocket-over-CONNECT, gRPC streaming, TLS renegotiation) relay correctly.
//
// The #1092 timeout sentinel is load-bearing: read_n on a quiet-but-alive peer
// returns ("", 0, "timeout") and leaves the socket connected — we must re-poll,
// NOT tear the tunnel down. Only "" (orderly FIN) or a non-"timeout" error is
// terminal. `poll_ms` bounds each wait so neither a dead poll nor a wholly idle
// tunnel spins; -1 would block forever with no way to notice a half-close.
// Returns "" on clean teardown (either FIN), or the first transport error seen.
splice(a: ptr, b: ptr, max_bytes: int, poll_ms: int) -> string {
    while 1 == 1 {
        a_ready, b_ready, perr = poll2(a, b, poll_ms)
        if string_length(perr) > 0 {
            return perr
        }
        if a_ready == true {
            done, err = _pump_one(a, b, max_bytes)
            if done == 1 {
                return err
            }
        }
        if b_ready == true {
            done, err = _pump_one(b, a, max_bytes)
            if done == 1 {
                return err
            }
        }
    }
    return ""
}

// Move one ready chunk src->dst. Returns (terminal, err): terminal=1 means the
// splice should stop — "" for an orderly FIN, or the transport error otherwise.
// A "timeout" read is NOT terminal (poll said readable but the byte was consumed
// by a racing path, or a spurious wakeup): report not-done so the caller re-polls.
_pump_one(src: ptr, dst: ptr, max_bytes: int) -> {
    data, n, rerr = read_n(src, max_bytes)
    if string_length(rerr) > 0 {
        if rerr == "timeout" {
            return 0, ""
        }
        return 1, rerr
    }
    if n <= 0 {
        return 1, ""
    }
    wrote, werr = write_all(dst, data, n)
    if string_length(werr) > 0 {
        return 1, werr
    }
    return 0, ""
}

// std.tcp.write_n may legally perform a partial write. Loop until the requested
// prefix has been accepted or the transport refuses progress.
write_all(sock: ptr, data: string, length: int) -> {
    if length <= 0 {
        return 0, ""
    }
    off = 0
    while off < length {
        chunk = string_substring(data, off, length)
        n, err = write_n(sock, chunk, length - off)
        if string_length(err) > 0 {
            return off, err
        }
        if n <= 0 {
            return off, "short write"
        }
        off = off + n
    }
    return off, ""
}

_first_line(req: string) -> string {
    crlf = string_index_of(req, "\r\n")
    if crlf >= 0 {
        return string_substring(req, 0, crlf)
    }
    lf = string_index_of(req, "\n")
    if lf >= 0 {
        return string_substring(req, 0, lf)
    }
    return req
}

_all_digits(s: string) -> int {
    n = string_length(s)
    if n == 0 {
        return 0
    }
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c < 48 {
            return 0
        }
        if c > 57 {
            return 0
        }
        i = i + 1
    }
    return 1
}

_trim(s: string) -> string {
    n = string_length(s)
    lo = 0
    while lo < n {
        c = string_char_at(s, lo)
        if c != 32 { if c != 10 { if c != 13 { if c != 9 { break } } } }
        lo = lo + 1
    }
    hi = n
    while hi > lo {
        c = string_char_at(s, hi - 1)
        if c != 32 { if c != 10 { if c != 13 { if c != 9 { break } } } }
        hi = hi - 1
    }
    return string_substring(s, lo, hi)
}
