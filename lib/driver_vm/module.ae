// lib/driver_vm — VM backends: bhyve (FreeBSD) and kvm/qemu (Linux).
//
// The VM arm of the driver split. Same contract as the jail/container
// drivers — idempotent up/down + a liveness probe, all shelling
// os.run_capture — but the resource is a full virtual machine.
//
// VMs differ from jails/containers in how liveness is checked: there is no
// in-guest `jexec`/`docker exec` without guest cooperation. So the probe is
// HOST-SIDE, two-layer (fits the containment model — the container probes
// the contained from outside):
//   1. the hypervisor process is alive (we record a pidfile on spawn);
//   2. if `health` is set, that command runs ON THE HOST (e.g.
//      `nc -z <ip> 22` / `curl -fsS http://<ip>/`) — reachability INTO the
//      guest, not a command run inside it.
//
//   up    — if the pidfile names a live process, no-op; else spawn the
//           hypervisor in the background and record its pid.
//   down  — kill the pid (bhyve: also `bhyvectl --destroy`); absent == ok.
//   probe — (int) 1 if the pid is alive AND (no health, or the host-side
//           health command exits 0).
//
// bhyve (FreeBSD): boots a disk image via UEFI bootrom — no bhyveload step,
//   so any UEFI-bootable image works. Needs vmm.ko loaded + a bootrom
//   (pkg bhyve-firmware → /usr/local/share/uefi-firmware/BHYVE_UEFI.fd).
//   Networking via a tap added to a bridge (operator/provision sets the
//   bridge up; aeo names the tap).
// kvm (Linux): boots via qemu-system-x86_64 with -enable-kvm. Coded but
//   untested here (no qemu installed on the dev box); exercised on a host
//   with the full Linux VM landscape.

import std.os (run_capture, os_which, getenv)
import std.list
import std.string (string_length, string_char_at, string_substring, string_contains, string_from_char, string_index_of)

exports (
    name,
    up, bhyve_up, guest_container_up, agent_delegate, agent_status, build_agent_seed, exec_capture, down, probe,
    bhyve_argv, qemu_argv, bhyvectl_destroy_argv,
    pidfile_for, bootrom_path
)

name() -> string {
    return "vm"
}

// Where a VM's pidfile lives. The pidfile is how up/down/probe across
// separate aeo invocations find the running hypervisor process.
pidfile_for(res_name: string) -> string {
    return "/tmp/aeo-vm-${res_name}.pid"
}

// Canonical bhyve UEFI bootrom (pkg bhyve-firmware). Overridable later via
// a setter; this is the default probe path.
bootrom_path() -> string {
    return "/usr/local/share/uefi-firmware/BHYVE_UEFI.fd"
}

// --- pure argv builders ----------------------------------------------

// bhyve VM. UEFI boot of `image` (a raw/UEFI-bootable disk), `cpus` vCPUs,
// `mem` RAM (e.g. "2G"), `tap` NIC (a tap device on a host bridge; "" =
// no NIC). Runs in the foreground; the caller backgrounds it.
//   bhyve -c CPUS -m MEM -A -H -P -l bootrom,UEFI.fd \
//         -s 0,hostbridge -s 31,lpc \
//         -s 4,virtio-blk,IMAGE [-s 5,virtio-net,TAP] NAME
bhyve_argv(res_name: string, image: string, cpus: int, mem: string, tap: string) -> ptr {
    av = list_new()
    list_add(av, "-c")
    list_add(av, _itoa(cpus))
    list_add(av, "-m")
    list_add(av, mem)
    list_add(av, "-A")
    list_add(av, "-H")
    list_add(av, "-P")
    list_add(av, "-l")
    list_add(av, "bootrom,${bootrom_path()}")
    list_add(av, "-s")
    list_add(av, "0,hostbridge")
    list_add(av, "-s")
    list_add(av, "31,lpc")
    list_add(av, "-s")
    list_add(av, "4,virtio-blk,${image}")
    if string_length(tap) > 0 {
        list_add(av, "-s")
        list_add(av, "5,virtio-net,${tap}")
    }
    list_add(av, res_name)
    return av
}

// `bhyvectl --vm=NAME --destroy` — tear down the kernel VM object after
// the bhyve process exits (bhyve leaves the /dev/vmm/NAME object behind).
bhyvectl_destroy_argv(res_name: string) -> ptr {
    av = list_new()
    list_add(av, "--vm=${res_name}")
    list_add(av, "--destroy")
    return av
}

// qemu/kvm VM (Linux). Coded, untested on this box.
//   qemu-system-x86_64 -enable-kvm -name NAME -smp CPUS -m MEM \
//       -drive file=IMAGE,if=virtio -display none -daemonize \
//       -pidfile PIDFILE [-nic tap,ifname=TAP,script=no]
qemu_argv(res_name: string, image: string, cpus: int, mem: string, tap: string, pidfile: string) -> ptr {
    av = list_new()
    list_add(av, "-enable-kvm")
    list_add(av, "-name")
    list_add(av, res_name)
    list_add(av, "-smp")
    list_add(av, _itoa(cpus))
    list_add(av, "-m")
    list_add(av, mem)
    list_add(av, "-drive")
    list_add(av, "file=${image},if=virtio")
    list_add(av, "-display")
    list_add(av, "none")
    list_add(av, "-daemonize")
    list_add(av, "-pidfile")
    list_add(av, pidfile)
    // Cloud-init SEED drive (agent path): when the guest is provisioned with a
    // NoCloud seed ISO (which couriers the agent's secret/port + starts it),
    // attach it as a cdrom. AEO_SEED_<res_name> | AEO_SEED gives the path; empty
    // = no seed (bare-disk boot, the pre-agent behaviour).
    seed = _agent_seed(res_name)
    if string_length(seed) > 0 {
        list_add(av, "-drive")
        list_add(av, "file=${seed},if=virtio,media=cdrom")
    }
    // Networking: a tap (nic("tapN")) needs root/CAP_NET_ADMIN to create the
    // device — for ROOTLESS qemu (e.g. an unprivileged Bazzite user) that fails
    // with "could not configure /dev/net/tun: Operation not permitted". When no
    // tap is given, fall back to `-nic user` (SLIRP user-mode): no tap, no root,
    // NAT'd egress + host->guest via hostfwd. tap is the privileged/bridged path.
    if string_length(tap) > 0 {
        list_add(av, "-nic")
        list_add(av, "tap,ifname=${tap},script=no")
    } else {
        // Agent path: forward a host port to the guest's in-agent :9450 so the
        // host can dial the resident agent (host:<hostport> -> guest:9450). The
        // host port is AEO_AGENT_PORT_<res_name> | AEO_AGENT_PORT; 0/unset = a
        // plain user NIC (no agent forward, the pre-agent behaviour).
        hp = _agent_hostport(res_name)
        if hp > 0 {
            // also forward ssh (agent-port + 1000) for operator debugging of the
            // guest — the seed bakes the operator's pubkey.
            sp = hp + 1000
            list_add(av, "-netdev")
            list_add(av, "user,id=n0,hostfwd=tcp::${_itoa(hp)}-:9450,hostfwd=tcp::${_itoa(sp)}-:22")
            list_add(av, "-device")
            list_add(av, "virtio-net-pci,netdev=n0")
        } else {
            list_add(av, "-nic")
            list_add(av, "user")
        }
    }
    return av
}

// Agent-courier reads (boot side of the agent path). Per-VM override then the
// shared var; empty/0 = pre-agent bare boot. (getenv-null footgun: guard on
// length, never == "".)
//
// Per-VM env keys embed the node name — but shell env var names can't contain
// hyphens (AEO_AGENT_PORT_vm-auto2 is not a valid var, the shell rejects it). So
// sanitize the name to [A-Za-z0-9_] (hyphen -> underscore) before building the
// key. (This bit the first _up_kvm auto-boot test: a hyphenated VM name silently
// dropped its per-VM env.)
_envkey(prefix: string, name: string) -> string {
    safe = ""
    n = string_length(name)
    i = 0
    while i < n {
        c = string_char_at(name, i)
        ok = 0
        if c >= 48 { if c <= 57 { ok = 1 } }        // 0-9
        if c >= 65 { if c <= 90 { ok = 1 } }        // A-Z
        if c >= 97 { if c <= 122 { ok = 1 } }       // a-z
        if c == 95 { ok = 1 }                        // _
        if ok == 1 {
            safe = "${safe}${string_from_char(c)}"
        } else {
            safe = "${safe}_"
        }
        i = i + 1
    }
    return "${prefix}${safe}"
}
_agent_seed(res_name: string) -> string {
    v = getenv(_envkey("AEO_SEED_", res_name))
    if string_length(v) > 0 {
        return v
    }
    v = getenv("AEO_SEED")
    if string_length(v) > 0 {
        return v
    }
    // Deterministic path build_agent_seed writes to; present iff _up_kvm built it
    // for the agent path. Return it only if the file actually exists.
    p = "/tmp/aeo-seed-${res_name}.iso"
    if _file_exists(p) == 1 {
        return p
    }
    return ""
}
_file_exists(p: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "test -f ${p} && echo yes")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 1 {
        return 1
    }
    return 0
}
// Driver-side courier reads (mirror the runner's, so the driver is standalone).
_agent_path_on_drv() -> int {
    v = getenv("AEO_AGENT_PATH")
    if string_length(v) == 0 {
        return 0
    }
    return 1
}
_agent_token_drv(res_name: string) -> string {
    v = getenv(_envkey("AEO_TOKEN_", res_name))
    if string_length(v) > 0 {
        return v
    }
    return getenv("AEO_TOKEN")
}
// The aeo-agent binary to plant. AEO_AGENT_BIN, else a couple of well-known
// build outputs relative to the aeo home.
_agent_binary() -> string {
    v = getenv("AEO_AGENT_BIN")
    if string_length(v) > 0 {
        return v
    }
    c1 = "${_aeo_home()}/out/aeo-agent"
    if _file_exists(c1) == 1 {
        return c1
    }
    c2 = "${_aeo_home()}/aeo-agent"
    if _file_exists(c2) == 1 {
        return c2
    }
    return ""
}
// An ssh pubkey to bake into the guest for debug access (optional).
_guest_pubkey() -> string {
    p = "${_home()}/.ssh/id_rsa.pub"
    av = list_new()
    list_add(av, "-c")
    list_add(av, "cat ${p} 2>/dev/null | tr -d '\\n'")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    return out
}
_agent_hostport(res_name: string) -> int {
    v = getenv(_envkey("AEO_AGENT_PORT_", res_name))
    if string_length(v) == 0 {
        v = getenv("AEO_AGENT_PORT")
    }
    if string_length(v) == 0 {
        return 0
    }
    return _atoi(v)
}
// 1 iff the resident agent answers /health on the forwarded port (curl -f -> the
// health endpoint returns 200). The orchestration-liveness of an agent-path VM.
_agent_health(hostport: int) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "curl -fsS --max-time 3 http://127.0.0.1:${_itoa(hostport)}/health >/dev/null 2>&1 && echo ok")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "ok") == 1 {
        return 1
    }
    return 0
}

// Build a NoCloud seed ISO that couriers the agent into the guest and starts it.
// The seed carries: meta-data, user-data (cloud-config), and the agent BINARY as
// a plain file on the ISO. cloud-init's runcmd mounts the seed, copies the agent
// out, and launches it with the couriered secret/port env — the bank-courier
// bootstrap, automated. Returns the seed path ("" on failure); the caller sets
// AEO_SEED_<res_name> to it before qemu_argv boots the guest.
//
//   res_name  — the VM/node name (becomes AEO_NODE inside the guest)
//   token     — the couriered secret (AEO_TOKEN in-guest)
//   agent_bin — host path to the aeo-agent binary to plant
//   ssh_key   — an authorized_keys entry (for debug ssh); "" = none
build_agent_seed(res_name: string, token: string, agent_bin: string, ssh_key: string) -> string {
    seed_dir = "/tmp/aeo-seed-${res_name}"
    iso = "/tmp/aeo-seed-${res_name}.iso"
    // user-data: cloud-config that plants + starts the agent from the seed's
    // second file. The agent runs as node=<res_name>, http on :9450, bound
    // 0.0.0.0 (reachable from the host across the VM NIC), NOOP boots for the
    // proof. runcmd mounts the cidata iso (/dev/v... — cloud-init already read it,
    // but we re-read the plain file it also placed at /var/lib/cloud seed dir).
    kline = ""
    if string_length(ssh_key) > 0 {
        kline = "ssh_authorized_keys:\n  - ${ssh_key}\n"
    }
    // The agent binary is placed on the ISO as `aeo-agent`; NoCloud mounts the
    // seed and cloud-init copies files from its dir. We reference it via the
    // well-known cidata mount cloud-init leaves, then start it.
    sh = list_new()
    list_add(sh, "-c")
    // The runcmd STARTS THE AGENT FIRST (so the runner's health-gate sees it
    // quickly), then installs podman IN THE BACKGROUND. podman is only needed at
    // delegate time (the agent's _ensure_child_container waits/retries for it), so
    // it must NOT block agent start — installing it via cloud-init `packages:`
    // (which runs before runcmd) delayed the agent past the health budget and the
    // VM was declared failed. Background apt keeps the agent's start immediate.
    list_add(sh, "set -e; rm -rf ${seed_dir}; mkdir -p ${seed_dir}; printf 'instance-id: ${res_name}\\nlocal-hostname: ${res_name}\\n' > ${seed_dir}/meta-data; printf '#cloud-config\\npassword: aeo\\nchpasswd: { expire: false }\\nssh_pwauth: true\\n${kline}runcmd:\\n  - [ sh, -c, \"m=/mnt/aeoseed; mkdir -p $m; mount /dev/sr0 $m 2>/dev/null || mount /dev/vdb $m 2>/dev/null || true; cp $m/aeo-agent /usr/local/bin/aeo-agent; chmod +x /usr/local/bin/aeo-agent; AEO_TRANSPORT=http AEO_PORT=9450 AEO_NODE=${res_name} AEO_TOKEN=${token} AEO_BIND=0.0.0.0 AEO_BOOT_NOOP=1 setsid /usr/local/bin/aeo-agent >/var/log/aeo-agent.log 2>&1 & ( DEBIAN_FRONTEND=noninteractive apt-get update -qq && DEBIAN_FRONTEND=noninteractive apt-get install -y -qq podman ) >/var/log/aeo-podman-install.log 2>&1 &\" ]\\n' > ${seed_dir}/user-data; cp ${agent_bin} ${seed_dir}/aeo-agent; mkisofs -o ${iso} -V cidata -J -r ${seed_dir}/meta-data ${seed_dir}/user-data ${seed_dir}/aeo-agent 2>/dev/null")
    out, status, err = run_capture("/bin/sh", sh, null)
    list_free(sh)
    if status != 0 {
        return ""
    }
    return iso
}

// --- exec'ing entry points -------------------------------------------

// Bring the VM up idempotently. `kind` is "bhyve" or "kvm". `image` is the
// disk; `cpus`/`mem` size it; `tap` is the host NIC ("" for none).
// Returns "" on success else an error message.
up(kind: string, res_name: string, image: string, cpus: int, mem: string, tap: string) -> string {
    // bhyve has its own entry (bhyve_up — provisions via vm-bhyve from the
    // guest declaration); this generic up() handles kvm (qemu).
    if kind == "kvm" {
        if string_length(image) == 0 {
            return "aeo: vm '${res_name}' has no image() set"
        }
        return _up_kvm(res_name, image, cpus, mem, tap)
    }
    return "aeo: vm '${res_name}' has unknown kind '${kind}'"
}

// bhyve via vm-bhyve, provisioning-if-absent from the guest declaration.
// config IS code down into the VM: the operator declares guest_image /
// network / ssh_key on the bhyve_vm block, and aeo realizes them as
//   vm img <url>                                    (fetch base image once)
//   vm create -t linux -i <img> -C -k <key> -n <net> <name>   (if absent)
//   vm start <name>
// vm-bhyve owns tap/disk/boot/networking; aeo orchestrates it like podman.
// `vm` needs root, so it runs under sudo (operator pre-authorizes; see the
// NOPASSWD sudoers note). Idempotent: existing+running VM is a no-op.
bhyve_up(res_name: string, guest_image: string, realize_target: string, guest_ip: string, cpus: int, mem: string, network: string, ssh_key: string) -> string {
    if _bhyve_running(res_name) == 1 {
        return ""
    }
    // Provision if the VM doesn't exist yet. FAST PATH: the image recipe's
    // realize_as("clone:<snap>") names a prepared golden snapshot (the runner
    // resolves it + passes it as realize_target). If that snapshot exists,
    // CLONE it (ZFS copy-on-write, ~seconds, boots an already-warm guest — no
    // cloud-init stall, no apt, no image pull). Else full-provision from the
    // raw cloud image (the slow cold-cache path; the recipe's build steps are
    // the declarative ancestor of that). realize_target "" falls back to the
    // legacy aeo-base@golden default for back-compat.
    if _bhyve_exists(res_name) == 0 {
        tgt = realize_target
        if string_length(tgt) == 0 {
            tgt = "aeo-base@golden"
        }
        if _snapshot_exists(tgt) == 1 {
            cerr = _bhyve_clone_from(res_name, tgt)
            if cerr != "" {
                return cerr
            }
        } else {
            perr = _bhyve_provision(res_name, guest_image, ssh_key, network, cpus, mem)
            if perr != "" {
                return perr
            }
        }
    }
    // Before first boot, give the guest its STATIC IP (guest_ip, resolved per
    // VM by ipam — no longer a single hardcoded .50) by writing a valid netplan
    // directly into its disk. Sidesteps the bridge DHCP-broadcast issue + the
    // cloud-init-schema trap. Idempotent. (Best-effort: if the helper isn't
    // present we still try to boot + wait.)
    _apply_static_ip(res_name, guest_ip)
    started = _vm_ok("start", res_name)
    if started == 0 {
        out = _vm_out("start", res_name)
        if string_contains(out, "already running") == 0 {
            return "aeo: 'vm start ${res_name}' failed: ${out}"
        }
    }
    // DETACHED bring-up under the agent path: the engine's readiness poller gates
    // on the guest agent's /health (see probe — IP-independent), so we RETURN NOW
    // and let sibling VMs in the same level boot CONCURRENTLY instead of blocking
    // each guest's ~130s boot serially. On the legacy (no-agent) path, probe can't
    // confirm ssh-reachability without the guest IP, so we still block here until
    // the guest answers on ssh (so a nested child isn't delegated before the guest
    // is reachable).
    if _agent_path_on_drv() == 1 {
        return ""
    }
    if _wait_guest_ready(guest_ip) == 0 {
        return "aeo: vm '${res_name}' started but never became ssh-reachable at ${guest_ip} (boot/network?)"
    }
    return ""
}

// 1 if the AMD-patched image exists in the vm-bhyve image store.
_amd_image_present() -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "[ -f /zroot/vm/.img/jammy-amd.img ] && echo yes")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 1 {
        return 1
    }
    return 0
}

// Apply the clean static-IP netplan to the VM's disk (proven reliable path).
// Best-effort via test/patch-static-ip.sh; the script stops the VM, writes
// /etc/netplan/99-aeo-static.yaml, and is a no-op if already patched.
_apply_static_ip(res_name: string, guest_ip: string) -> int {
    av = list_new()
    list_add(av, "-c")
    // The script self-sudoes each privileged op (no /bin/sh NOPASSWD), so we
    // invoke it as the normal user. A marker file makes it idempotent
    // (skip if already patched this VM). guest_ip is ipam-resolved per VM.
    list_add(av, "S=${_aeo_home()}/test/patch-static-ip.sh; M=/tmp/aeo-staticip-${res_name}.done; if [ -f \"$S\" ] && [ ! -f \"$M\" ]; then sh \"$S\" ${res_name} ${guest_ip} >/dev/null 2>&1 && touch \"$M\"; fi; true")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    return 1
}

// Wait until the guest answers ssh at its (resolved) IP. ~5min budget (boot
// ~130s + sshd). Returns 1 if reachable, 0 on timeout.
_wait_guest_ready(guest_ip: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "for i in $(seq 1 40); do nc -z -w2 ${guest_ip} 22 2>/dev/null && { echo ready; break; }; sleep 8; done")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "ready") == 1 {
        return 1
    }
    return 0
}

// aeo's home (where test/ scripts live) — AEO_HOME, else the repo default.
// The operator's home dir (for ssh keys etc.) — $HOME, so a colleague's
// checkout works without editing source. Falls back to "" only if HOME is unset.
_home() -> string {
    return getenv("HOME")
}
_aeo_home() -> string {
    h = getenv("AEO_HOME")
    if string_length(h) > 0 {
        return h
    }
    return "${_home()}/aeo"
}

// Bring a nested container up via the guest's RESIDENT aeo-agent — the
// containment-correct path that REPLACES guest_container_up's ssh-into-the-guest.
// The host does NOT reach into the guest; it sends a `delegate` to the agent
// already living inside the VM (over the guest's forwarded agent port), and the
// agent runs the child locally and reports back. Proven end-to-end on real KVM:
// test/real-nested-vm-container.sh (host -> VM-agent -> container-agent).
//
//   host_vm — the VM name (get_host of the nested node); used to resolve the
//             guest's forwarded agent endpoint (127.0.0.1:<agent-port>).
//   child   — the nested node's name (what the agent delegates + reports on).
//   token   — the couriered secret (bank-courier auth); "" = open (dev).
//   port    — the host-side forwarded port to the guest agent's :9450.
// Returns "" on success (agent reported the child up), else an error string.
// Drivers shell out (LLM.md), so this dials via curl rather than the in-process
// transport_http client.
agent_delegate(host_vm: string, child: string, token: string, port: int) -> string {
    base = "http://127.0.0.1:${_itoa(port)}"
    // ASYNC: `delegate` returns fast (the agent fires the child bring-up in the
    // background and replies `pending`), so we DON'T block on it. Then we POLL
    // `status <child>` until the child reports up — a cold bring-up (podman
    // install + image pull) can take minutes, which is why it can't be one
    // synchronous request. Bounded overall budget.
    del = _agent_post(base, "delegate ${token} ${child}")
    if string_contains(del, "report") == 0 {
        return "aeo: guest '${host_vm}' agent refused/failed delegate '${child}': '${del}'"
    }
    // poll status (~10min budget: cold apt podman ~2min + image pull + retries)
    tries = 0
    while tries < 300 {
        st = _agent_post(base, "status ${token} ${child}")
        if string_contains(st, " up") == 1 {
            return ""                        // child is up
        }
        if string_contains(st, " failed") == 1 {
            return "aeo: nested node '${child}' failed in guest '${host_vm}'"
        }
        _sleep_s(2)
        tries = tries + 1
    }
    return "aeo: nested node '${child}' did not come up in guest '${host_vm}' (timeout)"
}
// One-shot health probe of a nested node via the guest's agent `status` verb.
// Returns 1 if the child reports up, else 0. Used by the runner's driver_probe
// for agent-path nested containers (a host podman probe can't see them).
agent_status(host_vm: string, child: string, token: string, port: int) -> int {
    base = "http://127.0.0.1:${_itoa(port)}"
    st = _agent_post(base, "status ${token} ${child}")
    if string_contains(st, " up") == 1 {
        return 1
    }
    return 0
}
// POST a protocol line to the agent's /dispatch, return the reply body ("" on
// error). Shared by delegate + status polling.
_agent_post(base: string, body: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "curl -sS --max-time 10 -X POST --data ${_shquote(body)} ${base}/dispatch")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return ""
    }
    return out
}
_sleep_s(n: int) {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sleep ${_itoa(n)}")
    o, s, e = run_capture("/bin/sh", av, null)
    list_free(av)
}

// Bring a container UP INSIDE a guest VM (the nested-execution wire). The
// runner calls this for a `container` whose get_host() is a bhyve VM: aeo
// reaches into the running guest over ssh, writes the inline Dockerfile,
// builds it with podman, and runs it with the port published — so the
// service runs in the guest and is reachable from the host at <guest-ip>:<port>.
// This is what makes `aeo up <dsl>` do the real convergence (vs a shell
// script): the DSL's nested container actually executes in the VM.
// SUPERSEDED for the agent path by agent_delegate (above) — kept for the bhyve
// ssh path until that's migrated too.
//
//   host_vm    — the VM name (get_host of the container); used to find its IP
//   name       — the container/app name
//   dockerfile — the inline Dockerfile text (from dockerfile()); "" = none
//   image      — a stock image ref (from image()), used when no dockerfile
//   expose     — the port to publish (from expose()); 0 = none
// Either dockerfile (build it) OR image (pull+run a stock image, e.g. the
// redis db tier) — dockerfile wins if both are set.
guest_container_up(host_vm: string, host_ip: string, name: string, dockerfile: string, entrypoint: string, base: string, image: string, expose: int) -> string {
    ip = _guest_ip(host_vm, host_ip)
    if ip == "" {
        return "aeo: guest VM '${host_vm}' has no reachable IP (booted+networked?) for container '${name}'"
    }
    // Run with host networking so the tiers share the guest's localhost:
    // db (redis) publishes 6379 on the guest, and app reaches it at
    // 127.0.0.1:6379. expose()'d ports land directly on the guest's network,
    // so the host's curl to <guest-ip>:<port> works without -p mapping.
    net = "--network host"
    // Three shapes:
    //   entrypoint — write the program to app.py in the build context + a
    //                synthesized COPY-based Dockerfile (readable; builds on any
    //                podman, unlike a RUN heredoc). PREFERRED for one-script svcs.
    //   dockerfile — the operator's full inline Dockerfile.
    //   image      — pull + run a stock image (e.g. redis).
    run_part = ""
    if string_length(entrypoint) > 0 {
        // app.py written verbatim from the clean heredoc; the Dockerfile just
        // COPYs it — no printf, no escaping, no RUN heredoc.
        df = "FROM ${base}\nCOPY app.py /app.py\nCMD [\"python\", \"/app.py\"]"
        run_part = "mkdir -p /home/ubuntu/ctx-${name} && cat > /home/ubuntu/ctx-${name}/app.py <<'AEOPY'\n${entrypoint}\nAEOPY\ncat > /home/ubuntu/ctx-${name}/Dockerfile <<'AEODF'\n${df}\nAEODF\ncd /home/ubuntu/ctx-${name} && podman build -t aeo-${name} . >/dev/null 2>&1 && podman rm -f ${name} >/dev/null 2>&1; podman run -d --name ${name} ${net} aeo-${name} >/dev/null"
    } else {
        if string_length(dockerfile) > 0 {
            run_part = "cat > /home/ubuntu/Dockerfile.${name} <<'AEOEOF'\n${dockerfile}\nAEOEOF\ncd /home/ubuntu && podman build -t aeo-${name} -f Dockerfile.${name} . >/dev/null 2>&1 && podman rm -f ${name} >/dev/null 2>&1; podman run -d --name ${name} ${net} aeo-${name} >/dev/null"
        } else {
            if string_length(image) == 0 {
                return "aeo: container '${name}' in guest '${host_vm}' has no entrypoint(), dockerfile(), or image()"
            }
            run_part = "podman rm -f ${name} >/dev/null 2>&1; podman run -d --name ${name} ${net} ${image} >/dev/null"
        }
    }
    remote = "set -e; ${run_part}"
    av = list_new()
    list_add(av, "-c")
    list_add(av, "ssh -i ${_guest_key()} -o StrictHostKeyChecking=no -o ConnectTimeout=10 ubuntu@${ip} ${_shquote(remote)}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return "aeo: building/running container '${name}' inside guest '${host_vm}' (${ip}) failed: ${out}"
    }
    return ""
}

// exec_capture — run `cmd` inside a bhyve guest over ssh, return its stdout ("" on
// any failure / unreachable guest). The VM arm of `aeo exec <node> <cmd>`; reuses
// the same ssh-in path guest_container_up uses (resolved IP + the guest key).
exec_capture(host_vm: string, host_ip: string, cmd: string) -> string {
    ip = _guest_ip(host_vm, host_ip)
    if ip == "" {
        return ""
    }
    av = list_new()
    list_add(av, "-c")
    list_add(av, "ssh -i ${_guest_key()} -o StrictHostKeyChecking=no -o ConnectTimeout=10 ubuntu@${ip} ${_shquote(cmd)}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if err != "" {
        return ""
    }
    if status != 0 {
        return ""
    }
    return out
}

// The guest VM's IP. Prefers the cloud-init static IP convention
// (172.16.0.50 on the NAT net); falls back to an ARP/lease lookup by the
// VM's MAC. Returns "" if not found.
// Resolve the guest's reachable IP. Prefer the ipam-resolved host_ip (the
// binding bhyve_up assigned this VM); if that doesn't answer ssh, fall back to
// a MAC->arp/lease lookup. So multiple VMs each resolve to their OWN address.
_guest_ip(host_vm: string, host_ip: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "if nc -z -w2 ${host_ip} 22 2>/dev/null; then echo ${host_ip}; else MAC=$(grep -o 'network0_mac=\"[^\"]*\"' /zroot/vm/${host_vm}/${host_vm}.conf 2>/dev/null | cut -d'\"' -f2); ping -c1 -W1 172.16.0.255 >/dev/null 2>&1; arp -an 2>/dev/null | grep -i \"$MAC\" | grep -oE '172.16.0.[0-9]+' | head -1; fi")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    return _first_line(out)
}

_guest_key() -> string {
    k = getenv("AEO_SSH_KEY")
    if string_length(k) > 0 {
        return k
    }
    return "${_home()}/.ssh/id_rsa"
}

// First non-empty line of s, trimmed of a trailing newline.
_first_line(s: string) -> string {
    out = ""
    i = 0
    n = string_length(s)
    while i < n {
        c = string_char_at(s, i)
        if c == 10 {
            if string_length(out) > 0 {
                return out
            }
        } else {
            out = "${out}${string_from_char(c)}"
        }
        i = i + 1
    }
    return out
}

// Minimal single-quote shell-quoting: wrap in single quotes, escaping any
// embedded single quote as '\''.
_shquote(s: string) -> string {
    out = "'"
    i = 0
    n = string_length(s)
    while i < n {
        c = string_char_at(s, i)
        if c == 39 {
            out = "${out}'\\''"
        } else {
            out = "${out}${string_from_char(c)}"
        }
        i = i + 1
    }
    return "${out}'"
}

// 1 if vm-bhyve knows this VM (it's in `vm list`), else 0.
_bhyve_exists(res_name: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo -n vm list 2>/dev/null | awk -v n=${res_name} 'NR>1 && $1==n {print \"yes\"}'")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 1 {
        return 1
    }
    return 0
}

// 1 if a prepared golden base snapshot (aeo-base@golden) exists.
_golden_exists() -> int {
    return _snapshot_exists("aeo-base@golden")
}

// 1 if a given ZFS snapshot (e.g. "aeo-base@golden") exists. The recipe's
// realize_as("clone:<snap>") target is checked here.
_snapshot_exists(snap: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo -n zfs list -t snapshot 2>/dev/null | grep -q ' ${snap}\\|/${snap}\\|^${snap}' && echo yes || (sudo -n vm snapshot 2>/dev/null | grep -q '${snap}' && echo yes)")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 1 {
        return 1
    }
    return 0
}

// COLD PATH — build a clean golden from the recipe when the realize target is
// absent, then snapshot it so future clones are fast. Called by the runner
// (which has the recipe data). install_csv is comma-joined packages; units_csv
// is comma-joined systemd unit names with bodies looked up by the runner and
// passed pre-rendered in unit_writes (shell that writes+enables them).
// snap_target is the realize target to snapshot as (e.g. "aeo-base@golden").
//
// The sequence is what the on-box diagnosis proved is needed for a WORKING,
// CLONE-SAFE golden:
//   1. apt install the packages
//   2. load `overlay` at boot (podman's storage driver needs it; the broken
//      hand-made golden failed here)
//   3. write the systemd units (the runner pre-renders them)
//   4. CLEAN shutdown — the broken golden's aborted-ext4-journal (-> RO fs ->
//      overlay can't init) came from snapshotting an UNCLEAN guest. Halt and
//      wait for poweroff BEFORE snapshotting so the journal is consistent.
//   5. snapshot as snap_target.
bhyve_realize_cold(builder_vm: string, builder_ip: string, install_csv: string, unit_writes: string, snap_target: string) -> string {
    // The guest is already provisioned + booted + ssh-reachable at the static
    // IP (the caller did _bhyve_provision + _apply_static_ip + start + wait).
    apply = "set -e\n"
    apply = "${apply}export DEBIAN_FRONTEND=noninteractive\n"
    if string_length(install_csv) > 0 {
        // install_csv is "podman, foo" -> apt wants spaces; commas are fine to
        // strip to spaces.
        pkgs = _csv_to_spaces(install_csv)
        apply = "${apply}sudo apt-get update -qq && sudo apt-get install -y -qq ${pkgs}\n"
    }
    // overlay at boot (the fix the broken golden was missing)
    apply = "${apply}echo overlay | sudo tee /etc/modules-load.d/aeo.conf >/dev/null\n"
    apply = "${apply}sudo modprobe overlay\n"
    // hostname resolution (silence the sudo warning every command hit)
    apply = "${apply}grep -q aeo-guest /etc/hosts || echo '127.0.1.1 aeo-guest' | sudo tee -a /etc/hosts >/dev/null\n"
    if string_length(unit_writes) > 0 {
        apply = "${apply}${unit_writes}\n"
    }
    // verify podman actually works with overlay before we bless this golden
    apply = "${apply}sudo podman info --format '{{.Store.GraphDriverName}}' >/dev/null\n"

    rerr = _guest_ssh_script(builder_ip, apply)
    if rerr != "" {
        return "aeo: cold-realize: applying recipe in '${builder_vm}' failed: ${rerr}"
    }
    // CLEAN shutdown — critical: snapshot only a quiesced fs (else aborted
    // journal -> RO -> overlay broken, the exact bug we diagnosed).
    _guest_ssh_script(builder_ip, "sudo sync; sudo systemctl poweroff &")
    if _wait_vm_stopped(builder_vm) == 0 {
        // force it off if it didn't halt cleanly in time
        _vm_ok("poweroff", builder_vm)
    }
    // snapshot as the realize target
    serr = _snapshot_as(builder_vm, snap_target)
    if serr != "" {
        return serr
    }
    return ""
}

// run a multi-line shell script inside the guest (at ip) over ssh; "" on success.
_guest_ssh_script(ip: string, script: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "ssh -i ${_guest_key()} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 ubuntu@${ip} ${_shq(script)}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return out
    }
    return ""
}

// poll until the VM is Stopped (clean poweroff), up to ~60s. 1 if stopped.
_wait_vm_stopped(vm: string) -> int {
    i = 0
    while i < 20 {
        i = i + 1
        out = _vm_out("list", "")
        if string_contains(out, "${vm} ") == 1 {
            // crude: re-list and check state column for Stopped
        }
        if _bhyve_running(vm) == 0 {
            return 1
        }
        _sleep(3)
    }
    return 0
}

// snapshot a stopped VM as <vm>@<tag> derived from snap_target.
_snapshot_as(vm: string, snap_target: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo -n vm snapshot ${snap_target} 2>&1")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return "aeo: snapshot '${snap_target}' failed: ${out}"
    }
    return ""
}

_csv_to_spaces(csv: string) -> string {
    // "a, b, c" -> "a b c" (commas to spaces; collapse handled by shell)
    out = ""
    n = string_length(csv)
    i = 0
    while i < n {
        c = string_char_at(csv, i)
        if c == 44 {
            out = "${out} "
        } else {
            out = string_concat(out, string_from_char(c))
        }
        i = i + 1
    }
    return out
}

// Clone an arbitrary snapshot into res_name (the recipe-driven fast path).
_bhyve_clone_from(res_name: string, snap: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo -n vm clone ${snap} ${res_name}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if status != 0 {
        return "aeo: 'vm clone ${snap} ${res_name}' failed: ${out}"
    }
    return ""
}

// Clone the golden base into res_name (fast copy-on-write) + start.
_bhyve_clone(res_name: string) -> string {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo -n vm clone aeo-base@golden ${res_name}")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if err != "" {
        return "aeo: vm clone failed for '${res_name}': ${err}"
    }
    if status != 0 {
        return "aeo: 'vm clone aeo-base@golden ${res_name}' failed: ${out}"
    }
    return ""
}

// Fetch the base image (idempotent) + create the VM with cloud-init.
_bhyve_provision(res_name: string, guest_image: string, ssh_key: string, network: string, cpus: int, mem: string) -> string {
    url = _image_url(guest_image)
    if url == "" {
        return "aeo: vm '${res_name}' unknown guest_image '${guest_image}'"
    }
    // Prefer the AMD-safe image (jammy-amd.img, made by patch-amd-image.sh):
    // its GRUB carries clocksource=hpet tsc=unstable ... so the guest boots
    // reliably on AMD Ryzen. Falls back to the stock cloud image.
    file = _image_file(url)
    if _amd_image_present() == 1 {
        file = "jammy-amd.img"
    }
    key = ssh_key
    if string_length(key) == 0 {
        key = "${_home()}/.ssh/id_rsa.pub"
    }
    nc = cpus
    if nc < 1 {
        nc = 1
    }
    mm = mem
    if string_length(mm) == 0 {
        mm = "1G"
    }
    // Generate a cloud-init user-data with the hard-won fixes baked in:
    //  - datasource_list:[NoCloud,None] — don't hang ~2min probing network
    //    metadata; read our seed (verified: avoids the long init stall).
    //  - ssh key install (so aeo can ssh into the guest).
    //  - a console password (ubuntu:aeo) for debugging.
    //  - the guest networks via netplan's default DHCP (its NIC is
    //    enp0s6, not eth0); with the datasource pin removing the init stall,
    //    it gets a lease on its own. A name-agnostic runcmd brings up every
    //    non-lo interface as a safety net.
    //  - install podman (the in-guest container runtime aeo-agent uses to
    //    run nested resources), so the guest is ready to host `app`.
    // The shell writes the YAML to a temp file then `vm create -C -u`.
    ud = "/tmp/aeo-ud-${res_name}.yml"
    sh = list_new()
    list_add(sh, "-c")
    // Use the NAT template (linux-nat) if test/setup-nat.sh created it —
    // NAT networking is reliable (local dnsmasq, no LAN-switch MAC issue);
    // else the bridged `linux` template. See test/setup-nat.sh + memory
    // bhyve-guest-networking.
    list_add(sh, "set -e; KEY=$(cat ${key}); TPL=linux; [ -f /zroot/vm/.templates/linux-nat.conf ] && TPL=linux-nat; printf '#cloud-config\\ndatasource_list: [ NoCloud, None ]\\nssh_pwauth: true\\nchpasswd:\\n  expire: false\\n  list: |\\n    ubuntu:aeo\\n    root:aeo\\nssh_authorized_keys:\\n  - %s\\npackage_update: true\\npackages:\\n  - podman\\nruncmd:\\n  - [ sh, -c, \"for i in $(ls /sys/class/net | grep -v lo); do ip link set $i up; done; dhclient || true\" ]\\n' \"$KEY\" > ${ud}; sudo -n vm img 2>/dev/null | grep -q ${file} || sudo -n vm img ${url}; sudo -n vm create -t $TPL -i ${file} -c ${_itoa(nc)} -m ${mm} -C -u ${ud} ${res_name}")
    out, status, err = run_capture("/bin/sh", sh, null)
    list_free(sh)
    if err != "" {
        return "aeo: vm provision spawn failed for '${res_name}': ${err}"
    }
    if status != 0 {
        return "aeo: vm provision failed for '${res_name}': ${out}"
    }
    return ""
}

// Map a guest_image id to its fetch URL (a full URL passes through).
// Ubuntu cloud images are the most reliable cloud-init+bhyve guest:
// cloud-init is Canonical's project, pre-installed/enabled, NoCloud reads
// the CIDATA seed, netplan-native, console behaves. (Debian genericcloud's
// cloud-init didn't run under our vm-bhyve seed; Alpine's fought us too.)
_image_url(idin: string) -> string {
    if string_contains(idin, "://") == 1 {
        return idin
    }
    // Composable name: "ubuntu-22.04+podman" -> resolve the OS base URL from
    // the part before the first '+'. The +layers (podman, etc.) are satisfied
    // by the golden clone / image recipe, not by the base image fetch.
    id = idin
    plus = string_index_of(idin, "+")
    if plus >= 0 {
        id = string_substring(idin, 0, plus)
    }
    if id == "ubuntu-22.04" {
        return "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
    }
    if id == "ubuntu-22.04-minimal" {
        // Canonical's minimized cloud image: ~309MB vs ~695MB standard (56%
        // smaller) but SAME systemd + netplan, so all our plumbing (static-IP
        // netplan, link-up unit, cold-path) is a drop-in. Lighter guest, zero
        // rewrite — vs Alpine (OpenRC/ifupdown) which would need a new realizer.
        return "https://cloud-images.ubuntu.com/minimal/releases/jammy/release/ubuntu-22.04-minimal-cloudimg-amd64.img"
    }
    if id == "ubuntu-24.04" {
        return "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
    }
    if id == "ubuntu-24.04-minimal" {
        // 251MB — the smallest systemd/netplan option (even lighter than
        // 22.04-minimal's 294MB).
        return "https://cloud-images.ubuntu.com/minimal/releases/noble/release/ubuntu-24.04-minimal-cloudimg-amd64.img"
    }
    if id == "alpine-3.20" {
        // 194MB — smallest overall, but OpenRC/ifupdown (not systemd/netplan),
        // so the recipe's systemd_unit/netplan fields don't apply on it.
        return "https://dl-cdn.alpinelinux.org/alpine/v3.20/releases/cloud/nocloud_alpine-3.20.3-x86_64-uefi-cloudinit-r0.qcow2"
    }
    if id == "debian-12" {
        return "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-amd64.qcow2"
    }
    return ""
}

// Basename of a URL (the local image filename vm-bhyve stores) — scan for
// the last '/'. (std.string has no last_index_of.)
_image_file(url: string) -> string {
    n = string_length(url)
    last = 0 - 1
    i = 0
    while i < n {
        if string_char_at(url, i) == 47 {     // '/'
            last = i
        }
        i = i + 1
    }
    if last < 0 {
        return url
    }
    return string_substring(url, last + 1, n)
}

// Turn a network() spec into a vm-bhyve -n netconfig string.
//   "dhcp"  -> "interface=eth0;ip=dhcp"
//   "ip=..;gateway4=.." -> "interface=eth0;<spec>"  (passed through)
_netconfig(spec: string) -> string {
    if spec == "dhcp" {
        return "interface=eth0;ip=dhcp"
    }
    if string_contains(spec, "interface=") == 1 {
        return spec
    }
    return "interface=eth0;${spec}"
}

// 1 if vm-bhyve reports the VM in a running state. `vm list` shows a
// STATE column; "Running" (any case) means up. We grep the line for the
// VM name + Running via a shell-out (simple + robust across vm versions).
_bhyve_running(res_name: string) -> int {
    av = list_new()
    list_add(av, "-c")
    list_add(av, "sudo vm list 2>/dev/null | awk -v n=${res_name} '$1==n && $0 ~ /[Rr]unning/ {print \"yes\"}'")
    out, status, err = run_capture("/bin/sh", av, null)
    list_free(av)
    if string_contains(out, "yes") == 1 {
        return 1
    }
    return 0
}

// Run `vm <sub> <name>` under sudo, capture (stdout, status, err). The
// argv must be freed AFTER run_capture returns, and a constructed tuple
// literal can't be returned (Aether limitation), so this stays inline at
// each call site via the helper below rather than returning the tuple.
// _vm_out / _vm_status give the two values callers need without a tuple.
_vm_out(sub: string, name: string) -> string {
    av = list_new()
    list_add(av, "vm")
    list_add(av, sub)
    list_add(av, name)
    out, status, err = run_capture("/usr/bin/sudo", av, null)
    list_free(av)
    return out
}
// 1 if `vm <sub> <name>` exited 0, else 0. (Spawn failure also → 0.)
_vm_ok(sub: string, name: string) -> int {
    av = list_new()
    list_add(av, "vm")
    list_add(av, sub)
    list_add(av, name)
    out, status, err = run_capture("/usr/bin/sudo", av, null)
    list_free(av)
    if err != "" {
        return 0
    }
    if status == 0 {
        return 1
    }
    return 0
}

_up_kvm(res_name: string, image: string, cpus: int, mem: string, tap: string) -> string {
    bin = os_which("qemu-system-x86_64")
    if bin == "" {
        return "aeo: kvm needs qemu-system-x86_64 on PATH (not found)"
    }
    // AGENT PATH: before boot, courier the agent into the guest via a NoCloud
    // seed (build_agent_seed writes /tmp/aeo-seed-<res_name>.iso, which qemu_argv
    // then attaches by that deterministic path). Only when AEO_AGENT_PATH=1 and no
    // seed was pre-supplied — so a plain `aeo up` auto-bootstraps the agent.
    if _agent_path_on_drv() == 1 {
        if string_length(_agent_seed(res_name)) == 0 {
            abin = _agent_binary()
            if string_length(abin) == 0 {
                return "aeo: agent path on but no aeo-agent binary found (set AEO_AGENT_BIN)"
            }
            _iso = build_agent_seed(res_name, _agent_token_drv(res_name), abin, _guest_pubkey())
            // build_agent_seed writes the deterministic path _agent_seed() finds.
        }
    }
    pf = pidfile_for(res_name)
    av = qemu_argv(res_name, image, cpus, mem, tap, pf)
    // Launch so the VM SURVIVES the aeo process exiting. A plain -daemonize'd
    // qemu spawned as a child of the (short-lived) aeo front-door gets SIGHUP'd
    // when its launching session scope is reaped on a systemd box (this bit the
    // first driver-driven boot — the manual systemd-run boot survived, the direct
    // one didn't). Prefer `systemd-run --user` (its own lingering scope); fall
    // back to setsid+nohup. NB: NOT -daemonize under systemd-run — let the unit
    // hold the foreground qemu so the scope stays alive.
    lerr = _launch_persistent(bin, av, res_name)
    list_free(av)
    if string_length(lerr) > 0 {
        return "aeo: qemu launch failed for '${res_name}': ${lerr}"
    }
    return ""
}

// Launch qemu so it outlives the aeo process. Builds one shell command that
// tries systemd-run --user (persistent scope) then falls back to setsid+nohup.
// Returns (out, status, err) like run_capture. The argv (from qemu_argv) is
// space-joined — VM argv is controlled (paths/sizes/ports), not arbitrary user
// text, so this is safe. Strips -daemonize when using systemd-run (the unit is
// the daemon); keeps the pidfile either way.
_launch_persistent(bin: string, av: ptr, res_name: string) -> string {
    // Reconstruct the qemu command line by interpolating each argv element
    // (list_get returns a ptr — interpolation converts it; DON'T compare it, per
    // the list_get footgun). qemu keeps its own -daemonize (it forks + writes the
    // pidfile); setsid detaches from the launching session so the SIGHUP that
    // reaps the aeo session scope doesn't kill the VM. This is the fix for the
    // driver-driven boot dying where the manual systemd-run boot survived.
    // systemd-run --user owns a LINGERING scope, so the VM survives the
    // short-lived aeo process — plain setsid+-daemonize does NOT survive on a
    // systemd box (the reaped user session scope kills the orphaned qemu; seen
    // live). Type=forking + PIDFile lets systemd track qemu's own -daemonize fork.
    //
    // Build the argv as a LIST passed straight to run_capture — do NOT interpolate
    // list_get elements into a string: list_get returns a ptr and "${a}" yields
    // the ADDRESS, not the arg (the LLM.md footgun — this bit here: qemu was
    // invoked with pointer addresses and failed "Could not open '4248494'"). Use
    // list_get_raw + list_add_raw to copy element ptrs verbatim.
    unit = "aeo-${res_name}"
    pf = pidfile_for(res_name)
    sr = os_which("systemd-run")
    if string_length(sr) == 0 {
        return "aeo: systemd-run not found — persistent VM launch needs it on this host"
    }
    // best-effort clear any prior unit of this name
    _systemctl_user_stop(unit)
    cmd = list_new()
    list_add(cmd, "--user")
    list_add(cmd, "--unit=${unit}")
    list_add(cmd, "--property=Type=forking")
    list_add(cmd, "--property=PIDFile=${pf}")
    list_add(cmd, bin)
    n = list_size(av)
    i = 0
    while i < n {
        list_add_raw(cmd, list_get_raw(av, i))   // copy the element PTR, verbatim
        i = i + 1
    }
    o, s, e = run_capture(sr, cmd, null)
    list_free(cmd)
    if s != 0 {
        return o                       // non-zero launch -> the error text
    }
    return ""                          // launched under a persistent systemd scope
}
_systemctl_user_stop(unit: string) {
    av = list_new()
    list_add(av, "--user")
    list_add(av, "stop")
    list_add(av, unit)
    o, s, e = run_capture("/usr/bin/systemctl", av, null)
    list_free(av)
}

// Tear the VM down. bhyve → `vm stop` (vm-bhyve). kvm → kill the recorded
// qemu pid. Absent/already-stopped == success.
down(kind: string, res_name: string) -> string {
    if kind == "bhyve" {
        // vm stop is a graceful ACPI poweroff; ignore failure (already off).
        _ = _vm_ok("stop", res_name)
        return ""
    }
    // kvm: kill the qemu pid.
    pid = _read_pid(res_name)
    if pid > 0 {
        _kill(pid)
    }
    _rm_pidfile(res_name)
    return ""
}

// Liveness probe. The VM must be up (bhyve → vm-bhyve "Running"; kvm →
// qemu pid alive) AND, if a health command is given, the host-side check
// exits 0 (e.g. `nc -z <ip> 22` / `curl http://<ip>/add/0/0`). Plain int.
probe(kind: string, res_name: string, health: string) -> int {
    if kind == "bhyve" {
        if _bhyve_running(res_name) == 0 {
            return 0
        }
    } else {
        if _pid_alive(res_name) == 0 {
            return 0
        }
    }
    // AGENT PATH: a kvm_vm's health is its RESIDENT AGENT answering — the VM is
    // "up" for orchestration only once the agent is reachable (that's what the
    // parent will dial). Probe the forwarded agent port's /health. This gates
    // the runner's bring-up so a nested child isn't delegated before the guest's
    // agent is live. (Explicit health() below still wins if the operator set one.)
    if _agent_path_on_drv() == 1 {
        if string_length(health) == 0 {
            hp = _agent_hostport(res_name)
            if hp > 0 {
                return _agent_health(hp)
            }
        }
    }
    if string_length(health) == 0 {
        return 1
    }
    // Host-side reachability check — run via /bin/sh -c so an operator can
    // write `nc -z 10.0.0.20 22` or `curl -fsS http://10.0.0.20/`.
    sh = list_new()
    list_add(sh, "-c")
    list_add(sh, health)
    out, status, err = run_capture("/bin/sh", sh, null)
    list_free(sh)
    if err != "" {
        return 0
    }
    if status == 0 {
        return 1
    }
    return 0
}

// --- pidfile + process helpers ---------------------------------------

// Build a shell command that launches `bin argv...` in the background and
// writes its pid to `pf`. argv elements are space-joined; VM argv here is
// controlled (paths/sizes), not arbitrary user text, so this is safe.
_bg_command(bin: string, argv: ptr, pf: string) -> string {
    line = bin
    n = list_size(argv)
    i = 0
    while i < n {
        a = list_get(argv, i)
        line = "${line} ${a}"
        i = i + 1
    }
    // `cmd & echo $! > pidfile` records the background pid.
    return "${line} >/tmp/aeo-vm-out.log 2>&1 & echo $! > ${pf}"
}

_read_pid(res_name: string) -> int {
    pf = pidfile_for(res_name)
    av = list_new()
    list_add(av, pf)
    out, status, err = run_capture("/bin/cat", av, null)
    list_free(av)
    if err != "" {
        return 0
    }
    if status != 0 {
        return 0
    }
    return _atoi(out)
}

// 1 if the VM's recorded pid is alive (kill -0), else 0.
_pid_alive(res_name: string) -> int {
    pid = _read_pid(res_name)
    if pid <= 0 {
        return 0
    }
    av = list_new()
    list_add(av, "-0")
    list_add(av, _itoa(pid))
    out, status, err = run_capture("/bin/kill", av, null)
    list_free(av)
    if err != "" {
        return 0
    }
    if status == 0 {
        return 1
    }
    return 0
}

_kill(pid: int) {
    av = list_new()
    list_add(av, _itoa(pid))
    _o, _s, _e = run_capture("/bin/kill", av, null)
    list_free(av)
}

_rm_pidfile(res_name: string) {
    av = list_new()
    list_add(av, "-f")
    list_add(av, pidfile_for(res_name))
    _o, _s, _e = run_capture("/bin/rm", av, null)
    list_free(av)
}

// int → string (no std wrapper that avoids a tuple here; hand-roll).
_itoa(n: int) -> string {
    if n == 0 {
        return "0"
    }
    neg = 0
    v = n
    if v < 0 {
        neg = 1
        v = 0 - v
    }
    s = ""
    while v > 0 {
        d = v - (v / 10) * 10
        s = "${_digit(d)}${s}"
        v = v / 10
    }
    if neg == 1 {
        return "-${s}"
    }
    return s
}

_digit(d: int) -> string {
    if d == 0 { return "0" }
    if d == 1 { return "1" }
    if d == 2 { return "2" }
    if d == 3 { return "3" }
    if d == 4 { return "4" }
    if d == 5 { return "5" }
    if d == 6 { return "6" }
    if d == 7 { return "7" }
    if d == 8 { return "8" }
    return "9"
}

// Parse leading digits of a string to int (cat output may have a newline).
_atoi(s: string) -> int {
    n = string_length(s)
    acc = 0
    i = 0
    while i < n {
        c = string_char_at(s, i)
        if c >= 48 {
            if c <= 57 {
                acc = acc * 10 + (c - 48)
            }
        }
        i = i + 1
    }
    return acc
}
